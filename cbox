#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVICE=cbox
CONF="$INSTALL_DIR/cbox.conf"

[ -f "$INSTALL_DIR/_common.sh" ] && . "$INSTALL_DIR/_common.sh"
[ -f "$INSTALL_DIR/templates/generators.sh" ] && . "$INSTALL_DIR/templates/generators.sh"
[ -f "$INSTALL_DIR/lib/cbox-ai.sh" ] && . "$INSTALL_DIR/lib/cbox-ai.sh"
[ -f "$INSTALL_DIR/lib/cbox-session.sh" ] && . "$INSTALL_DIR/lib/cbox-session.sh"

HAVE_GLOBAL_CONF=0
if [ -f "$CONF" ]; then
  source "$CONF"
  export CBOX_LOCAL_MODEL CBOX_LOCAL_MODEL_URL CBOX_LOCAL_MODEL_NAME
  export CBOX_HERMES CBOX_HERMES_VERSION CBOX_HERMES_PROVIDER CBOX_HERMES_MODEL_URL CBOX_HERMES_MODEL_NAME
  HAVE_GLOBAL_CONF=1
fi

COMPOSE=(docker compose -f "$INSTALL_DIR/docker-compose.yml")

require_global_conf() {
  [ "$HAVE_GLOBAL_CONF" = 1 ] || { echo "cbox: $CONF not found - run ./setup.sh first" >&2; exit 1; }
}

die_no_conf() {
  echo "cbox: no configuration applies to $PWD - run ./setup.sh (global) or ./setup.sh --local <root> (isolated) first" >&2
  exit 1
}

check_tpl_sha() {
  require_global_conf
  local cur
  cur="$(_cbox_tpl_sha)"
  if [ "$cur" != "${CBOX_TPL_SHA:-}" ]; then
    echo "cbox: templates changed since last generation - run $INSTALL_DIR/setup.sh update to re-bless"
    exit 1
  fi
}

_cbox_local_effdir_for() {
  local root="$1" p
  p="$(_cbox_path_hash "$root")"
  printf '%s/.config/cbox/projects/%s' "$HOME" "$p"
}

_cbox_root_in_global_scope() {
  local root="$1" w
  local -a ws=()
  read -r -a ws <<< "${CBOX_WORKSPACES:-}"
  for w in "${ws[@]}"; do
    [ -n "$w" ] || continue
    case "$root" in
      "$w"|"$w"/*) return 0 ;;
    esac
  done
  return 1
}

_cbox_effective_mode() {
  local root eff have_eff=0
  if root="$(_cbox_workspace_root 2>/dev/null)"; then
    eff="$(_cbox_local_effdir_for "$root")"
    [ -f "$eff/cbox.conf" ] && have_eff=1
  fi
  if [ "$HAVE_GLOBAL_CONF" = 1 ] && [ "${CBOX_MODE:-global}" = global ]; then
    if [ "$have_eff" = 1 ] && ! _cbox_root_in_global_scope "$root"; then
      printf 'isolated'
      return 0
    fi
    printf 'global'
    return 0
  fi
  if [ "$have_eff" = 1 ]; then
    printf 'isolated'
    return 0
  fi
  if [ "$HAVE_GLOBAL_CONF" = 1 ]; then
    printf '%s' "${CBOX_MODE:-global}"
    return 0
  fi
  printf 'none'
}

_compose_p() {
  local eff="$1"; shift
  docker compose --project-directory "$eff" -f "$eff/docker-compose.yml" "$@"
}

_cbox_compose_files_digest() {
  local expect_f=0 arg out=""
  for arg in "$@"; do
    if [ "$expect_f" = 1 ]; then
      expect_f=0
      [ -f "$arg" ] || continue
      out="$out$(sha256sum "$arg" | awk '{print $1}')"
      continue
    fi
    case "$arg" in
      -f|--file) expect_f=1 ;;
    esac
  done
  printf '%s' "$out" | sha256sum | awk '{print $1}'
}

_cbox_compose_up() {
  local stamp="$1"; shift
  local new old="" force=0 rc=0 have=""
  new="$(_cbox_compose_files_digest "$@")"
  [ -n "$stamp" ] && [ -f "$stamp" ] && old="$(cat "$stamp" 2>/dev/null || true)"
  have="$("$@" ps -q cbox 2>/dev/null | head -n1)" || have=""
  if [ -n "$have" ] && [ "$old" != "$new" ]; then
    force=1
  fi
  if [ "$force" = 1 ]; then
    "$@" up -d --force-recreate || rc=$?
  else
    "$@" up -d || rc=$?
  fi
  if [ "$rc" -eq 0 ] && [ -n "$stamp" ]; then
    printf '%s\n' "$new" > "$stamp" 2>/dev/null || true
  fi
  return "$rc"
}

_cbox_netaccess_render() {
  local container_id="$1" state_dir="$2" scope network cidr result internal_ip internal_cidr targets
  local -a args=()
  _cbox_proxy_active || return 0
  [ -n "$container_id" ] || { echo "cbox: netaccess proxy container is not running" >&2; return 1; }
  if _cbox_netaccess_active; then
    scope="$(_cbox_netaccess_scope)"
    for network in ${CBOX_NETACCESS_NETWORKS:-}; do
      args+=(--network "$network")
    done
    for cidr in ${CBOX_NETACCESS_CIDRS:-}; do
      args+=(--cidr "$cidr")
    done
  else
    scope=list
  fi
  result="$(python3 "$INSTALL_DIR/lib/cbox_netaccess.py" \
    --container "$container_id" \
    --state-dir "$state_dir" \
    --scope "$scope" \
    "${args[@]}")" || return 1
  internal_ip="$(python3 -c 'import json,sys; print(json.load(sys.stdin)["internalIp"])' <<<"$result")" || return 1
  internal_cidr="$(python3 -c 'import json,sys; print(json.load(sys.stdin)["internalCidr"])' <<<"$result")" || return 1
  targets="$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(" ".join(x["externalIp"]+","+x["cidr"] for x in d["targets"]))' <<<"$result")" || return 1
  if _cbox_egress_active; then
    gen_tinyproxy_conf_into "$state_dir" "$internal_ip"
  fi
  if _cbox_netaccess_active; then
    gen_sockd_conf_into "$state_dir" "$internal_ip" "$internal_cidr" "$targets"
  fi
}

_cbox_netaccess_apply_global() {
  _cbox_proxy_active || return 0
  local container_id
  container_id="$("${COMPOSE[@]}" ps -q proxy 2>/dev/null)" || container_id=""
  _cbox_netaccess_render "$container_id" "$INSTALL_DIR/generated/proxy" || return 1
  "${COMPOSE[@]}" restart proxy >/dev/null
}

_cbox_netaccess_apply_isolated() {
  local eff="$1" container_id
  _cbox_proxy_active || return 0
  container_id="$(_compose_p "$eff" ps -q proxy 2>/dev/null)" || container_id=""
  _cbox_netaccess_render "$container_id" "$eff/proxy" || return 1
  _compose_p "$eff" restart proxy >/dev/null
}

_run_global() {
  local bin="$1"; shift
  local workspaces=() w root inscope=0
  read -r -a workspaces <<< "${CBOX_WORKSPACES:-}"
  root="$(realpath "$PWD" 2>/dev/null || printf '%s' "$PWD")"
  for w in "${workspaces[@]}"; do
    [ -n "$w" ] || continue
    case "$root" in
      "$w"|"$w"/*) inscope=1; break ;;
    esac
  done
  if [ "${#workspaces[@]}" -gt 0 ] && [ "$inscope" != 1 ]; then
    if [ -t 0 ] && [ -t 1 ]; then
      local ans
      printf 'cbox: global container does not mount this folder - switch to an isolated per-project container? [y/N] '
      read -r ans
      case "$ans" in
        y|Y)
          _run_isolated "$bin" "$@"
          return
          ;;
        *)
          echo "cbox: cancelled" >&2
          return 1
          ;;
      esac
    else
      echo "cbox: global container does not mount $PWD and no TTY to confirm switching to isolated mode" >&2
      return 1
    fi
  fi
  check_tpl_sha
  _cbox_global_prepare_locked
  _gc_bg
  _bins_soft "$IMG_TAG"
  if _cbox_proxy_active; then "${COMPOSE[@]}" build >/dev/null; fi
  _clip_bridge_start "$(_cbox_clip_dir "${CBOX_NAME:-cbox}")"
  local workspace_scope
  workspace_scope="$(_cbox_workspace_root 2>/dev/null)" || workspace_scope="$root"
  _container_exec_bridge_start "$(_cbox_container_exec_dir "${CBOX_NAME:-cbox}")" "$workspace_scope" global || {
    _clip_bridge_stop
    return 1
  }
  _cbox_compose_up "$HOME/.config/cbox/compose.up.stamp" "${COMPOSE[@]}" >/dev/null || {
    _container_exec_bridge_stop
    _clip_bridge_stop
    return 1
  }
  _cbox_netaccess_apply_global || {
    _container_exec_bridge_stop
    _clip_bridge_stop
    return 1
  }
  local workdir="$CBOX_WORKDIR"
  for w in "${workspaces[@]}"; do
    case "$root" in
      "$w"|"$w"/*) workdir="$root" ;;
    esac
  done
  if [ -t 0 ] && [ -t 1 ]; then
    exec "${COMPOSE[@]}" exec -it "${CBOX_CONTAINER_EXEC_ENV[@]}" -w "$workdir" "$SERVICE" /entrypoint.sh "$bin" "$@"
  else
    exec "${COMPOSE[@]}" exec -T "${CBOX_CONTAINER_EXEC_ENV[@]}" -w "$workdir" "$SERVICE" /entrypoint.sh "$bin" "$@"
  fi
}

_first_run_init() {
  local root="$1" eff="$2" ans rc
  if ! { [ -t 0 ] && [ -t 1 ]; }; then
    echo "cbox: no effective config for $root and no TTY - run 'cbox run codex' interactively or 'setup.sh --local $root' first" >&2
    return 1
  fi
  mkdir -p "$HOME/.config/cbox/projects"
  exec 7> "$HOME/.config/cbox/projects/.init.lock"
  flock -w 60 7 || { echo "cbox: another init is running" >&2; exec 7>&-; return 1; }
  if [ -f "$eff/cbox.conf" ]; then
    exec 7>&-
    return 0
  fi
  printf 'cbox: new project %s\n  [n] configure from scratch\n  [d] derive from global config\n  [z] cancel\n> ' "$root"
  read -r ans
  rc=0
  case "$ans" in
    n) "$INSTALL_DIR/setup.sh" --local "$root" || rc=$? ;;
    d) "$INSTALL_DIR/setup.sh" --local "$root" --from-global || rc=$? ;;
    *) echo "cbox: cancelled" >&2; exec 7>&-; return 1 ;;
  esac
  exec 7>&-
  [ "$rc" -eq 0 ] && [ -f "$eff/cbox.conf" ]
}

_gen_effective() {
  local eff="$1" root="$2" digest
  digest="$(_cbox_resolve_base_digest ubuntu:24.04)" || die "cannot resolve base image digest and no local image - network required for first build"
  cp "$INSTALL_DIR/entrypoint.sh" "$eff/entrypoint.sh"
  cp "$INSTALL_DIR/install-bins.sh" "$eff/install-bins.sh"
  cp "$INSTALL_DIR/.dockerignore" "$eff/.dockerignore"
  gen_image_inputs "$eff" "$digest"
  IMG_HASH="$(_cbox_image_hash "$eff")"
  IMG_TAG="$(_cbox_image_tag "$IMG_HASH")"
  gen_dockerfile_into "$eff" "$digest"
  gen_env_file_into "$eff"
  gen_compose_isolated "$eff" "$root" "$IMG_TAG" "$IMG_HASH"
  gen_compose_readonly_into "$eff/docker-compose.readonly.yml" "$root"
  gen_codex_profile_into "$eff/codex" isolated "$root"
  gen_codex_agents_into "$eff/codex"
  gen_codex_hooks_json_into "$eff/codex"
  if [ "${CBOX_HERMES:-off}" = on ]; then
    gen_hermes_managed_into "$eff/hermes/managed.env"
  else
    rm -f "$eff/hermes/managed.env"
  fi
}

_ensure_image() {
  local eff="$1" img_hash img_tag base
  img_hash="$(_cbox_image_hash "$eff")"
  img_tag="$(_cbox_image_tag "$img_hash")"
  IMG_HASH="$img_hash"
  IMG_TAG="$img_tag"
  docker image inspect "$img_tag" >/dev/null 2>&1 && return 0
  echo "cbox: building $img_tag (inputs changed or first build)" >&2
  base="$(_cbox_manifest_field "$eff/image.inputs" base 2>/dev/null || true)"
  docker build -t "$img_tag" \
    --label "cbox.inputs=$img_hash" \
    --label "cbox.base=$base" \
    -f "$eff/Dockerfile" "$eff"
}

_bins_cache_file() {
  printf '%s/.config/cbox/bins.stamp' "$HOME"
}

_bins_lock_file() {
  printf '%s/.config/cbox/bins.lock' "$HOME"
}

_bins_want() {
  local tool="$1"
  case "$tool" in
    claude) printf '%s' "${CBOX_CLAUDE_TARGET:-stable}" ;;
    codex) printf '%s|%s' "${CBOX_CODEX_VERSION:-latest}" "${CBOX_CODEX_TARGET:-}" ;;
  esac
}

_bins_cache_get() {
  local volume="$1" cache line
  cache="$(_bins_cache_file)"
  [ -f "$cache" ] || return 1
  line="$(grep -F "$volume|" "$cache" 2>/dev/null | tail -n1)" || true
  [ -n "$line" ] || return 1
  printf '%s' "$line"
}

_bins_cache_put() {
  local volume="$1" tool="$2" want="$3" version="$4" cache dir tmp
  cache="$(_bins_cache_file)"
  dir="$(dirname "$cache")"
  mkdir -p "$dir"
  tmp="$(mktemp "$dir/.cbox.XXXXXX")"
  {
    if [ -f "$cache" ]; then
      grep -Fv "$volume|" "$cache" 2>/dev/null || true
    fi
    printf '%s|%s|%s|%s|%s\n' "$volume" "$tool" "$want" "$version" "$(date +%s)"
  } > "$tmp"
  mv "$tmp" "$cache"
}

_bins_cache_field() {
  local line="$1" field="$2"
  printf '%s' "$line" | awk -F'|' -v f="$field" '{
    n = NF
    if (f == "volume") { print $1; next }
    if (f == "tool") { print $2; next }
    if (f == "version") { print $(n - 1); next }
    if (f == "epoch") { print $n; next }
    if (f == "want") {
      out = $3
      for (i = 4; i <= n - 2; i++) out = out "|" $i
      print out
      next
    }
  }'
}

_bins_stale() {
  local volume="$1" tool="$2" want="$3" line cur_tool cur_want
  docker volume inspect "$volume" >/dev/null 2>&1 || return 0
  line="$(_bins_cache_get "$volume")" || return 0
  cur_tool="$(_bins_cache_field "$line" tool)"
  cur_want="$(_bins_cache_field "$line" want)"
  [ "$cur_tool" = "$tool" ] || return 0
  [ "$cur_want" = "$want" ] || return 0
  return 1
}

_bins_run_install() {
  local img_tag="$1" tools="$2" force="$3" claude_vol codex_vol rc line name version hash status status_word
  claude_vol="$(_cbox_bins_volume claude)"
  codex_vol="$(_cbox_bins_volume codex)"
  docker volume create "$claude_vol" >/dev/null
  docker volume create "$codex_vol" >/dev/null
  rc=0
  status="$(docker run --rm \
    -v "$claude_vol:$HOME/.local:rw" \
    -v "$codex_vol:$HOME/.codex/packages:rw" \
    -e HOST_USER="$(id -un)" \
    -e HOST_UID="$(id -u)" \
    -e HOST_GID="$(id -g)" \
    -e HOST_HOME="$HOME" \
    -e CBOX_CLAUDE_TARGET="${CBOX_CLAUDE_TARGET:-stable}" \
    -e CBOX_CODEX_VERSION="${CBOX_CODEX_VERSION:-latest}" \
    -e CBOX_CODEX_TARGET="${CBOX_CODEX_TARGET:-}" \
    -e CBOX_INSTALL_TOOLS="$tools" \
    -e CBOX_INSTALL_FORCE="$force" \
    --entrypoint /opt/cbox/install-bins.sh \
    "$img_tag")" || rc=$?
  printf '%s\n' "$status" | while IFS= read -r line; do
    case "$line" in
      ""|cbox-bins:*) ;;
      *) echo "$line" >&2 ;;
    esac
  done
  while IFS= read -r line; do
    case "$line" in
      cbox-bins:*)
        name="$(printf '%s' "$line" | awk '{print $2}')"
        version="$(printf '%s' "$line" | awk '{print $3}')"
        hash="$(printf '%s' "$line" | awk '{print $4}')"
        status_word="$(printf '%s' "$line" | awk '{print $5}')"
        case "$status_word" in
          refuse|fail)
            echo "cbox: bins install refused for $name (see message above) - re-pin the project, run '$0 reinstall-bins' to move the shared tuple, or set CBOX_BINS_SCOPE=pinned for a private volume" >&2
            rc=1
            ;;
          ok|adopt)
            _bins_cache_put "$(_cbox_bins_volume "$name")" "$name" "$(_bins_want "$name")" "$version"
            ;;
        esac
        ;;
    esac
  done <<< "$status"
  return "$rc"
}

_ensure_bins() {
  local img_tag="$1" force="${2:-0}" lock claude_vol codex_vol
  local -a stale_tools=()
  claude_vol="$(_cbox_bins_volume claude)"
  codex_vol="$(_cbox_bins_volume codex)"
  if [ "$force" != 1 ]; then
    _bins_stale "$claude_vol" claude "$(_bins_want claude)" && stale_tools+=(claude)
    _bins_stale "$codex_vol" codex "$(_bins_want codex)" && stale_tools+=(codex)
    [ "${#stale_tools[@]}" -eq 0 ] && return 0
  else
    stale_tools=(claude codex)
  fi
  lock="$(_bins_lock_file)"
  mkdir -p "$(dirname "$lock")"
  exec 6> "$lock"
  flock -w 900 6 || { echo "cbox: timed out waiting for another bins install to finish" >&2; exec 6>&-; return 1; }
  if [ "$force" != 1 ]; then
    stale_tools=()
    _bins_stale "$claude_vol" claude "$(_bins_want claude)" && stale_tools+=(claude)
    _bins_stale "$codex_vol" codex "$(_bins_want codex)" && stale_tools+=(codex)
    if [ "${#stale_tools[@]}" -eq 0 ]; then
      exec 6>&-
      return 0
    fi
  fi
  echo "cbox: installing/updating binaries (${stale_tools[*]}) into shared volumes" >&2
  local rc=0
  _bins_run_install "$img_tag" "${stale_tools[*]}" "$force" || rc=$?
  exec 6>&-
  return "$rc"
}

_bins_soft() {
  _ensure_bins "$@" || echo "cbox: warning: bins install failed - continuing; affected tools stay unavailable until you fix the pin or network and run '$0 reinstall-bins'" >&2
  _bins_autoupdate_bg "$1"
  return 0
}

_bins_channel() {
  case "$1" in
    claude)
      case "${CBOX_CLAUDE_TARGET:-stable}" in stable|latest) return 0 ;; esac
      ;;
    codex)
      case "${CBOX_CODEX_VERSION:-latest}" in latest) return 0 ;; esac
      ;;
  esac
  return 1
}

_engine_autoupdate_off() {
  case "$1" in
    claude)
      grep -Eqs '"autoUpdates"[[:space:]]*:[[:space:]]*false' "$HOME/.claude/settings.json"
      ;;
    codex)
      grep -Eqs '^[[:space:]]*check_for_update_on_startup[[:space:]]*=[[:space:]]*false' "$HOME/.codex/config.toml"
      ;;
    *)
      return 1
      ;;
  esac
}

_bins_autoupdate() {
  local img_tag="$1" ttl_h="${CBOX_AUTOUPDATE_TTL_HOURS:-24}" tool stampdir stampf last now lock
  case "$ttl_h" in ''|*[!0-9]*) ttl_h=24 ;; esac
  stampdir="$HOME/.config/cbox"
  now="$(date +%s)"
  local -a due=()
  for tool in claude codex; do
    _bins_channel "$tool" || continue
    _engine_autoupdate_off "$tool" && continue
    stampf="$stampdir/autoupdate.$(_cbox_bins_volume "$tool").stamp"
    last="$(cat "$stampf" 2>/dev/null || echo 0)"
    case "$last" in ''|*[!0-9]*) last=0 ;; esac
    [ "$last" -gt "$now" ] && last=0
    [ $((now - last)) -ge $((ttl_h * 3600)) ] && due+=("$tool")
  done
  [ "${#due[@]}" -gt 0 ] || return 0
  lock="$(_bins_lock_file)"
  mkdir -p "$stampdir"
  exec 5> "$lock"
  flock -n 5 || { exec 5>&-; return 0; }
  for tool in "${due[@]}"; do
    printf '%s\n' "$now" > "$stampdir/autoupdate.$(_cbox_bins_volume "$tool").stamp"
  done
  echo "cbox: autoupdate: refreshing channel bins (${due[*]}) at $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  _bins_run_install "$img_tag" "${due[*]}" refresh || echo "cbox: autoupdate: install failed; next attempt after TTL"
  exec 5>&-
}

_bins_autoupdate_bg() {
  [ "${CBOX_AUTOUPDATE:-on}" = on ] || return 0
  local img_tag="$1" log="$HOME/.config/cbox/autoupdate.log"
  mkdir -p "$HOME/.config/cbox"
  ( _bins_autoupdate "$img_tag" >> "$log" 2>&1 ) </dev/null >/dev/null 2>&1 &
  disown 2>/dev/null || true
}

_bins_conflict_scan() {
  local tool="$1" want="$2" proj conf p_want p_scope hits=""
  for proj in "$HOME"/.config/cbox/projects/*/; do
    [ -d "$proj" ] || continue
    conf="$proj/cbox.conf"
    [ -f "$conf" ] || continue
    p_want="$(unset CBOX_CLAUDE_TARGET CBOX_CODEX_VERSION CBOX_CODEX_TARGET CBOX_BINS_SCOPE; source "$conf" 2>/dev/null; _bins_want "$tool")"
    p_scope="$(unset CBOX_BINS_SCOPE; source "$conf" 2>/dev/null; printf '%s' "${CBOX_BINS_SCOPE:-global}")"
    [ "$p_scope" = "global" ] || continue
    if [ "$p_want" != "$want" ]; then
      hits="$hits $(basename "$proj")"
    fi
  done
  printf '%s' "${hits# }"
}

reinstall_bins() {
  local fresh=0 if_stale=0
  case "${1:-}" in
    --fresh) fresh=1; shift ;;
    --if-stale) if_stale=1; shift ;;
  esac
  local mode img_tag force=0 hits_claude hits_codex
  mode="$(_cbox_effective_mode)"
  case "$mode" in
    isolated)
      local root eff
      root="$(_cbox_workspace_root)" || die "refusing to run in $PWD (home, /, or a mount root)"
      eff="$HOME/.config/cbox/projects/$(_cbox_path_hash "$root")"
      [ -f "$eff/cbox.conf" ] || die "no effective config for $root - run 'cbox run codex' or 'setup.sh --local $root' first"
      (
        set -e
        unset CBOX_MODE CBOX_SESSION_SCOPE CBOX_BASE_DIGEST_TTL CBOX_CODEX_TARGET
        . "$eff/cbox.conf"
        img_tag="$(_cbox_image_tag "$(_cbox_image_hash "$eff")")"
        docker image inspect "$img_tag" >/dev/null 2>&1 || die "image $img_tag not built - run 'cbox run codex' first"
        if [ "$if_stale" = 1 ]; then
          _ensure_bins "$img_tag" 0
        else
          if [ "$fresh" = 1 ]; then
            force=1
            docker volume rm "$(_cbox_bins_volume claude)" >/dev/null 2>&1 || true
            docker volume rm "$(_cbox_bins_volume codex)" >/dev/null 2>&1 || true
          else
            hits_claude="$(_bins_conflict_scan claude "$(_bins_want claude)")"
            hits_codex="$(_bins_conflict_scan codex "$(_bins_want codex)")"
            [ -z "$hits_claude" ] || echo "cbox: moving the shared claude tuple will make these projects mismatch:$hits_claude" >&2
            [ -z "$hits_codex" ] || echo "cbox: moving the shared codex tuple will make these projects mismatch:$hits_codex" >&2
          fi
          _ensure_bins "$img_tag" "$force"
        fi
      )
      ;;
    global)
      require_global_conf
      [ -f "$INSTALL_DIR/image.inputs" ] || die "global image inputs missing - run 'cbox up' first"
      img_tag="$(_cbox_image_tag "$(_cbox_image_hash "$INSTALL_DIR")")"
      docker image inspect "$img_tag" >/dev/null 2>&1 || die "image $img_tag not built - run 'cbox up' first"
      if [ "$if_stale" = 1 ]; then
        _ensure_bins "$img_tag" 0
        return
      fi
      if [ "$fresh" = 1 ]; then
        force=1
        docker volume rm "$(_cbox_bins_volume claude)" >/dev/null 2>&1 || true
        docker volume rm "$(_cbox_bins_volume codex)" >/dev/null 2>&1 || true
      else
        hits_claude="$(_bins_conflict_scan claude "$(_bins_want claude)")"
        hits_codex="$(_bins_conflict_scan codex "$(_bins_want codex)")"
        [ -z "$hits_claude" ] || echo "cbox: moving the shared claude tuple will make these projects mismatch:$hits_claude" >&2
        [ -z "$hits_codex" ] || echo "cbox: moving the shared codex tuple will make these projects mismatch:$hits_codex" >&2
      fi
      _ensure_bins "$img_tag" "$force"
      ;;
    *)
      die_no_conf
      ;;
  esac
}

_ensure_volumes() {
  local eff="$1" p_hash
  p_hash="$(_cbox_path_hash "$(cat "$eff/workspace")")"
  if [ "${CBOX_CLAUDE_MODE:-mount}" = volume ]; then
    docker volume create "cbox-p${p_hash}-claude" >/dev/null
  fi
  if [ "${CBOX_CODEX_MODE:-mount}" = volume ]; then
    docker volume create "cbox-p${p_hash}-codex" >/dev/null
  fi
  if [ "${CBOX_VENV_MODE:-none}" = volume ]; then
    docker volume create "cbox-p${p_hash}-venv" >/dev/null
  fi
  case "${CBOX_SSH_MODE:-none}" in
    container-keys|mixed) docker volume create "cbox-p${p_hash}-ssh" >/dev/null ;;
  esac
}

_mirror_write_one() {
  local dir="$1" src="$2" name="$3" tmp
  [ -f "$src" ] || return 0
  tmp="$(mktemp "$dir/.cbox.XXXXXX")" || return 0
  if cp "$src" "$tmp" 2>/dev/null; then
    chmod 0644 "$tmp"
    mv "$tmp" "$dir/$name" 2>/dev/null || rm -f "$tmp"
  else
    rm -f "$tmp"
  fi
}

_write_mirror() {
  local root="$1" eff="$2" dir tmp
  dir="$root/.cbox/runtime"
  if [ -L "$root/.cbox" ] || [ -L "$dir" ]; then
    echo "cbox: warning: $dir is a symlink - skipping mirror" >&2
    return 0
  fi
  mkdir -p "$dir" 2>/dev/null || { echo "cbox: warning: cannot create $dir - skipping mirror" >&2; return 0; }
  case "$(realpath "$dir" 2>/dev/null)" in
    "$root"/*) ;;
    *) echo "cbox: warning: $dir escapes workspace - skipping mirror" >&2; return 0 ;;
  esac
  _mirror_write_one "$dir" "$eff/docker-compose.yml" docker-compose.mirror.yml
  _mirror_write_one "$dir" "$eff/cbox.conf" cbox.conf.mirror
  _mirror_write_one "$dir" "$eff/Dockerfile" Dockerfile.mirror
  _mirror_write_one "$dir" "$eff/image.inputs" image-inputs.mirror
  tmp="$(mktemp "$dir/.cbox.XXXXXX")"
  if [ -n "$tmp" ]; then
    printf '*\n' > "$tmp"
    mv "$tmp" "$dir/.gitignore" 2>/dev/null || rm -f "$tmp"
  fi
  tmp="$(mktemp "$dir/.cbox.XXXXXX")"
  if [ -n "$tmp" ]; then
    {
      printf 'mirror of %s\n' "$eff"
      printf 'not authoritative; edits here have no effect and are overwritten\n'
      printf 'add .cbox/runtime/ (never .cbox/) to your repo .gitignore if you want it untracked there too\n'
    } > "$tmp"
    mv "$tmp" "$dir/README" 2>/dev/null || rm -f "$tmp"
  fi
}

_CBOX_PROBE_SH='
cp="$(sed -n 2p "$HOST_HOME/.local/.cbox-stamp" 2>/dev/null)"
xp="$(sed -n 2p "$HOST_HOME/.codex/packages/.cbox-stamp" 2>/dev/null)"
n=0
for p in /proc/[0-9]*/exe; do
  e="$(readlink "$p" 2>/dev/null)" || continue
  e="${e% (deleted)}"
  d="${p%/exe}/cmdline"
  if [ -n "$cp" ] && [ "$e" = "$cp" ]; then
    [ -e "$d" ] || continue
    a1="$(tr "\0" "\n" < "$d" 2>/dev/null | sed -n 2p)"
    case "$a1" in daemon|--bg-pty-host|--bg-spare) continue ;; esac
    n=$((n+1)); continue
  fi
  if [ -n "$xp" ] && [ "$e" = "$xp" ]; then
    [ -e "$d" ] || continue
    a1="$(tr "\0" "\n" < "$d" 2>/dev/null | sed -n 2p)"
    case "$a1" in mcp-server) continue ;; esac
    n=$((n+1)); continue
  fi
  case "$e" in
    /usr/bin/python3*|/opt/hermes/bin/python3*)
      [ -e "$d" ] || continue
      a0="$(tr "\0" "\n" < "$d" 2>/dev/null | sed -n 1p)"
      case "$a0" in
        /opt/hermes/bin/*)
          a1="$(tr "\0" "\n" < "$d" 2>/dev/null | sed -n 2p)"
          case "$a1" in
            /opt/hermes/bin/hermes|/usr/local/bin/hermes) n=$((n+1)) ;;
          esac
          ;;
      esac
      ;;
  esac
done
printf %s "$n"
'

_probe() {
  docker exec "$1" sh -c "$_CBOX_PROBE_SH"
}

_reap() {
  local eff="$1" cid n
  exec 9> "$eff/session.lock"
  if ! flock -n -x 9; then
    exec 9>&-
    return 0
  fi
  cid="$(_compose_p "$eff" ps -q cbox 2>/dev/null)" || cid=""
  if [ -z "$cid" ]; then
    exec 9>&-
    return 0
  fi
  n="$(_probe "$cid" 2>/dev/null)" || n=unknown
  case "$n" in ''|*[!0-9]*) n=unknown ;; esac
  if [ "$n" = unknown ]; then
    sleep 1
    n="$(_probe "$cid" 2>/dev/null)" || n=unknown
    case "$n" in ''|*[!0-9]*) n=unknown ;; esac
  fi
  if [ "$n" = unknown ]; then
    echo "cbox: probe failed for ${cid:0:12}; container left up, cbox gc will retry" >&2
  elif [ "$n" = 0 ]; then
    _compose_p "$eff" down --remove-orphans >/dev/null 2>&1 || true
  fi
  exec 9>&-
}

_clip_bridge_start() {
  [ "${CBOX_CLIPBOARD_MODE:-off}" = bridge ] || return 0
  local dir="$1"
  [ -f "$INSTALL_DIR/etc/clipboard/clip_bridge.py" ] || return 0
  mkdir -p -m 0700 "$dir" 2>/dev/null || true
  python3 "$INSTALL_DIR/etc/clipboard/clip_bridge.py" --sock-dir "$dir" --parent-pid "${BASHPID:-$$}" >/dev/null 2>&1 &
  _CBOX_CLIP_PID=$!
}

_clip_bridge_stop() {
  [ -n "${_CBOX_CLIP_PID:-}" ] || return 0
  kill "$_CBOX_CLIP_PID" 2>/dev/null || true
  _CBOX_CLIP_PID=""
}

_container_exec_bridge_start() {
  local dir="$1" workspace_root="${2:-}" workspace_mode="${3:-isolated}" network token socket_dir audit_dir parent_pid parent_start root
  local -a networks=() workspace_args=() guard_roots=()
  CBOX_CONTAINER_EXEC_ENV=()
  _cbox_netaccess_exec_active || return 0
  [ -f "$INSTALL_DIR/etc/container/docker_exec_bridge.py" ] || return 1
  for network in ${CBOX_NETACCESS_NETWORKS:-}; do
    networks+=("$network")
  done
  [ "${#networks[@]}" -gt 0 ] || return 1
  if [ "${CBOX_NETACCESS_EXEC_WORKSPACE_GUARD:-off}" = on ]; then
    if [ "$workspace_mode" = global ]; then
      read -r -a guard_roots <<< "${CBOX_WORKSPACES:-}"
    else
      [ -n "$workspace_root" ] || workspace_root="$(_cbox_workspace_root 2>/dev/null)" || return 1
      guard_roots=("$workspace_root")
    fi
    [ "${#guard_roots[@]}" -gt 0 ] || return 1
    for root in "${guard_roots[@]}"; do
      root="$(realpath "$root" 2>/dev/null)" || return 1
      [ -d "$root" ] && [ "$root" != / ] || return 1
      workspace_args+=(--workspace-root "$root")
    done
  fi
  token="p${BASHPID:-$$}-$(od -An -tx1 -N4 /dev/urandom 2>/dev/null | tr -d ' \n')"
  case "$token" in *-) token="p${BASHPID:-$$}-${RANDOM}${RANDOM}" ;; esac
  socket_dir="$dir/sockets/$token"
  audit_dir="$dir/audit"
  mkdir -p -m 0700 "$socket_dir" "$audit_dir"
  chmod 0700 "$dir" "$dir/sockets" "$socket_dir" "$audit_dir"
  parent_pid="${BASHPID:-$$}"
  parent_start="$(awk '{print $22}' "/proc/$parent_pid/stat" 2>/dev/null)" || return 1
  case "$parent_start" in ''|*[!0-9]*) return 1 ;; esac
  python3 "$INSTALL_DIR/etc/container/docker_exec_bridge.py" \
    --sock-dir "$socket_dir" \
    --parent-pid "$parent_pid" \
    --parent-start "$parent_start" \
    --audit-path "$audit_dir/$token.jsonl" \
    --timeout "${CBOX_NETACCESS_EXEC_TIMEOUT:-900}" \
    --max-bytes "${CBOX_NETACCESS_EXEC_MAX_BYTES:-10485760}" \
    "${workspace_args[@]}" \
    --networks "${networks[@]}" >/dev/null 2>&1 &
  _CBOX_CONTAINER_EXEC_PID=$!
  _CBOX_CONTAINER_EXEC_SOCKET_HOST_DIR="$socket_dir"
  CBOX_CONTAINER_EXEC_ENV=(-e "CBOX_CONTAINER_EXEC_SOCKET=/run/cbox-container-exec/$token/bridge.sock")
  local i
  for i in {1..20}; do
    [ -S "$socket_dir/bridge.sock" ] && return 0
    kill -0 "$_CBOX_CONTAINER_EXEC_PID" 2>/dev/null || break
    sleep 0.1
  done
  _container_exec_bridge_stop
  CBOX_CONTAINER_EXEC_ENV=()
  echo "cbox: scoped container exec bridge failed to start" >&2
  return 1
}

_container_exec_bridge_stop() {
  [ -n "${_CBOX_CONTAINER_EXEC_PID:-}" ] || return 0
  kill "$_CBOX_CONTAINER_EXEC_PID" 2>/dev/null || true
  wait "$_CBOX_CONTAINER_EXEC_PID" 2>/dev/null || true
  _CBOX_CONTAINER_EXEC_PID=""
  [ -z "${_CBOX_CONTAINER_EXEC_SOCKET_HOST_DIR:-}" ] || rmdir "$_CBOX_CONTAINER_EXEC_SOCKET_HOST_DIR" 2>/dev/null || true
  _CBOX_CONTAINER_EXEC_SOCKET_HOST_DIR=""
  CBOX_CONTAINER_EXEC_ENV=()
}

_session_sig() {
  local sig="$1"
  trap - INT TERM HUP
  exec 8>&- 2>/dev/null || true
  _container_exec_bridge_stop
  _clip_bridge_stop
  _reap "$_CBOX_SESSION_EFF"
  kill -s "$sig" "${BASHPID:-$$}" 2>/dev/null
  exit 1
}

_session_run() {
  local eff="$1" bin="$2"; shift 2
  local rc=0 wd root
  local use_session_env=0
  local -a extra_env=()
  if [ "${1:-}" = "--session-env" ]; then
    shift
    use_session_env=1
  fi
  local pre_hook=""
  if [ "${1:-}" = "--pre-hook" ]; then
    pre_hook="$2"
    shift 2
  fi
  local post_hook=""
  if [ "${1:-}" = "--post-hook" ]; then
    post_hook="$2"
    shift 2
  fi
  if [ "${1:-}" = "--" ]; then
    shift
  fi
  root="$(cat "$eff/workspace" 2>/dev/null || printf '%s' "$PWD")"
  exec 8> "$eff/session.lock"
  flock -s 8 || { echo "cbox: cannot lock session for $eff" >&2; exec 8>&-; return 1; }
  _gc_bg
  _CBOX_SESSION_EFF="$eff"
  trap '_session_sig INT' INT
  trap '_session_sig TERM' TERM
  trap '_session_sig HUP' HUP
  _clip_bridge_start "$(_cbox_clip_dir "p$(basename "$eff")")"
  _container_exec_bridge_start "$(_cbox_container_exec_dir "p$(basename "$eff")")" "$root" || {
    trap - INT TERM HUP
    _clip_bridge_stop
    exec 8>&-
    return 1
  }
  _cbox_compose_up "$eff/.compose.up.stamp" docker compose --project-directory "$eff" -f "$eff/docker-compose.yml" || {
    trap - INT TERM HUP
    _container_exec_bridge_stop
    _clip_bridge_stop
    exec 8>&-
    return 1
  }
  _cbox_netaccess_apply_isolated "$eff" || {
    trap - INT TERM HUP
    _container_exec_bridge_stop
    _clip_bridge_stop
    exec 8>&-
    return 1
  }
  if [ -n "$pre_hook" ]; then
    "$pre_hook" || true
  fi
  extra_env=("${CBOX_CONTAINER_EXEC_ENV[@]}")
  if [ "$use_session_env" = 1 ]; then
    extra_env+=("${CBOX_SESSION_EXEC_ENV[@]}")
  fi
  wd="$(realpath "$PWD" 2>/dev/null || printf '%s' "$PWD")"
  case "$wd" in
    "$root"|"$root"/*) ;;
    *) wd="$root" ;;
  esac
  if [ -t 0 ] && [ -t 1 ]; then
    _compose_p "$eff" exec -it "${extra_env[@]}" -w "$wd" cbox /entrypoint.sh "$bin" "$@" || rc=$?
  else
    _compose_p "$eff" exec -T "${extra_env[@]}" -w "$wd" cbox /entrypoint.sh "$bin" "$@" || rc=$?
  fi
  if [ -n "$post_hook" ]; then
    "$post_hook" "$rc" || true
  fi
  exec 8>&-
  trap - INT TERM HUP
  _container_exec_bridge_stop
  _clip_bridge_stop
  _reap "$eff"
  return "$rc"
}

_cbox_rebless_local() {
  local root="$1" eff="$2" rc=0
  mkdir -p "$HOME/.config/cbox/projects"
  exec 7> "$HOME/.config/cbox/projects/.init.lock"
  flock -w 60 7 || { echo "cbox: another init is running" >&2; exec 7>&-; return 1; }
  "$INSTALL_DIR/setup.sh" --local "$root" --from-global || rc=$?
  exec 7>&-
  [ "$rc" -eq 0 ] && [ -f "$eff/cbox.conf" ]
}

_cbox_manifest_verify_conf_interactive() {
  local eff="$1" root="$2" status ans reason
  status="$(_cbox_manifest_status "$eff" "$root")"
  case "$status" in
    missing|malformed|drifted)
      if [ -t 0 ] && [ -t 1 ]; then
        case "$status" in
          missing)  reason="manifest missing" ;;
          malformed) reason="manifest malformed" ;;
          drifted)  reason="config/templates drifted" ;;
        esac
        printf 'cbox: effective config for %s: %s.\n  Re-derive from the global profile now? [Y/n] ' "$root" "$reason"
        read -r ans || ans=n
        case "$ans" in
          n|N) : ;;
          *) _cbox_rebless_local "$root" "$eff" || die "re-bless failed for $root" ;;
        esac
      fi
      ;;
  esac
  _cbox_manifest_verify_conf "$eff" "$root"
}

_run_isolated() {
  local bin="$1"; shift
  local root P eff
  root="$(_cbox_workspace_root)" || die "refusing to run in $PWD (home, /, or a mount root)"
  _cbox_check_workspace_overlap "$root"
  P="$(_cbox_path_hash "$root")"
  eff="$HOME/.config/cbox/projects/$P"
  if [ ! -f "$eff/cbox.conf" ]; then
    _first_run_init "$root" "$eff" || return 1
  fi
  _cbox_manifest_verify_conf_interactive "$eff" "$root"
  (
    set -e
    unset CBOX_MODE CBOX_SESSION_SCOPE CBOX_BASE_DIGEST_TTL CBOX_CODEX_TARGET
    local lockfile="$eff/.regen.lock"
    exec 6> "$lockfile"
    flock -x 6 || { echo "cbox: cannot lock $lockfile" >&2; exit 1; }
    . "$eff/cbox.conf"
    export CBOX_LOCAL_MODEL CBOX_LOCAL_MODEL_URL CBOX_LOCAL_MODEL_NAME
    export CBOX_HERMES CBOX_HERMES_VERSION CBOX_HERMES_PROVIDER CBOX_HERMES_MODEL_URL CBOX_HERMES_MODEL_NAME
    _gen_effective "$eff" "$root"
    local slug
    slug="$(_cbox_slug "$root")"
    mkdir -p "$HOME/.claude/projects/$slug"
    _write_mirror "$root" "$eff"
    _cbox_manifest_write_generated "$eff"
    exec 6>&-
    _ensure_image "$eff"
    _bins_soft "$IMG_TAG"
    _ensure_volumes "$eff"
    _session_run "$eff" "$bin" "$@"
  )
}

_gc_bg() {
  mkdir -p "$HOME/.config/cbox"
  ( flock -n 200 || exit 0
    gc
  ) 200> "$HOME/.config/cbox/gc.auto.lock" >/dev/null 2>&1 &
  disown 2>/dev/null || true
}

run() {
  local session_id=""
  if [ "${1:-}" = "--session" ]; then
    session_id="${2:-}"
    [ -n "$session_id" ] || { echo "cbox: usage: $0 run --session <id> <bin> [args...]" >&2; return 1; }
    _cbox_session_id_valid "$session_id" || { echo "cbox: refusing - invalid session id '$session_id'" >&2; return 1; }
    shift 2
  fi
  local bin="${1:-}"
  [ -n "$bin" ] || { echo "cbox: usage: $0 run <bin> [args...]" >&2; return 1; }
  shift
  if [ -n "$session_id" ]; then
    if [ "$(_cbox_effective_mode)" = global ]; then
      echo "cbox: sessions unsupported in global mode v1 - falling back to plain run" >&2
      _run_global "$bin" "$@"
      return
    fi
    _cbox_session_run_leg "$session_id" "$bin" "$@"
    return
  fi
  if [ "$(_cbox_effective_mode)" = global ]; then
    _run_global "$bin" "$@"
    return
  fi
  _run_isolated "$bin" "$@"
}

_project_eff_from_cwd() {
  local root P eff
  root="$(_cbox_workspace_root)" || die "refusing to operate in $PWD (home, /, or a mount root)"
  P="$(_cbox_path_hash "$root")"
  eff="$HOME/.config/cbox/projects/$P"
  [ -f "$eff/cbox.conf" ] || die "no effective config for $root - run 'cbox run codex' or 'setup.sh --local $root' first"
  printf '%s' "$eff"
}

_cbox_down_guard_decision() {
  local locked="$1" probe_n="$2" force="$3"
  if [ "$force" = 1 ]; then
    printf 'proceed'
    return 0
  fi
  if [ "$locked" != 1 ]; then
    printf 'refuse'
    return 0
  fi
  case "$probe_n" in
    ''|*[!0-9]*) printf 'refuse'; return 0 ;;
    0) printf 'proceed'; return 0 ;;
    *) printf 'refuse'; return 0 ;;
  esac
}

down_project() {
  local force="${1:-0}" eff cid locked=0 n decision rc=0
  eff="$(_project_eff_from_cwd)"
  _cbox_manifest_verify_generated "$eff"
  exec 9> "$eff/session.lock"
  if flock -n -x 9; then
    locked=1
  fi
  local ps_rc=0
  cid="$(_compose_p "$eff" ps -q cbox 2>/dev/null)" || ps_rc=$?
  n=unknown
  if [ "$ps_rc" -ne 0 ]; then
    n=unknown
  elif [ -n "$cid" ]; then
    n="$(_probe "$cid" 2>/dev/null)" || n=unknown
  else
    n=0
  fi
  decision="$(_cbox_down_guard_decision "$locked" "$n" "$force")"
  if [ "$decision" = refuse ]; then
    exec 9>&-
    echo "cbox: refusing down - a session looks live for $eff (probe: $n live process(es)); use 'cbox down --force' to stop anyway" >&2
    return 1
  fi
  if [ "$force" = 1 ] && [ "$locked" != 1 ]; then
    echo "cbox: --force: a session lock is held for $eff; stopping anyway" >&2
  elif [ "$force" = 1 ] && { [ "$n" = unknown ] || [ "$n" != 0 ]; }; then
    echo "cbox: --force: probe reports $n live process(es) for $eff; stopping anyway" >&2
  fi
  _compose_p "$eff" down --remove-orphans || rc=$?
  exec 9>&-
  return "$rc"
}

shell_isolated() {
  local eff root rc=0
  eff="$(_project_eff_from_cwd)"
  . "$eff/cbox.conf"
  root="$(cat "$eff/workspace" 2>/dev/null)" || return 1
  exec 8> "$eff/session.lock"
  flock -s 8 || { echo "cbox: cannot lock session for $eff" >&2; exec 8>&-; return 1; }
  _clip_bridge_start "$(_cbox_clip_dir "p$(basename "$eff")")"
  _container_exec_bridge_start "$(_cbox_container_exec_dir "p$(basename "$eff")")" "$root" || {
    _clip_bridge_stop
    exec 8>&-
    return 1
  }
  _cbox_compose_up "$eff/.compose.up.stamp" docker compose --project-directory "$eff" -f "$eff/docker-compose.yml" || {
    _container_exec_bridge_stop
    _clip_bridge_stop
    exec 8>&-
    return 1
  }
  _cbox_netaccess_apply_isolated "$eff" || {
    _container_exec_bridge_stop
    _clip_bridge_stop
    exec 8>&-
    return 1
  }
  if [ -t 0 ] && [ -t 1 ]; then
    _compose_p "$eff" exec -it "${CBOX_CONTAINER_EXEC_ENV[@]}" cbox /entrypoint.sh bash || rc=$?
  else
    _compose_p "$eff" exec -T "${CBOX_CONTAINER_EXEC_ENV[@]}" cbox /entrypoint.sh bash || rc=$?
  fi
  exec 8>&-
  _container_exec_bridge_stop
  _clip_bridge_stop
  _reap "$eff"
  return "$rc"
}

logs_isolated() {
  local eff
  eff="$(_project_eff_from_cwd)"
  _compose_p "$eff" logs "$@"
}

gc() {
  local cid eff n1 n2
  while IFS="$(printf '\t')" read -r cid eff; do
    [ -n "$cid" ] || continue
    if [ ! -d "$eff" ]; then
      docker stop "$cid" >/dev/null 2>&1 || true
      continue
    fi
    exec 9> "$eff/session.lock"
    if ! flock -n -x 9; then
      exec 9>&-
      continue
    fi
    n1="$(_probe "$cid" 2>/dev/null)" || n1=unknown
    if [ "$n1" = 0 ]; then
      exec 9>&-
      sleep 10
      exec 9> "$eff/session.lock"
      if flock -n -x 9; then
        n2="$(_probe "$cid" 2>/dev/null)" || n2=unknown
        if [ "$n2" = 0 ]; then
          _compose_p "$eff" down --remove-orphans >/dev/null 2>&1 || docker stop "$cid" >/dev/null 2>&1 || true
        fi
      fi
    fi
    exec 9>&-
  done < <(docker ps --filter label=cbox.kind=isolated --format '{{.ID}}'$'\t''{{.Label "cbox.effdir"}}')
  docker ps -a --filter label=cbox.kind=isolated --filter status=exited -q | xargs -r docker rm >/dev/null 2>&1 || true
  _gc_legacy_bins_volumes
}

net_refresh() {
  local cid img n=0
  while IFS="$(printf '\t')" read -r cid img; do
    [ -n "$cid" ] || continue
    case "$img" in
      cbox-proxy:*|cbox-proxy-img:*)
        docker restart "$cid" >/dev/null 2>&1 && n=$((n+1))
        ;;
    esac
  done < <(docker ps --filter label=com.docker.compose.service=proxy --format '{{.ID}}'$'\t''{{.Image}}')
  echo "cbox: net-refresh: restarted $n proxy container(s); main containers keep their DNS until restart (use CBOX_DNS_MODE=public|stub to make them immune)"
}

_gc_legacy_bins_volumes() {
  local v
  docker volume ls --format '{{.Name}}' 2>/dev/null | while IFS= read -r v; do
    case "$v" in
      cbox-i[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]-local|cbox-i[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]-codex-packages)
        if docker volume rm "$v" >/dev/null 2>&1; then
          echo "cbox: gc: removed legacy volume $v"
        fi
        ;;
    esac
  done
  if [ "$HAVE_GLOBAL_CONF" = 1 ]; then
    for v in "${CBOX_NAME:-cbox}-claude-local" "${CBOX_NAME:-cbox}-codex-packages"; do
      if docker volume rm "$v" >/dev/null 2>&1; then
        echo "cbox: gc: removed legacy volume $v"
      fi
    done
  fi
}

ls_projects() {
  printf '%-14s %-14s %s\n' PHASH IMGHASH ROOT
  docker ps --filter label=cbox.kind=isolated --format '{{.Label "cbox.phash"}}'$'\t''{{.Label "cbox.imghash"}}'$'\t''{{.Label "cbox.root"}}' \
  | while IFS="$(printf '\t')" read -r p i r; do
      printf '%-14s %-14s %s\n' "${p:0:12}" "${i:0:12}" "$r"
    done
}

images_list() {
  printf '%-24s %-10s %s\n' TAG SIZE PROJECTS
  local line tag size hash refs proj
  docker images --filter reference='cbox-img:*' --format '{{.Repository}}:{{.Tag}}'$'\t''{{.Size}}' \
  | while IFS="$(printf '\t')" read -r tag size; do
      hash="${tag#cbox-img:}"
      refs=""
      for proj in "$HOME"/.config/cbox/projects/*/; do
        [ -f "$proj/image.inputs" ] || continue
        if grep -q "^base=" "$proj/image.inputs" 2>/dev/null; then
          local ih
          ih="$(sha256sum "$proj/image.inputs" | awk '{print $1}')"
          case "$ih" in "$hash"*) refs="$refs $(basename "$proj")" ;; esac
        fi
      done
      if [ -f "$INSTALL_DIR/image.inputs" ]; then
        local gih
        gih="$(sha256sum "$INSTALL_DIR/image.inputs" | awk '{print $1}')"
        case "$gih" in "$hash"*) refs="$refs global" ;; esac
      fi
      printf '%-24s %-10s %s\n' "$tag" "$size" "${refs# }"
    done
}

images_rm() {
  local hash="${1:-}" tag running refs proj ih
  [ -n "$hash" ] || die "usage: $0 images rm <hash>"
  tag="cbox-img:${hash:0:12}"
  running="$(docker ps -q --filter ancestor="$tag" 2>/dev/null)" || running=""
  [ -z "$running" ] || die "refusing: $tag is in use by a running container"
  refs=""
  for proj in "$HOME"/.config/cbox/projects/*/; do
    [ -f "$proj/image.inputs" ] || continue
    ih="$(sha256sum "$proj/image.inputs" | awk '{print $1}')"
    case "$ih" in "$hash"*) refs="$refs $(basename "$proj")" ;; esac
  done
  if [ -f "$INSTALL_DIR/image.inputs" ]; then
    ih="$(sha256sum "$INSTALL_DIR/image.inputs" | awk '{print $1}')"
    case "$ih" in "$hash"*) refs="$refs global" ;; esac
  fi
  [ -z "$refs" ] || die "refusing: $tag is referenced by project(s):$refs"
  docker rmi "$tag"
}

images_cmd() {
  case "${1:-}" in
    rm) shift; images_rm "${1:-}" ;;
    ""|list) images_list ;;
    *) echo "cbox: usage: $0 images [list|rm <hash>]" >&2; return 1 ;;
  esac
}

