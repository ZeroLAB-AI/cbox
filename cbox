  local digest rc=0
  digest="$(_cbox_resolve_base_digest ubuntu:24.04)" || { exec 8>&-; die "cannot resolve base image digest and no local image - network required for first build"; }
  gen_dockerfile_into "$INSTALL_DIR" "$digest"
