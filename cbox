up() {
  local gpu=0 workspace_root=""
  if [ "${1:-}" = "--gpu" ]; then gpu=1; fi
  check_tpl_sha
  source "$INSTALL_DIR/templates/generators.sh"
  _cbox_global_prepare_locked
  local cmd=("${COMPOSE[@]}")
  if [ "$gpu" = 1 ]; then
    [ -f "$INSTALL_DIR/docker-compose.gpu.yml" ] || { echo "cbox: docker-compose.gpu.yml not found - run ./setup.sh update gpu"; exit 1; }
    cmd+=(-f "$INSTALL_DIR/docker-compose.gpu.yml")
  fi
  if _cbox_proxy_active; then "${cmd[@]}" build; fi
  _bins_soft "$IMG_TAG"
  if _cbox_netaccess_exec_active; then
    mkdir -p -m 0700 "$(_cbox_container_exec_dir "${CBOX_NAME:-cbox}")/sockets"
    chmod 0700 "$(_cbox_container_exec_dir "${CBOX_NAME:-cbox}")" "$(_cbox_container_exec_dir "${CBOX_NAME:-cbox}")/sockets"
  fi
  _cbox_compose_up "$HOME/.config/cbox/compose.up.stamp" "${cmd[@]}"
  _cbox_netaccess_apply_global
  if [ -t 0 ] && [ -t 1 ] && [ "${CBOX_NO_EXEC:-0}" != 1 ]; then
    _clip_bridge_start "$(_cbox_clip_dir "${CBOX_NAME:-cbox}")"
    workspace_root="$(_cbox_workspace_root 2>/dev/null)" || workspace_root=""
    _container_exec_bridge_start "$(_cbox_container_exec_dir "${CBOX_NAME:-cbox}")" "$workspace_root" global || {
      _clip_bridge_stop
      return 1
    }
    exec "${COMPOSE[@]}" exec -it "${CBOX_CONTAINER_EXEC_ENV[@]}" "$SERVICE" /entrypoint.sh claude
  fi
  echo "cbox: up"
}

down() {
  require_global_conf
  local force="${1:-0}" cid n decision ps_rc=0 locked=0
  exec 9> "$INSTALL_DIR/session.lock"
  if flock -n -x 9; then
    locked=1
  fi
  cid="$("${COMPOSE[@]}" ps -q "$SERVICE" 2>/dev/null)" || ps_rc=$?
  if [ "$ps_rc" -ne 0 ]; then
    n=unknown
  elif [ -n "$cid" ]; then
    n="$(_probe "$cid" 2>/dev/null)" || n=unknown
  else
    n=0
  fi
  decision="$(_cbox_down_guard_decision "$locked" "$n" "$force")"
  if [ "$decision" = refuse ]; then
    exec 9>&-
    echo "cbox: refusing down - the global container looks live (probe: $n live process(es)); use 'cbox down --force' to stop anyway" >&2
    return 1
  fi
  if [ "$force" = 1 ] && [ "$locked" != 1 ]; then
    echo "cbox: --force: a session lock is held for the global container; stopping anyway" >&2
  elif [ "$force" = 1 ] && { [ "$n" = unknown ] || [ "$n" != 0 ]; }; then
    echo "cbox: --force: probe reports $n live process(es) for the global container; stopping anyway" >&2
  fi
  "${COMPOSE[@]}" down
  exec 9>&-
}

restart() {
  down 1
  up "$@"
}

shell() {
  local workspace_root
  require_global_conf
  workspace_root="$(_cbox_workspace_root 2>/dev/null)" || workspace_root=""
  exec 8> "$INSTALL_DIR/session.lock"
  flock -s 8 || { echo "cbox: cannot lock session for the global container" >&2; exec 8>&-; return 1; }
  _clip_bridge_start "$(_cbox_clip_dir "${CBOX_NAME:-cbox}")"
  _container_exec_bridge_start "$(_cbox_container_exec_dir "${CBOX_NAME:-cbox}")" "$workspace_root" global || {
    _clip_bridge_stop
    exec 8>&-
    return 1
  }
  exec "${COMPOSE[@]}" exec -it "${CBOX_CONTAINER_EXEC_ENV[@]}" "$SERVICE" /entrypoint.sh bash
}

