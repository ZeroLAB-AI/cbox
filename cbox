install_hooks() {
  require_global_conf
  [ -t 0 ] || { echo "cbox: install-hooks requires a TTY"; return 1; }
  local files=(codex_mode_guard.py agent_label_guard.py code_hygiene_guard.py commit_guard.py orchestrator-global.txt conduct-kernel.txt session-core.txt codex_scope.container.json ask_claude_mcp.py codex_notify.py codex_bump_probe.sh codex_mcp_shim.py continuity_commit_log.py continuity_ledger_sweep.py continuity_session_digest.py continuity_session_start.py session_scope_farm.py limit_watchdog.py session_pane_map.py)
  local srcs=(
    "$INSTALL_DIR/etc/hooks/codex_mode_guard.py"
    "$INSTALL_DIR/etc/hooks/agent_label_guard.py"
    "$INSTALL_DIR/etc/hooks/code_hygiene_guard.py"
    "$INSTALL_DIR/etc/hooks/commit_guard.py"
    "$INSTALL_DIR/etc/hooks/orchestrator-global.txt"
    "$INSTALL_DIR/generated/hooks/conduct-kernel.txt"
    "$INSTALL_DIR/etc/hooks/session-core.txt"
    "$INSTALL_DIR/generated/hooks/codex_scope.container.json"
    "$INSTALL_DIR/etc/codex/ask_claude_mcp.py"
    "$INSTALL_DIR/etc/codex/codex_notify.py"
    "$INSTALL_DIR/etc/codex/codex_bump_probe.sh"
    "$INSTALL_DIR/etc/mcp/codex_mcp_shim.py"
    "$INSTALL_DIR/etc/hooks/continuity_commit_log.py"
    "$INSTALL_DIR/etc/hooks/continuity_ledger_sweep.py"
    "$INSTALL_DIR/etc/hooks/continuity_session_digest.py"
    "$INSTALL_DIR/etc/hooks/continuity_session_start.py"
    "$INSTALL_DIR/etc/hooks/session_scope_farm.py"
    "$INSTALL_DIR/etc/hooks/limit_watchdog.py"
    "$INSTALL_DIR/etc/hooks/session_pane_map.py"
  )
  local s f i stage target ans changed=0
  for s in "${srcs[@]}"; do
    [ -f "$s" ] || { echo "cbox: $s missing - run ./setup.sh first"; return 1; }
  done
  stage="$(mktemp -d)"
  trap 'rm -rf "$stage"' RETURN
  for i in "${!files[@]}"; do
    cp "${srcs[$i]}" "$stage/${files[$i]}"
  done
  if [ "${CBOX_CLAUDE_MODE:-mount}" = mount ]; then
    target="${CBOX_CLAUDE_PATH:-$HOME/.claude}/hooks"
    mkdir -p "$target"
    for f in "${files[@]}"; do
      if cmp -s "$stage/$f" "$target/$f" 2>/dev/null; then
        echo "cbox: $f unchanged"
        continue
      fi
      echo "== $f: $target/$f vs staged =="
      if [ -f "$target/$f" ]; then
        diff -u "$target/$f" "$stage/$f" || true
      else
        echo "(new file)"
        sed 's/^/+ /' "$stage/$f"
      fi
      changed=1
    done
    if [ "$changed" = 0 ]; then
      echo "cbox: install-hooks: nothing to do"
      return 0
    fi
    read -r -p "Install the changes above into $target? [y/N] " ans
    case "$ans" in
      y|Y) ;;
      *) echo "cbox: install-hooks: cancelled"; return 1;;
    esac
    for f in "${files[@]}"; do
      install -m 0644 "$stage/$f" "$target/$f"
    done
  else
    target="$INSTALL_DIR/generated/hooks"
    mkdir -p "$target"
    for f in "${files[@]}"; do
      if cmp -s "$stage/$f" "$target/$f" 2>/dev/null; then
        echo "cbox: $f unchanged"
      else
        install -m 0644 "$stage/$f" "$target/$f"
        echo "cbox: $f updated"
      fi
    done
  fi
  echo "cbox: install-hooks: done - apply with: $0 restart"
}

_continuity_brain_files() {
  local root="$1" f
  for f in LEDGER.md LEDGER_ARCHIVE.md DIARY.md CHANGELOG.md OPEN_QUESTIONS.md .continuity_state.json; do
    [ -e "$root/.claude/$f" ] && printf '%s\n' "$f"
  done
  for f in "$root/.claude"/PROGRESS_*.md; do
    [ -e "$f" ] || continue
    printf '%s\n' "$(basename "$f")"
  done
}

continuity_migrate() {
  local root gitroot has_claude=0 has_cbox=0 f tracked
  gitroot="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "cbox: continuity migrate: not inside a git work-tree" >&2
    return 1
  }
  root="$gitroot"

  local -a files=()
  while IFS= read -r f; do
    [ -n "$f" ] && files+=("$f")
  done < <(_continuity_brain_files "$root")

  if [ "${#files[@]}" -gt 0 ]; then
    has_claude=1
  fi
  if [ -d "$root/.cbox" ]; then
    for f in LEDGER.md LEDGER_ARCHIVE.md DIARY.md CHANGELOG.md OPEN_QUESTIONS.md .continuity_state.json "$root/.cbox"/PROGRESS_*.md; do
      case "$f" in
        "$root/.cbox"/*) [ -e "$f" ] && has_cbox=1 ;;
        *) [ -e "$root/.cbox/$f" ] && has_cbox=1 ;;
      esac
    done
  fi

  if [ "$has_claude" = 1 ] && [ "$has_cbox" = 1 ]; then
    echo "cbox: continuity migrate: both .claude/ and .cbox/ already contain brain files in $root - refusing to merge; resolve by hand" >&2
    return 1
  fi

  if [ "$has_claude" = 0 ]; then
    echo "cbox: continuity migrate: no known brain files under $root/.claude - nothing to do"
    return 0
  fi

  mkdir -p "$root/.cbox"

  for f in "${files[@]}"; do
    tracked=0
    if git -C "$root" ls-files --error-unmatch ".claude/$f" >/dev/null 2>&1; then
      tracked=1
    fi
    if [ "$tracked" = 1 ]; then
      git -C "$root" mv ".claude/$f" ".cbox/$f"
      echo "cbox: continuity migrate: git mv .claude/$f -> .cbox/$f"
    else
      mv "$root/.claude/$f" "$root/.cbox/$f"
      echo "cbox: continuity migrate: mv .claude/$f -> .cbox/$f"
    fi
  done

  echo "cbox: continuity migrate: done - ${#files[@]} file(s) moved to $root/.cbox"
}

backup() {
  require_global_conf
  local ts v vols=()
  if [ "${CBOX_CLAUDE_MODE:-mount}" = volume ]; then vols+=("${CBOX_NAME:-cbox}-claude"); fi
  if [ "${CBOX_CODEX_MODE:-mount}" = volume ]; then vols+=("${CBOX_NAME:-cbox}-codex"); fi
  if [ "${CBOX_VENV_MODE:-none}" = volume ]; then vols+=("${CBOX_NAME:-cbox}-venv"); fi
  case "${CBOX_SSH_MODE:-none}" in
    container-keys|mixed) vols+=("${CBOX_NAME:-cbox}-ssh");;
  esac
  ts="$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$INSTALL_DIR/backups"
  for v in "${vols[@]}"; do
    if ! docker volume inspect "$v" >/dev/null 2>&1; then
      echo "cbox: volume $v not found - skipped"
      continue
    fi
    docker run --rm -v "$v:/src:ro" -v "$INSTALL_DIR/backups:/out" ubuntu:24.04 tar czf "/out/$v-$ts.tar.gz" -C /src .
    du -h "$INSTALL_DIR/backups/$v-$ts.tar.gz"
  done
  local iso_vols
  iso_vols="$(docker volume ls --format '{{.Name}}' 2>/dev/null | grep -c '^cbox-p' || true)"
  if [ "${iso_vols:-0}" -gt 0 ] 2>/dev/null; then
    echo "cbox: note: $iso_vols isolated project volume(s) (cbox-p*) are not covered by this backup - archive them per project: docker run --rm -v <vol>:/src:ro -v <dest>:/out ubuntu:24.04 tar czf /out/<vol>.tar.gz -C /src ."
  fi
}

_socat_exec_addr() {
  local tok out=""
  for tok in "$@"; do
    case "$tok" in
      "")
        echo "cbox: cannot build the socat bridge command - empty argument" >&2
        return 1
        ;;
      *[[:space:]]*|*\\*)
        echo "cbox: cannot build the socat bridge command - argument contains whitespace or backslash (install cbox under a path without spaces): $tok" >&2
        return 1
        ;;
    esac
    out+="$tok "
  done
  out="${out% }"
  out="${out//:/\\:}"
  out="${out//,/\\,}"
  out="${out//!/\\!}"
  printf 'EXEC:%s' "$out"
}

login_claude() {
  local url="${1:-}"
  if [ -z "$url" ]; then
    printf 'cbox: run /login in a claude session inside the container, then paste the printed URL here: '
    IFS= read -r url || return 1
  fi
  case "$url" in
    https://claude.ai/oauth/authorize\?*|https://claude.com/cai/oauth/authorize\?*|https://platform.claude.com/oauth/authorize\?*|https://console.anthropic.com/oauth/authorize\?*) ;;
    *) echo "cbox: refusing - not a recognized Claude OAuth authorize URL"; return 1 ;;
  esac
  local port
  port="$(printf '%s' "$url" | grep -o 'redirect_uri=http%3A%2F%2Flocalhost%3A[0-9]\{1,5\}' | head -n1 | grep -o '[0-9]\{1,5\}$')" || true
  case "$port" in
    ''|*[!0-9]*) echo "cbox: cannot extract the callback port from redirect_uri"; return 1 ;;
  esac
  if [ "$port" -lt 1024 ] || [ "$port" -gt 65535 ]; then
    echo "cbox: callback port $port out of range"
    return 1
  fi
  command -v socat >/dev/null 2>&1 || { echo "cbox: socat not found on host - install it first (e.g. apt install socat)"; return 1; }
  local -a cc=()
  local svc eff
  case "$(_cbox_effective_mode)" in
    global)
      require_global_conf
      cc=("${COMPOSE[@]}")
      svc="$SERVICE"
      ;;
    isolated)
      eff="$(_project_eff_from_cwd)"
      cc=(docker compose --project-directory "$eff" -f "$eff/docker-compose.yml")
      svc=cbox
      ;;
    *)
      echo "cbox: no cbox configuration found (neither global nor for this workspace)"
      return 1
      ;;
  esac
  echo "cbox: forwarding host 127.0.0.1:$port into the container's loopback for this one login"
  echo "cbox: finish the login in the browser, then press Ctrl-C to stop the bridge"
  trap 'echo; echo "cbox: login bridge stopped"; exit 0' INT
  local exec_addr
  exec_addr="$(_socat_exec_addr "${cc[@]}" exec -T "$svc" socat - "TCP:127.0.0.1:$port")" || return 1
  if command -v xdg-open >/dev/null 2>&1; then
    (xdg-open "$url" >/dev/null 2>&1 &)
  else
    echo "cbox: open this URL in your browser:"
    printf '%s\n' "$url"
  fi
  socat "TCP-LISTEN:$port,bind=127.0.0.1,reuseaddr,fork,max-children=1" "$exec_addr"
}

login_codex() {
  require_global_conf
  if [ "${CBOX_EGRESS_MODE:-off}" = off ]; then
    echo "cbox: egress mode is off - the login bridge is only needed with egress enabled; run 'codex login' inside '$0 shell'"
    return 0
  fi
  command -v socat >/dev/null 2>&1 || { echo "cbox: socat not found on host - install it first (e.g. apt install socat)"; return 1; }
  echo "cbox: forwarding host 127.0.0.1:1455 into the container"
  echo "cbox: run 'codex login' inside '$0 shell' and open the printed URL in a browser on this host"
  echo "cbox: press Ctrl-C to stop the bridge"
  trap 'echo; echo "cbox: login bridge stopped"; exit 0' INT
  local exec_addr
  exec_addr="$(_socat_exec_addr docker compose -f "$INSTALL_DIR/docker-compose.yml" exec -T "$SERVICE" socat - TCP:127.0.0.1:1455)" || return 1
  socat TCP-LISTEN:1455,bind=127.0.0.1,reuseaddr,fork,max-children=1 "$exec_addr"
}

VN=0
VOK=0
VFAIL=0
VSKIP=0

v_t() {
  VN=$((VN + 1))
  printf '[%d] %s: ' "$VN" "$1"
}

v_ok() {
  VOK=$((VOK + 1))
  if [ -n "${1:-}" ]; then echo "OK ($1)"; else echo "OK"; fi
}

v_fail() {
  VFAIL=$((VFAIL + 1))
  if [ -n "${1:-}" ]; then echo "FAIL ($1)"; else echo "FAIL"; fi
}

v_skip() {
  VSKIP=$((VSKIP + 1))
  if [ -n "${1:-}" ]; then echo "SKIP ($1)"; else echo "SKIP"; fi
}

verify() {
  require_global_conf
  local gpu=0
  if [ "${1:-}" = "--gpu" ]; then gpu=1; fi
  local X=("${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh)
  local workspaces=()
  read -r -a workspaces <<< "${CBOX_WORKSPACES:-}"
  local w v got want rc ref payload gitws
  echo "== cbox verify =="

  v_t "uid/gid match"
  got="$("${X[@]}" sh -c 'echo "$(id -u):$(id -g)"' 2>/dev/null)" || got=""
  if _cbox_is_rootless_docker; then
    want="0:0"
  else
    want="$(id -u):$(id -g)"
  fi
  if [ "$got" = "$want" ]; then v_ok "$got"; else v_fail "container ${got:-unknown}, expected $want"; fi

  for w in "${workspaces[@]}"; do
    v_t "workspace writable $w"
    if "${X[@]}" sh -c 'touch "$1/.cbox-verify" && rm "$1/.cbox-verify"' sh "$w" >/dev/null 2>&1; then v_ok; else v_fail; fi
  done

  for w in "${workspaces[@]}"; do
    v_t "workspace is a git work-tree $w"
    if "${X[@]}" sh -c 'git -C "$1" rev-parse --is-inside-work-tree' sh "$w" >/dev/null 2>&1; then
      v_ok
    else
      v_fail "no git history - run git init in $w"
    fi
  done

  if [ "${CBOX_VENV_MODE:-none}" = host ]; then
    v_t "venv mount read-only ${CBOX_VENV_PATH:-}"
    if "${X[@]}" sh -c 'touch "$1/.cbox-verify"' sh "${CBOX_VENV_PATH:-}" >/dev/null 2>&1; then
      v_fail "writable"
    else
      v_ok "write denied"
    fi
  fi

  v_t "claude --version"
  if v="$("${X[@]}" claude --version 2>&1)"; then v_ok "$v"; else v_fail "$v"; fi

  v_t "codex --version"
  if v="$("${X[@]}" codex --version 2>&1)"; then v_ok "$v"; else v_fail "$v"; fi

  v_t "binaries from volumes"
  if "${X[@]}" sh -c 'test "$(command -v claude)" = "$HOME/.local/bin/claude" && test "$(command -v codex)" = "$HOME/.local/bin/codex" && case "$(readlink -f "$HOME/.local/bin/codex")" in "$HOME/.codex/packages/"*) exit 0;; *) exit 1;; esac' >/dev/null 2>&1; then
    v_ok
  else
    v_fail "claude/codex not from ~/.local/bin or codex does not resolve under ~/.codex/packages"
  fi

  v_t "claude bins mount read-only (write denied)"
  if "${X[@]}" sh -c 'touch "$HOME/.local/.cbox-verify"' >/dev/null 2>&1; then
    v_fail "writable"
  else
    v_ok "write denied"
  fi

  v_t "codex bins mount read-only (write denied)"
  if "${X[@]}" sh -c 'touch "$HOME/.codex/packages/.cbox-verify"' >/dev/null 2>&1; then
    v_fail "writable"
  else
    v_ok "write denied"
  fi

  v_t "claude stamp present and want matches pin"
  want="${CBOX_CLAUDE_TARGET:-stable}"
  if got="$("${X[@]}" sh -c 'sed -n 1p "$HOME/.local/.cbox-stamp"' 2>/dev/null)" && [ "$got" = "$want" ]; then
    v_ok "$got"
  else
    v_fail "stamp missing or want '${got:-}' != pin '$want'"
  fi

  v_t "codex stamp present and want matches pin"
  want="${CBOX_CODEX_VERSION:-latest}|${CBOX_CODEX_TARGET:-}"
  if got="$("${X[@]}" sh -c 'sed -n 1p "$HOME/.codex/packages/.cbox-stamp"' 2>/dev/null)" && [ "$got" = "$want" ]; then
    v_ok "$got"
  else
    v_fail "stamp missing or want '${got:-}' != pin '$want'"
  fi

  v_t "Codex MCP contract exposes developer-instructions"
  if "${X[@]}" env \
    CBOX_CONTRACT_INIT='{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2024-11-05","capabilities":{},"clientInfo":{"name":"cbox-contract-canary","version":"1"}}}' \
    CBOX_CONTRACT_READY='{"jsonrpc":"2.0","method":"notifications/initialized"}' \
    CBOX_CONTRACT_LIST='{"jsonrpc":"2.0","id":2,"method":"tools/list","params":{}}' \
    sh -c 'codex mcp-server --help >/dev/null 2>&1 && printf "%s\n" "$CBOX_CONTRACT_INIT" "$CBOX_CONTRACT_READY" "$CBOX_CONTRACT_LIST" | timeout 10 codex mcp-server 2>/dev/null | grep -qF developer-instructions'; then
    v_ok
  else
    v_fail "Codex MCP contract broken: developer-instructions not found"
    exit 1
  fi

  v_t "claude resolved binary executable and matches stamp"
  if "${X[@]}" sh -c '
p="$(sed -n 2p "$HOME/.local/.cbox-stamp")"
v="$(sed -n 4p "$HOME/.local/.cbox-stamp")"
test -n "$p" && test -x "$p" || exit 1
case "$("$p" --version 2>&1)" in *"$v"*) exit 0;; *) exit 1;; esac
' >/dev/null 2>&1; then
    v_ok
  else
    v_fail "resolved binary missing, not executable, or --version does not match stamp"
  fi

  v_t "codex resolved binary executable and matches stamp"
  if "${X[@]}" sh -c '
p="$(sed -n 2p "$HOME/.codex/packages/.cbox-stamp")"
v="$(sed -n 4p "$HOME/.codex/packages/.cbox-stamp")"
test -n "$p" && test -x "$p" || exit 1
case "$("$p" --version 2>&1)" in *"$v"*) exit 0;; *) exit 1;; esac
' >/dev/null 2>&1; then
    v_ok
  else
    v_fail "resolved binary missing, not executable, or --version does not match stamp"
  fi

  v_t "guard read-only (append denied)"
  if "${X[@]}" sh -c 'echo x >> "$HOME/.claude/hooks/codex_mode_guard.py"' >/dev/null 2>&1; then
    v_fail "writable"
  else
    v_ok "write denied"
  fi

  v_t "guard read-only (rm denied)"
  if "${X[@]}" sh -c 'rm "$HOME/.claude/hooks/codex_mode_guard.py"' >/dev/null 2>&1; then
    v_fail "removable"
  else
    v_ok "remove denied"
  fi

  v_t "guard wired in settings.json"
  if "${X[@]}" sh -c 'p="$(jq -r ".hooks.PreToolUse[] | select(.matcher==\"mcp__codex-.*\") | .hooks[0].command" "$HOME/.claude/settings.json" | grep -oE "/[^ ]+codex_mode_guard\.py" | head -n 1)"; test -n "$p" && test -f "$p"' >/dev/null 2>&1; then
    v_ok
  else
    v_fail
  fi

  if [ "${CBOX_CLAUDE_MODE:-mount}" = mount ]; then
    ref="${CBOX_CLAUDE_PATH:-$HOME/.claude}/hooks/codex_mode_guard.py"
  else
    ref="$INSTALL_DIR/generated/hooks/codex_mode_guard.py"
  fi
  v_t "guard in sync with $ref"
  if [ ! -f "$ref" ]; then
    v_fail "reference file missing"
  elif "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'cmp -s - "$HOME/.claude/hooks/codex_mode_guard.py"' < "$ref" >/dev/null 2>&1; then
    v_ok
  else
    v_fail "drift - run $0 install-hooks"
  fi

  if [ "${CBOX_CLAUDE_MODE:-mount}" = mount ]; then
    ref="${CBOX_CLAUDE_PATH:-$HOME/.claude}/settings.json"
  else
    ref="$INSTALL_DIR/generated/settings.json"
  fi
  v_t "settings.json in sync with $ref"
  if [ ! -f "$ref" ]; then
    v_fail "reference file missing"
  elif "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'cmp -s - "$HOME/.claude/settings.json"' < "$ref" >/dev/null 2>&1; then
    v_ok
  else
    v_fail "drift - run $0 install-hooks"
  fi

  v_t "CLAUDE.md read-only (append denied)"
  if "${X[@]}" sh -c 'echo x >> "$HOME/.claude/CLAUDE.md"' >/dev/null 2>&1; then
    v_fail "writable"
  else
    v_ok "write denied"
  fi

  v_t "CLAUDE.md read-only (rm denied)"
  if "${X[@]}" sh -c 'rm "$HOME/.claude/CLAUDE.md"' >/dev/null 2>&1; then
    v_fail "removable"
  else
    v_ok "remove denied"
  fi

  v_t "agents dir read-only (create denied)"
  if "${X[@]}" sh -c 'touch "$HOME/.claude/agents/.cbox-verify"' >/dev/null 2>&1; then
    v_fail "writable"
  else
    v_ok "write denied"
  fi

  v_t "agents dir read-only (rm denied)"
  if "${X[@]}" sh -c 'rm -rf "$HOME/.claude/agents"' >/dev/null 2>&1; then
    v_fail "removable"
  else
    v_ok "remove denied"
  fi

  if [ "${CBOX_HISTORY:-1}" = 1 ]; then
    v_t "agents and policies populated"
    if "${X[@]}" sh -c '[ -n "$(ls -A "$HOME/.claude/agents" 2>/dev/null)" ] && [ -n "$(ls -A "$HOME/.claude/policies" 2>/dev/null)" ]' >/dev/null 2>&1; then
      v_ok
    else
      v_fail "empty - run ./setup.sh update agents / update claude-md"
    fi

    v_t "CLAUDE.md imports resolve"
    if "${X[@]}" sh -c 'ok=1; while IFS= read -r l; do case "$l" in "@~/"*) p="$HOME/${l#@~/}"; [ -f "$p" ] || ok=0;; esac; done < "$HOME/.claude/CLAUDE.md"; [ "$ok" = 1 ]' >/dev/null 2>&1; then
      v_ok
    else
      v_fail "missing policy file for an @import line"
    fi

    v_t "CLAUDE.md carries the conduct kernel literally"
    if "${X[@]}" sh -c 'grep -qF "cbox:conduct-kernel:begin" "$HOME/.claude/CLAUDE.md" && grep -qF "cbox:conduct-kernel:end" "$HOME/.claude/CLAUDE.md" && grep -qF "CONDUCT KERNEL" "$HOME/.claude/CLAUDE.md"' >/dev/null 2>&1; then
      v_ok
    else
      v_fail "kernel block missing - run ./setup.sh update claude-md"
    fi

    v_t "context manifest digests match rendered artifacts"
    local manifest_err manifest_tmp
    manifest_tmp="$(mktemp)"
    if ( _cbox_context_manifest_verify "$INSTALL_DIR/generated" ) >"$manifest_tmp" 2>&1; then
      v_ok
    else
      manifest_err="$(tr '\n' ' ' < "$manifest_tmp")"
      v_fail "$manifest_err"
    fi
    rm -f "$manifest_tmp"
  fi

  if [ "${CBOX_CLAUDE_MODE:-mount}" = mount ]; then
    v_t "host sessions readable"
    if "${X[@]}" sh -c 'test -d "$HOME/.claude/projects" && ls "$HOME/.claude/projects" >/dev/null' >/dev/null 2>&1; then
      v_ok
    else
      v_fail
    fi
  fi

  gitws=""
  for w in "${workspaces[@]}" "${CBOX_WORKDIR:-}"; do
    [ -n "$w" ] || continue
    if git -C "$w" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      gitws="$w"
      break
    fi
  done
  v_t "guard allows danger-full-access in scope"
  if [ -z "$gitws" ]; then
    v_skip "no git work-tree among workspaces"
  else
    printf -v payload '{"tool_name":"mcp__codex-terra__codex","permission_mode":"auto","tool_input":{"cwd":"%s","sandbox":"danger-full-access","approval-policy":"never"}}' "$gitws"
    rc=0
    printf '%s' "$payload" | "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'CODEX_GUARD_CONFIG="$HOME/.claude/hooks/codex_scope.container.json" python3 "$HOME/.claude/hooks/codex_mode_guard.py"' >/dev/null 2>&1 || rc=$?
    if [ "$rc" -eq 0 ]; then v_ok "$gitws"; else v_fail "exit $rc"; fi
  fi

  v_t "guard denies out-of-scope cwd (git gate)"
  payload='{"tool_name":"mcp__codex-terra__codex","permission_mode":"bypassPermissions","tool_input":{"cwd":"/etc","sandbox":"danger-full-access","approval-policy":"never"}}'
  rc=0
  printf '%s' "$payload" | "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'CODEX_GUARD_CONFIG="$HOME/.claude/hooks/codex_scope.container.json" python3 "$HOME/.claude/hooks/codex_mode_guard.py"' >/dev/null 2>&1 || rc=$?
  if [ "$rc" -eq 2 ]; then v_ok; else v_fail "exit $rc, expected 2"; fi

  v_t "ask-claude wrapper present and read-only"
  if "${X[@]}" sh -c 'test -f "$HOME/.claude/hooks/ask_claude_mcp.py" && ! { echo x >> "$HOME/.claude/hooks/ask_claude_mcp.py"; } 2>/dev/null' >/dev/null 2>&1; then
    v_ok
  else
    v_fail "missing or writable"
  fi

  v_t "ask-claude mcp protocol roundtrip"
  payload='{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-03-26","capabilities":{},"clientInfo":{"name":"verify","version":"0"}}}
{"jsonrpc":"2.0","method":"notifications/initialized"}
{"jsonrpc":"2.0","id":2,"method":"tools/list"}'
  if printf '%s\n' "$payload" | "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'python3 "$HOME/.claude/hooks/ask_claude_mcp.py"' 2>/dev/null | grep -q '"ask-claude"'; then
    v_ok
  else
    v_fail "tools/list did not report ask-claude"
  fi

  v_t "ask-claude depth guard refuses nested calls"
  payload='{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-03-26","capabilities":{},"clientInfo":{"name":"verify","version":"0"}}}
{"jsonrpc":"2.0","method":"notifications/initialized"}
{"jsonrpc":"2.0","id":2,"method":"tools/call","params":{"name":"ask-claude","arguments":{"prompt":"ping"}}}'
  if printf '%s\n' "$payload" | "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'CBOX_MCP_DEPTH=1 CBOX_DELEGATION_DEPTH=1 python3 "$HOME/.claude/hooks/ask_claude_mcp.py"' 2>/dev/null | grep -q 'depth limit'; then
    v_ok
  else
    v_fail "nested call was not refused"
  fi

  if [ "${CBOX_CODEX_MCP:-0}" = 1 ]; then
    v_t "codex-mcp wired in config.toml"
    if "${X[@]}" sh -c 'grep -q "^\[mcp_servers\.claude\]" "$HOME/.codex/config.toml"' >/dev/null 2>&1; then
      v_ok
    else
      v_fail "run ./setup.sh update codex-mcp"
    fi
  fi

  if [ "${CBOX_EGRESS_MODE:-off}" != off ] && [ "${CBOX_EGRESS_APPLIED:-0}" != 1 ]; then
    v_t "egress topology"
    v_skip "configured but not applied - run ./setup.sh update egress"
  elif [ "${CBOX_EGRESS_MODE:-off}" != off ]; then
    v_t "egress proxy allows api.anthropic.com"
    if "${X[@]}" curl -s -o /dev/null --connect-timeout 10 -x http://proxy:8888 https://api.anthropic.com >/dev/null 2>&1; then
      v_ok
    else
      v_fail
    fi

    v_t "egress proxy denies example.com"
    if "${X[@]}" curl -s -o /dev/null --connect-timeout 10 -x http://proxy:8888 https://example.com >/dev/null 2>&1; then
      v_fail "reachable through proxy"
    else
      v_ok "denied"
    fi

    v_t "direct egress bypass fails"
    if "${X[@]}" curl -s -o /dev/null --noproxy "*" --connect-timeout 3 https://api.anthropic.com >/dev/null 2>&1; then
      v_fail "direct connection succeeded"
    else
      v_ok "blocked"
    fi

    v_t "proxy service running"
    if [ -n "$("${COMPOSE[@]}" ps -q --status running proxy 2>/dev/null)" ]; then v_ok; else v_fail; fi
  fi

  case "${CBOX_SSH_MODE:-none}" in
    none)
      v_t "ssh isolation (~/.ssh absent)"
      if "${X[@]}" sh -c 'test -e "$HOME/.ssh"' >/dev/null 2>&1; then v_fail "exists"; else v_ok; fi
      ;;
    host-agent)
      v_t "ssh agent socket present"
      if "${X[@]}" sh -c 'test -S /run/cbox-ssh/agent.sock' >/dev/null 2>&1; then v_ok; else v_fail; fi
      v_t "no private key files in ~/.ssh"
      if "${X[@]}" sh -c 'ls "$HOME/.ssh"/id_* >/dev/null 2>&1' >/dev/null 2>&1; then v_fail "key files present"; else v_ok; fi
      ;;
    container-keys)
      v_t "~/.ssh owned by user"
      if "${X[@]}" sh -c 'test -d "$HOME/.ssh" && test "$(stat -c %u "$HOME/.ssh")" = "$(id -u)"' >/dev/null 2>&1; then v_ok; else v_fail; fi
      ;;
    mixed)
      v_t "ssh agent socket present"
      if "${X[@]}" sh -c 'test -S /run/cbox-ssh/agent.sock' >/dev/null 2>&1; then v_ok; else v_fail; fi
      v_t "~/.ssh owned by user"
      if "${X[@]}" sh -c 'test -d "$HOME/.ssh" && test "$(stat -c %u "$HOME/.ssh")" = "$(id -u)"' >/dev/null 2>&1; then v_ok; else v_fail; fi
      ;;
  esac

  if [ "$gpu" = 1 ]; then
    v_t "nvidia-smi in container"
    if "${X[@]}" nvidia-smi -L >/dev/null 2>&1; then v_ok; else v_fail; fi
  fi

  _cbox_verify_doc_coverage
  _cbox_verify_engines_registry
  _cbox_verify_netaccess_scope

  echo "== cbox verify: $VN tests, $VOK ok, $VFAIL failed, $VSKIP skipped =="
  [ "$VFAIL" -eq 0 ] || exit 1
}

_cbox_verify_engines_registry() {
  local reg="$INSTALL_DIR/etc/engines/engines.json"
  local py="$INSTALL_DIR/etc/engines/engines_registry.py"
  local install_bins="$INSTALL_DIR/install-bins.sh"
  local entrypoint="$INSTALL_DIR/entrypoint.sh"
  local sec="$INSTALL_DIR/templates/sections.sh"
  local cbox_self="$INSTALL_DIR/cbox"
  v_t "engines registry: schema valid"
  if [ ! -f "$reg" ] || [ ! -f "$py" ]; then
    v_skip "engines.json or engines_registry.py not present (host-side check)"
    return 0
  fi
  local msg
  if msg="$(python3 "$py" validate "$reg" 2>&1)"; then
    v_ok
  else
    v_fail "$msg"
    return 0
  fi

  local names
  names="$(python3 "$py" names "$reg" 2>/dev/null)" || names=""
  [ -n "$names" ] || { v_t "engines registry: at least one engine declared"; v_fail "names command returned nothing"; return 0; }

  if [ ! -f "$install_bins" ] || [ ! -f "$entrypoint" ] || [ ! -f "$sec" ]; then
    v_t "engines registry: cross-file agreement"
    v_skip "install-bins.sh, entrypoint.sh or sections.sh not present (host-side check)"
    return 0
  fi

  local ib_allow ep_arm
  ib_allow="$(grep -oE '^\s*[A-Za-z0-9_|-]+\)\s*;;' "$install_bins" | head -1 | sed -E 's/^\s*//; s/\)\s*;;\s*$//')"
  ep_arm="$(grep -oE '^  [A-Za-z0-9_|-]+\)\s*$' "$entrypoint" | sed -E 's/^\s*//; s/\)\s*$//' | tr '\n' '|' | sed 's/|$//')"

  . "$sec" 2>/dev/null || true

  local name bin install version_vars enabled_var pending=""
  local missing="" mismatch="" sec_gaps="" get_fail=""
  for name in $names; do
    bin="$(python3 "$py" get "$reg" "$name" bin 2>/dev/null)" || { get_fail="$get_fail $name.bin"; bin=""; }
    install="$(python3 "$py" get "$reg" "$name" install 2>/dev/null)" || { get_fail="$get_fail $name.install"; install=""; }
    enabled_var="$(python3 "$py" get "$reg" "$name" enabled_var 2>/dev/null)" || { get_fail="$get_fail $name.enabled_var"; enabled_var=""; }

    if [ "$install" = "bins-volume" ]; then
      case "|$ib_allow|" in
        *"|$name|"*) ;;
        *) missing="$missing install-bins:$name" ;;
      esac
    fi

    local armed=1
    case "|$ep_arm|" in
      *"|$name|"*)
        if [ "$bin" != "$name" ]; then
          mismatch="$mismatch entrypoint-bin:$name(bin=$bin)"
        fi
        ;;
      *)
        pending="$pending $name"
        armed=0
        ;;
    esac

    version_vars="$(python3 "$py" get "$reg" "$name" version_vars 2>/dev/null)" || { get_fail="$get_fail $name.version_vars"; version_vars=""; }
    local vv
    vv="$(printf '%s' "$version_vars" | python3 -c 'import json,sys; print(" ".join(json.load(sys.stdin)))' 2>/dev/null)" || vv=""
    local sec_binaries="${SEC_VARS[binaries]:-}"
    local sec_own="${SEC_VARS[$name]:-}"
    local v
    for v in $vv; do
      case " $sec_binaries " in
        *" $v "*) continue ;;
      esac
      case " $sec_own " in
        *" $v "*) continue ;;
      esac
      if [ "$armed" = 1 ]; then
        missing="$missing sec-vars:$name:$v"
      else
        sec_gaps="$sec_gaps sec-vars:$name:$v"
      fi
    done
  done

  v_t "engines registry: per-engine field lookups succeed"
  if [ -z "$get_fail" ]; then
    v_ok
  else
    v_fail "${get_fail}"
  fi

  v_t "engines registry: bins-volume engines in install-bins.sh allowlist"
  local missing_ib
  missing_ib="$(printf '%s' "$missing" | grep -o 'install-bins:[^ ]*' | tr '\n' ' ' || true)"
  if [ -z "$missing_ib" ]; then
    v_ok
  else
    v_fail "${missing_ib}"
  fi

  v_t "engines registry: version_vars covered by SEC_VARS[binaries] or own section (entrypoint-armed engines)"
  local missing_sv
  missing_sv="$(printf '%s' "$missing" | grep -o 'sec-vars:[^ ]*' | tr '\n' ' ' || true)"
  if [ -z "$missing_sv" ]; then
    v_ok
  else
    v_fail "${missing_sv}"
  fi

  v_t "engines registry: entrypoint-armed engines agree on bin name"
  if [ -z "$mismatch" ]; then
    v_ok
  else
    v_fail "${mismatch}"
  fi

  v_t "engines registry: entrypoint-armed and install-bins-allowlisted engines are all declared in the registry"
  local names_bar="|$(printf '%s' "$names" | tr '\n' '|' | sed 's/||*/|/g')|"
  local unreg="" tok
  local IFS_bak="$IFS"; IFS='|'
  for tok in $ep_arm; do
    [ -n "$tok" ] || continue
    case "$names_bar" in *"|$tok|"*) ;; *) unreg="$unreg entrypoint-arm:$tok" ;; esac
  done
  for tok in $ib_allow; do
    [ -n "$tok" ] || continue
    case "$names_bar" in *"|$tok|"*) ;; *) unreg="$unreg install-bins:$tok" ;; esac
  done
  IFS="$IFS_bak"
  if [ -z "$unreg" ]; then
    v_ok
  else
    v_fail "engines armed/allowlisted in code but missing from engines.json:${unreg}"
  fi

  v_t "engines registry: canonical-paths probe literals appear verbatim in the _CBOX_PROBE_SH heredoc"
  if [ ! -f "$cbox_self" ]; then
    v_skip "cbox script not present at $cbox_self (host-side check)"
  else
    local probe_kind cp_missing="" cp_none=1
    for name in $names; do
      probe_kind="$(python3 "$py" get "$reg" "$name" probe.kind 2>/dev/null)" || probe_kind=""
      [ "$probe_kind" = "canonical-paths" ] || continue
      cp_none=0
      local exe_prefix argv0_prefix argv1_json argv1_item
      exe_prefix="$(python3 "$py" get "$reg" "$name" probe.exe_realpath_prefix 2>/dev/null)" || exe_prefix=""
      argv0_prefix="$(python3 "$py" get "$reg" "$name" probe.argv0_prefix 2>/dev/null)" || argv0_prefix=""
      argv1_json="$(python3 "$py" get "$reg" "$name" probe.argv1 2>/dev/null)" || argv1_json=""
      if [ -z "$exe_prefix" ] || ! grep -qF "$exe_prefix" "$cbox_self"; then
        cp_missing="$cp_missing $name.exe_realpath_prefix"
      fi
      if [ -z "$argv0_prefix" ] || ! grep -qF "$argv0_prefix" "$cbox_self"; then
        cp_missing="$cp_missing $name.argv0_prefix"
      fi
      for argv1_item in $(printf '%s' "$argv1_json" | python3 -c 'import json,sys; print("\n".join(json.load(sys.stdin)))' 2>/dev/null); do
        grep -qF "$argv1_item" "$cbox_self" || cp_missing="$cp_missing $name.argv1:$argv1_item"
      done
    done
    if [ "$cp_none" = 1 ]; then
      v_skip "no canonical-paths engines declared"
    elif [ -z "$cp_missing" ]; then
      v_ok
    else
      v_fail "probe literals absent from _CBOX_PROBE_SH:${cp_missing}"
    fi
  fi

  v_t "engines registry: shared-session capability fields populated"
  local cap_missing="" resume seed hist
  for name in claude codex hermes; do
    resume="$(python3 "$py" get "$reg" "$name" resume_argv 2>/dev/null)" || resume=""
    seed="$(python3 "$py" get "$reg" "$name" seed_channel 2>/dev/null)" || seed=""
    hist="$(python3 "$py" get "$reg" "$name" history_read 2>/dev/null)" || hist=""
    case "$resume" in ""|null) cap_missing="$cap_missing $name.resume_argv" ;; esac
    case "$seed" in ""|null) cap_missing="$cap_missing $name.seed_channel" ;; esac
    case "$hist" in ""|null) cap_missing="$cap_missing $name.history_read" ;; esac
  done
  if [ -z "$cap_missing" ]; then
    v_ok
  else
    v_fail "shared-session capability fields missing/unpopulated:${cap_missing}"
  fi

  if [ -n "$pending" ]; then
    echo "NOTE: engines pending an entrypoint arm:${pending}"
  fi
  if [ -n "$sec_gaps" ]; then
    echo "NOTE: pending engines with no SEC_VARS coverage yet:${sec_gaps}"
  fi
}

_cbox_verify_netaccess_scope() {
  v_t "netaccess scope resolution: legacy configs never widen to all"
  command -v _cbox_netaccess_scope >/dev/null 2>&1 || { v_skip "generators not loaded"; return 0; }
  local bad=""
  _cbox_verify_scope_case() {
    local got
    got="$(CBOX_NETACCESS_SCOPE="$1" CBOX_NETACCESS_NETWORKS="$2" CBOX_NETACCESS_CIDRS="$3" _cbox_netaccess_scope)"
    [ "$got" = "$4" ] || bad="$bad [scope=$1 nets=$2 cidrs=$3 -> $got, want $4]"
  }
  _cbox_verify_scope_case "" "" "" all
  _cbox_verify_scope_case "" "mynet" "" list
  _cbox_verify_scope_case "" "" "10.42.0.0/16" list
  _cbox_verify_scope_case all "mynet" "" all
  _cbox_verify_scope_case list "" "" list
  _cbox_verify_scope_case bogus "mynet" "" list
  if [ -z "$bad" ]; then v_ok; else v_fail "scope matrix:$bad"; fi
}

_cbox_verify_doc_coverage() {
  local sec="$INSTALL_DIR/templates/sections.sh"
  local manual="$INSTALL_DIR/MANUAL.md"
  v_t "setup-doc coverage: every wizard section documented"
  if [ ! -f "$sec" ] || [ ! -f "$manual" ]; then
    v_skip "sections.sh or MANUAL.md not present (host-side check)"
    return 0
  fi
  if ! . "$sec" 2>/dev/null; then v_skip "sections.sh not readable"; return 0; fi
  [ -n "${SECTIONS[*]:-}" ] || { v_skip "SECTIONS not readable"; return 0; }
  local missing="" doctor_src="$INSTALL_DIR/cbox" s tok row
  local expected=""
  for s in "${SECTIONS[@]}"; do
    grep -qiE "^### +$s *\$" "$manual" || missing="$missing manual:$s"
    if [ -n "${SEC_DOCTOR_ROWS[$s]+set}" ]; then
      expected="$expected ${SEC_DOCTOR_ROWS[$s]}"
    else
      expected="$expected $s"
    fi
  done
  expected="$expected ${DOCTOR_EXTRA_ROWS:-}"
  for tok in "${!SEC_DEPS[@]}"; do
    [ -n "${SEC_DEP_TEXT[${SEC_DEPS[$tok]%% *}]:-}" ] || [ -n "${SEC_DEP_TEXT[${SEC_DEPS[$tok]}]:-}" ] || missing="$missing deptext:$tok"
  done
  for row in $expected; do
    grep -qE "_cbox_doctor_row \"$row\"" "$doctor_src" || missing="$missing missing-row:$row"
  done
  local present
  present="$(grep -oE '_cbox_doctor_row "[a-z][a-z-]*"' "$doctor_src" | sed 's/_cbox_doctor_row "//;s/"//' | sort -u)"
  for row in $present; do
    case " $expected " in *" $row "*) ;; *) missing="$missing undeclared-row:$row" ;; esac
  done
  if [ -z "$missing" ]; then
    v_ok "sections in MANUAL, dep-text complete, doctor rows match declarations both ways"
  else
    v_fail "coverage gaps:$missing"
  fi
}

_cbox_verify_v13_restore() {
  [ "${v13_restored:-1}" = 0 ] || return 0
  v13_restored=1
  if [ "$v13_had_cache" = 1 ]; then
    printf '%s\n' "$v13_saved" > "$v13_cache"
  else
    rm -f "$v13_cache"
  fi
  rm -f "$v13_cache.verify"
}

_cbox_verify_v13_digest_bump() {
  local eff="$1" root="$2"
  local v13_cache="$HOME/.config/cbox/base-digest.cache"
  local v13_saved="" v13_had_cache=0 v13_restored=0
  local fake_digest tag_before tag_after
  if [ -f "$v13_cache" ]; then
    v13_saved="$(cat "$v13_cache")"
    v13_had_cache=1
  fi
  trap '_cbox_verify_v13_restore' RETURN
  fake_digest="sha256:$(printf 'cbox-verify-fake-%s' "$$" | sha256sum | awk '{print $1}')"
  tag_before="$(_cbox_image_tag "$(_cbox_image_hash "$eff")")"
  {
    if [ -n "$v13_saved" ]; then
      printf '%s\n' "$v13_saved" | grep -v '^ubuntu:24.04|' || true
    fi
    printf 'ubuntu:24.04|%s|%s\n' "$fake_digest" "$(date +%s)"
  } > "$v13_cache.verify" 2>/dev/null
  if [ ! -s "$v13_cache.verify" ]; then
    v_skip "could not stage cache poke"
    return 0
  fi
  mv "$v13_cache.verify" "$v13_cache"
  ( . "$eff/cbox.conf" 2>/dev/null; _gen_effective "$eff" "$root" ) >/dev/null 2>&1 || true
  tag_after="$(_cbox_image_tag "$(_cbox_image_hash "$eff")")"
  _cbox_verify_v13_restore
  ( . "$eff/cbox.conf" 2>/dev/null; _gen_effective "$eff" "$root" ) >/dev/null 2>&1 || true
  if [ "$tag_before" != "$tag_after" ]; then
    v_ok "$tag_before -> $tag_after"
  else
    v_fail "tag unchanged after digest bump"
  fi
}

verify_isolated() {
  echo "== cbox verify (isolated) =="
  local root P eff cid n rc
  if ! root="$(_cbox_workspace_root)"; then
    v_t "isolated project resolvable from cwd"
    v_skip "cwd is home, /, or a mount root"
    echo "== cbox verify: $VN tests, $VOK ok, $VFAIL failed, $VSKIP skipped =="
    return 0
  fi
  P="$(_cbox_path_hash "$root")"
  eff="$HOME/.config/cbox/projects/$P"
  if [ ! -f "$eff/cbox.conf" ]; then
    v_t "effective config present for $root"
    v_skip "no project - run 'cbox run codex' first"
    echo "== cbox verify: $VN tests, $VOK ok, $VFAIL failed, $VSKIP skipped =="
    return 0
  fi
  _cbox_manifest_verify_conf "$eff" "$root"

  v_t "manifest verify (conf+generators)"
  v_ok

  local eff_scope eff_claude_target eff_codex_want
  eff_scope="$( unset CBOX_SESSION_SCOPE; . "$eff/cbox.conf" 2>/dev/null; printf '%s' "${CBOX_SESSION_SCOPE:-isolated}" )"
  eff_claude_target="$( unset CBOX_CLAUDE_TARGET; . "$eff/cbox.conf" 2>/dev/null; printf '%s' "${CBOX_CLAUDE_TARGET:-stable}" )"
  eff_codex_want="$( unset CBOX_CODEX_VERSION CBOX_CODEX_TARGET; . "$eff/cbox.conf" 2>/dev/null; printf '%s|%s' "${CBOX_CODEX_VERSION:-latest}" "${CBOX_CODEX_TARGET:-}" )"

  cid="$(_compose_p "$eff" ps -q cbox 2>/dev/null)" || cid=""

  v_t "v10 mirror tamper ignored"
  if [ -f "$root/.cbox/runtime/docker-compose.yml" ]; then
    local before after
    before="$(sha256sum "$eff/docker-compose.yml" | awk '{print $1}')"
    printf 'tampered: this line must never be read\n' >> "$root/.cbox/runtime/docker-compose.yml"
    _compose_p "$eff" config >/dev/null 2>&1 || true
    after="$(sha256sum "$eff/docker-compose.yml" | awk '{print $1}')"
    if [ "$before" = "$after" ]; then v_ok "effdir compose unchanged"; else v_fail "effdir compose mutated"; fi
  else
    v_skip "no mirror written yet"
  fi

  v_t "v11 SIGKILL-then-gc reap"
  if [ -n "$cid" ] && [ -z "${CBOX_VERIFY_NO_KILL:-}" ]; then
    n="$(_probe "$cid" 2>/dev/null)" || n=unknown
    if [ "$n" = 0 ]; then
      docker kill "$cid" >/dev/null 2>&1 || true
      gc >/dev/null 2>&1 || true
      if [ -z "$(_compose_p "$eff" ps -q cbox 2>/dev/null)" ]; then v_ok "reaped"; else v_fail "container survived gc"; fi
    else
      v_skip "container has $n live session(s) - refusing to kill a real session"
    fi
  else
    v_skip "no running container or CBOX_VERIFY_NO_KILL set"
  fi

  v_t "v12 piped claude -p no hang"
  if [ -n "$cid" ] || [ -f "$eff/docker-compose.yml" ]; then
    rc=0
    printf '' | _compose_p "$eff" exec -T cbox timeout 20 /entrypoint.sh true >/dev/null 2>&1 || rc=$?
    if [ "$rc" -ne 124 ]; then v_ok "no timeout"; else v_fail "hung past 20s"; fi
  else
    v_skip "no effective compose"
  fi

  v_t "v13 digest-bump triggers rebuild"
  if command -v docker >/dev/null 2>&1; then
    _cbox_verify_v13_digest_bump "$eff" "$root" || true
  else
    v_skip "docker not available"
  fi

  v_t "v14 slug round-trip vs live claude run"
  local slug slugdir
  slug="$(_cbox_slug "$root")"
  slugdir="$HOME/.claude/projects/$slug"
  if [ -d "$slugdir" ]; then v_ok "$slug"; else v_skip "no session recorded yet under $slugdir - run 'cbox run codex' once"; fi

  v_t "v15 agent-copies-binary still stops (B-2)"
  if [ -n "$cid" ]; then
    n="$(_probe "$cid" 2>/dev/null)" || n=unknown
    if [ "$n" = 0 ]; then
      if docker exec "$cid" sh -c 'cp "$HOME/.local/bin/claude" /tmp/.cbox-verify-copy 2>/dev/null && /tmp/.cbox-verify-copy --version' >/dev/null 2>&1; then
        n="$(_probe "$cid" 2>/dev/null)" || n=unknown
        docker exec "$cid" sh -c 'rm -f /tmp/.cbox-verify-copy' >/dev/null 2>&1 || true
        if [ "$n" = 0 ]; then v_ok "copy not counted"; else v_fail "copy inflated probe count to $n"; fi
      else
        v_skip "could not stage a binary copy in the container"
      fi
    else
      v_skip "container has $n live session(s) already"
    fi
  else
    v_skip "no running container"
  fi

  v_t "v16 buildx-absent digest fallback"
  if command -v docker >/dev/null 2>&1; then
    local stub stubdir dg
    stubdir="$(mktemp -d)"
    stub="$stubdir/docker"
    {
      printf '#!/bin/sh\n'
      printf 'if [ "$1" = buildx ]; then exit 1; fi\n'
      printf 'exec %q "$@"\n' "$(command -v docker)"
    } > "$stub"
    chmod 755 "$stub"
    dg="$(PATH="$stubdir:$PATH" CBOX_BASE_DIGEST_TTL=0 _cbox_resolve_base_digest ubuntu:24.04 2>/dev/null)" || dg=""
    rm -rf "$stubdir"
    if [ -n "$dg" ]; then v_ok "resolved via fallback"; else v_fail "digest resolution failed without buildx"; fi
  else
    v_skip "docker not available"
  fi

  v_t "restart policy is no"
  if grep -q 'restart: "no"' "$eff/docker-compose.yml" 2>/dev/null; then v_ok; else v_fail "restart policy is not \"no\""; fi

  v_t "external bins volumes (cbox-bins-claude/codex)"
  if grep -q 'name: cbox-bins-claude' "$eff/docker-compose.yml" 2>/dev/null \
    && grep -q 'name: cbox-bins-codex' "$eff/docker-compose.yml" 2>/dev/null \
    && grep -q 'external: true' "$eff/docker-compose.yml" 2>/dev/null; then
    v_ok
  else
    v_fail "cbox-bins-claude/codex not declared external"
  fi

  v_t "no claude-home volume overlapping projects/"
  if grep -q 'claude-home' "$eff/docker-compose.yml" 2>/dev/null; then v_fail "claude-home volume present"; else v_ok; fi

  v_t "session-scope isolated mounts only own slug"
  if [ "$eff_scope" = "isolated" ]; then
    if grep -q "projects/$slug:" "$eff/docker-compose.yml" 2>/dev/null && ! grep -q '\.claude/projects:\${HOST_HOME}' "$eff/docker-compose.yml" 2>/dev/null; then
      v_ok
    else
      v_fail "compose does not scope to slug $slug"
    fi
  else
    v_skip "CBOX_SESSION_SCOPE=global"
  fi

  v_t "workspace B absent in A (label-based cross-project check)"
  if command -v docker >/dev/null 2>&1; then
    local other has_other=0
    for other in "$HOME"/.config/cbox/projects/*/; do
      [ -d "$other" ] || continue
      [ "$(realpath "$other")" = "$(realpath "$eff")" ] && continue
      has_other=1
      break
    done
    if [ "$has_other" = 1 ] && [ -n "$cid" ]; then
      local otherroot
      otherroot="$(cat "$other/workspace" 2>/dev/null || true)"
      if [ -n "$otherroot" ] && docker exec "$cid" test -e "$otherroot" >/dev/null 2>&1; then
        v_fail "$otherroot visible inside this container"
      else
        v_ok "not visible"
      fi
    else
      v_skip "no other project or no running container to check"
    fi
  else
    v_skip "docker not available"
  fi

  v_t "two windows no premature stop / last exit immediate stop"
  v_skip "requires two concurrent live sessions - exercised manually, not by automated verify"

  v_t "two projects share one image (by inputs hash)"
  if command -v docker >/dev/null 2>&1; then
    local other otherhash myhash=""
    myhash="$(_cbox_image_hash "$eff" 2>/dev/null)" || myhash=""
    local found=0
    for other in "$HOME"/.config/cbox/projects/*/; do
      [ -d "$other" ] || continue
      [ "$(realpath "$other")" = "$(realpath "$eff")" ] && continue
      [ -f "$other/image.inputs" ] || continue
      otherhash="$(sha256sum "$other/image.inputs" 2>/dev/null | awk '{print $1}')" || otherhash=""
      if [ -n "$myhash" ] && [ "$otherhash" = "$myhash" ]; then found=1; break; fi
    done
    if [ "$found" = 1 ]; then v_ok "shared image confirmed"; else v_skip "no other project with matching inputs"; fi
  else
    v_skip "docker not available"
  fi

  v_t "claude bins mount read-only (write denied)"
  if [ -n "$cid" ]; then
    if _compose_p "$eff" exec -T cbox /entrypoint.sh sh -c 'touch "$HOME/.local/.cbox-verify"' >/dev/null 2>&1; then
      v_fail "writable"
    else
      v_ok "write denied"
    fi
  else
    v_skip "no running container"
  fi

  v_t "codex bins mount read-only (write denied)"
  if [ -n "$cid" ]; then
    if _compose_p "$eff" exec -T cbox /entrypoint.sh sh -c 'touch "$HOME/.codex/packages/.cbox-verify"' >/dev/null 2>&1; then
      v_fail "writable"
    else
      v_ok "write denied"
    fi
  else
    v_skip "no running container"
  fi

  v_t "claude stamp present and want matches pin"
  if [ -n "$cid" ]; then
    local iso_want iso_got
    iso_want="$eff_claude_target"
    if iso_got="$(_compose_p "$eff" exec -T cbox /entrypoint.sh sh -c 'sed -n 1p "$HOME/.local/.cbox-stamp"' 2>/dev/null)" && [ "$iso_got" = "$iso_want" ]; then
      v_ok "$iso_got"
    else
      v_fail "stamp missing or want '${iso_got:-}' != pin '$iso_want'"
    fi
  else
    v_skip "no running container"
  fi

  v_t "codex stamp present and want matches pin"
  if [ -n "$cid" ]; then
    local iso_want iso_got
    iso_want="$eff_codex_want"
    if iso_got="$(_compose_p "$eff" exec -T cbox /entrypoint.sh sh -c 'sed -n 1p "$HOME/.codex/packages/.cbox-stamp"' 2>/dev/null)" && [ "$iso_got" = "$iso_want" ]; then
      v_ok "$iso_got"
    else
      v_fail "stamp missing or want '${iso_got:-}' != pin '$iso_want'"
    fi
  else
    v_skip "no running container"
  fi

  v_t "resolved binaries executable and match stamp"
  if [ -n "$cid" ]; then
    if _compose_p "$eff" exec -T cbox /entrypoint.sh sh -c '
for f in "$HOME/.local/.cbox-stamp" "$HOME/.codex/packages/.cbox-stamp"; do
  p="$(sed -n 2p "$f")"
  v="$(sed -n 4p "$f")"
  test -n "$p" && test -x "$p" || exit 1
  case "$("$p" --version 2>&1)" in *"$v"*) ;; *) exit 1;; esac
done
' >/dev/null 2>&1; then
      v_ok
    else
      v_fail "resolved binary missing, not executable, or --version does not match stamp"
    fi
  else
    v_skip "no running container"
  fi

  v_t "bins volumes are the shared global names, not per-project"
  if grep -oE 'name: cbox-bins-(claude|codex)(-[0-9a-f]{8})?' "$eff/docker-compose.yml" 2>/dev/null \
    | grep -qE -- '-[0-9a-f]{8}$'; then
    v_skip "CBOX_BINS_SCOPE=pinned - per-tool private volume by design"
  elif grep -q 'name: cbox-bins-claude$' "$eff/docker-compose.yml" 2>/dev/null \
    && grep -q 'name: cbox-bins-codex$' "$eff/docker-compose.yml" 2>/dev/null; then
    v_ok "global cbox-bins-claude/codex"
  else
    v_fail "bins volume names are not the fixed global cbox-bins-claude/codex pair"
  fi

  v_t "two effdir composes reference the same bins volume names"
  local other_eff found_share=0
  for other_eff in "$HOME"/.config/cbox/projects/*/; do
    [ -d "$other_eff" ] || continue
    [ "$(realpath "$other_eff")" = "$(realpath "$eff")" ] && continue
    [ -f "$other_eff/docker-compose.yml" ] || continue
    if grep -q 'name: cbox-bins-claude$' "$eff/docker-compose.yml" 2>/dev/null \
      && grep -q 'name: cbox-bins-claude$' "$other_eff/docker-compose.yml" 2>/dev/null; then
      found_share=1
      break
    fi
  done
  if [ "$found_share" = 1 ]; then
    v_ok "shared with $(basename "$other_eff")"
  else
    v_skip "no other project with a matching global bins volume name"
  fi

  _cbox_verify_engines_registry

  echo "== cbox verify: $VN tests, $VOK ok, $VFAIL failed, $VSKIP skipped =="
  [ "$VFAIL" -eq 0 ] || exit 1
}

_cbox_doctor_in_container() {
  [ -n "${HOST_HOME:-}" ] && [ -n "${HOST_USER:-}" ] && [ -f /entrypoint.sh ]
}

_cbox_doctor_row() {
  printf '%-28s %-11s %s\n' "$1" "$2" "$3"
}

_cbox_doctor_file() {
  [ -e "$1" ]
}

_cbox_doctor_nonempty() {
  [ -s "$1" ]
}

_cbox_doctor_netaccess_detail() {
  local scope="${1:-list}"
  local nets="" n members mark missing="" cidr routes
  nets="$(_cbox_list_docker_networks)" || nets=""
  if [ -z "$nets" ]; then
    printf '  %s\n' "docker CLI or daemon not reachable - cannot enumerate networks"
    return 0
  fi
  if [ "$scope" = all ]; then
    printf '  %s\n' "docker networks on this host (scope=all - the proxy joins every one at apply time):"
  else
    printf '  %s\n' "docker networks on this host (* = configured for netaccess):"
  fi
  for n in $nets; do
    members="$(_cbox_docker_bounded network inspect -f '{{range $k, $v := .Containers}}{{$v.Name}} {{end}}' "$n")" || members=""
    members="${members% }"
    mark=" "
    if [ "$scope" = all ]; then
      mark="*"
    else
      case " ${CBOX_NETACCESS_NETWORKS:-} " in *" $n "*) mark="*" ;; esac
    fi
    printf '  %s %-26s %s\n' "$mark" "$n" "${members:-<no containers>}"
  done
  if [ "$scope" != all ]; then
    local nets_sp
    nets_sp="$(printf '%s' "$nets" | tr '\n' ' ')"
    for n in ${CBOX_NETACCESS_NETWORKS:-}; do
      case " $nets_sp " in
        *" $n "*) ;;
        *) missing="$missing $n" ;;
      esac
    done
    [ -z "$missing" ] || printf '  ! %s\n' "configured networks not found on this host:$missing"
  fi
  for cidr in ${CBOX_NETACCESS_CIDRS:-}; do
    routes="$(ip route show to match "$cidr" 2>/dev/null | grep -v '^default' | head -1)" || routes=""
    if [ -n "$routes" ]; then
      printf '    cidr %-18s closest matching host route (prefix match, may be broader): %s\n' "$cidr" "$routes"
    else
      printf '    cidr %-18s no non-default host route - reachability from the proxy is not guaranteed\n' "$cidr"
    fi
  done
}

doctor() {
  local in_container=0
  _cbox_doctor_in_container && in_container=1

  echo "== cbox doctor =="
  if [ "$in_container" = 1 ]; then
    echo "context: inside container (HOST_USER=${HOST_USER:-} HOST_HOME=${HOST_HOME:-})"
  else
    echo "context: host (run this from inside the container for a live per-container report)"
  fi
  echo

  local home="${HOME:-}"
  local claude_dir="$home/.claude"
  local codex_dir="$home/.codex"
  local hooks_dir="$claude_dir/hooks"

  _cbox_doctor_row FEATURE STATUS DETAIL
  _cbox_doctor_row "------------------------" "-----------" "------"

  local mode
  if [ -n "${CBOX_MODE:-}" ]; then
    mode="$CBOX_MODE"
    _cbox_doctor_row "mode" ACTIVE "CBOX_MODE=$mode"
  elif [ -n "${CBOX_SCOPE_ROOT:-}" ] || [ -n "${CBOX_SCOPE_SLUG:-}" ]; then
    _cbox_doctor_row "mode" ACTIVE "CBOX_MODE unset, farm scope CBOX_SCOPE_ROOT=${CBOX_SCOPE_ROOT:-} slug=${CBOX_SCOPE_SLUG:-}"
  else
    _cbox_doctor_row "mode" MISSING "CBOX_MODE not set and no scope env - cannot identify global/isolated"
  fi

  if [ -n "${CBOX_CONTEXT_PROFILE:-}" ]; then
    _cbox_doctor_row "context-profile" ACTIVE "CBOX_CONTEXT_PROFILE=$CBOX_CONTEXT_PROFILE"
  else
    _cbox_doctor_row "context-profile" MISSING "CBOX_CONTEXT_PROFILE not set, default would be full"
  fi

  if _cbox_doctor_nonempty "$hooks_dir/conduct-kernel.txt" 2>/dev/null; then
    if grep -qF "cbox:conduct-kernel:begin" "$claude_dir/CLAUDE.md" 2>/dev/null; then
      _cbox_doctor_row "continuity-brain" ACTIVE "conduct kernel present in hooks/ and inlined in CLAUDE.md"
    else
      _cbox_doctor_row "continuity-brain" CONFIG-ONLY "hooks/conduct-kernel.txt present but not inlined in CLAUDE.md"
    fi
  else
    _cbox_doctor_row "continuity-brain" MISSING "no hooks/conduct-kernel.txt in this container's ~/.claude"
  fi

  if [ "${CBOX_HISTORY:-}" = 1 ] || { [ -z "${CBOX_HISTORY:-}" ] && _cbox_doctor_nonempty "$claude_dir/CLAUDE.md" 2>/dev/null; }; then
    if _cbox_doctor_nonempty "$claude_dir/CLAUDE.md" 2>/dev/null; then
      _cbox_doctor_row "history" ACTIVE "CLAUDE.md deployed (CBOX_HISTORY=${CBOX_HISTORY:-unset,inferred})"
    else
      _cbox_doctor_row "history" MISSING "CLAUDE.md absent or empty"
    fi
  else
    _cbox_doctor_row "history" OFF "CBOX_HISTORY=${CBOX_HISTORY:-0}"
  fi

  if [ "${CBOX_GIT:-1}" = 1 ]; then
    _cbox_doctor_row "git-changelog" ACTIVE "CBOX_GIT=${CBOX_GIT:-1}"
  else
    _cbox_doctor_row "git-changelog" OFF "CBOX_GIT=$CBOX_GIT"
  fi

  if [ "${CBOX_DIARY:-1}" = 1 ]; then
    _cbox_doctor_row "diary" ACTIVE "CBOX_DIARY=${CBOX_DIARY:-1}"
  else
    _cbox_doctor_row "diary" OFF "CBOX_DIARY=$CBOX_DIARY"
  fi

  if [ "${CBOX_OPEN_QUESTIONS:-1}" = 1 ]; then
    _cbox_doctor_row "open-questions" ACTIVE "CBOX_OPEN_QUESTIONS=${CBOX_OPEN_QUESTIONS:-1}"
  else
    _cbox_doctor_row "open-questions" OFF "CBOX_OPEN_QUESTIONS=$CBOX_OPEN_QUESTIONS"
  fi

  if [ "${CBOX_GITCONFIG:-0}" = 1 ]; then
    if _cbox_doctor_file "$home/.gitconfig" 2>/dev/null; then
      _cbox_doctor_row "git-identity" ACTIVE "CBOX_GITCONFIG=1, ~/.gitconfig mounted"
    else
      _cbox_doctor_row "git-identity" CONFIG-ONLY "CBOX_GITCONFIG=1 but ~/.gitconfig not present"
    fi
  elif _cbox_doctor_file "$home/.gitconfig" 2>/dev/null; then
    _cbox_doctor_row "git-identity" ACTIVE "~/.gitconfig present (CBOX_GITCONFIG unset in this shell)"
  else
    _cbox_doctor_row "git-identity" OFF "no ~/.gitconfig, CBOX_GITCONFIG=${CBOX_GITCONFIG:-0}"
  fi

  if grep -q '^\[mcp_servers\.claude\]' "$codex_dir/config.toml" 2>/dev/null; then
    if [ -f "$hooks_dir/codex_mode_guard.py" ]; then
      _cbox_doctor_row "codex-mcp" ACTIVE "mcp_servers.claude wired in config.toml, guard hook present"
    else
      _cbox_doctor_row "codex-mcp" CONFIG-ONLY "mcp_servers.claude wired but codex_mode_guard.py missing"
    fi
  elif [ "${CBOX_CODEX_MCP:-0}" = 1 ]; then
    _cbox_doctor_row "codex-mcp" CONFIG-ONLY "CBOX_CODEX_MCP=1 but not wired in config.toml"
  else
    _cbox_doctor_row "codex-mcp" OFF "no mcp_servers.claude in config.toml, CBOX_CODEX_MCP=${CBOX_CODEX_MCP:-0}"
  fi

  local shim_mode="${CBOX_CODEX_PROGRESS_MODE:-}"
  if [ "$shim_mode" = shim ]; then
    if [ -f "$hooks_dir/codex_mcp_shim.py" ]; then
      _cbox_doctor_row "codex-progress" ACTIVE "CBOX_CODEX_PROGRESS_MODE=shim, shim file present"
    else
      _cbox_doctor_row "codex-progress" CONFIG-ONLY "CBOX_CODEX_PROGRESS_MODE=shim but shim file missing"
    fi
  elif [ -z "$shim_mode" ] && [ -f "$hooks_dir/codex_mcp_shim.py" ]; then
    _cbox_doctor_row "codex-progress" CONFIG-ONLY "shim file present but CBOX_CODEX_PROGRESS_MODE unset in this shell"
  else
    _cbox_doctor_row "codex-progress" OFF "CBOX_CODEX_PROGRESS_MODE=${shim_mode:-off}"
  fi

  if [ "$in_container" = 1 ]; then
    _cbox_doctor_row "egress" HOST-CHECK "network topology decided host-side (docker compose networks)"
    if [ -n "${CBOX_SOCKS_PROXY:-}" ]; then
      _cbox_doctor_row "netaccess" ACTIVE "CBOX_SOCKS_PROXY=$CBOX_SOCKS_PROXY; use it explicitly for target-network TCP"
    else
      _cbox_doctor_row "netaccess" HOST-CHECK "SOCKS proxy topology decided host-side"
    fi
    if [ -S "${CBOX_CONTAINER_EXEC_SOCKET:-/run/cbox-container-exec/bridge.sock}" ] && command -v cbox-container >/dev/null 2>&1; then
      _cbox_doctor_row "container-exec" ACTIVE "cbox-container client and private bridge socket are present"
    else
      _cbox_doctor_row "container-exec" OFF "no scoped host exec bridge in this session"
    fi
    _cbox_doctor_row "hostroute" HOST-CHECK "host forward-proxy route decided host-side"
    _cbox_doctor_row "gpu" HOST-CHECK "CDI/nvidia-ctk wiring decided host-side"
    _cbox_doctor_row "ssh" HOST-CHECK "agent-forward/keys mount decided host-side"
  else
    if [ "${CBOX_EGRESS_MODE:-off}" != off ]; then
      _cbox_doctor_row "egress" CONFIG-ONLY "CBOX_EGRESS_MODE=$CBOX_EGRESS_MODE, applied=${CBOX_EGRESS_APPLIED:-0} - verify in a running container"
    else
      _cbox_doctor_row "egress" OFF "CBOX_EGRESS_MODE=off"
    fi
    if [ -n "${CBOX_NETACCESS_MODE:-}" ] && [ "${CBOX_NETACCESS_MODE:-off}" != off ]; then
      local na_scope
      na_scope="$(_cbox_netaccess_scope)"
      if [ "$na_scope" = all ]; then
        _cbox_doctor_row "netaccess" CONFIG-ONLY "CBOX_NETACCESS_MODE=$CBOX_NETACCESS_MODE, scope=all - eligible Docker networks attach on cbox run, cidrs=[${CBOX_NETACCESS_CIDRS:-}]"
      elif [ -z "${CBOX_NETACCESS_NETWORKS:-}" ] && [ -z "${CBOX_NETACCESS_CIDRS:-}" ]; then
        _cbox_doctor_row "netaccess" CONFIG-ONLY "CBOX_NETACCESS_MODE=$CBOX_NETACCESS_MODE, scope=list with no targets - proxy denies everything"
      else
        _cbox_doctor_row "netaccess" CONFIG-ONLY "CBOX_NETACCESS_MODE=$CBOX_NETACCESS_MODE, scope=list networks=[${CBOX_NETACCESS_NETWORKS:-}] cidrs=[${CBOX_NETACCESS_CIDRS:-}] - lifecycle applies on cbox run"
      fi
      _cbox_doctor_netaccess_detail "$na_scope"
    else
      _cbox_doctor_row "netaccess" OFF "CBOX_NETACCESS_MODE=${CBOX_NETACCESS_MODE:-off}"
    fi
    if _cbox_netaccess_exec_active; then
      _cbox_doctor_row "container-exec" CONFIG-ONLY "host bridge is session-bound; explicit networks=[${CBOX_NETACCESS_NETWORKS:-}], workspace-guard=${CBOX_NETACCESS_EXEC_WORKSPACE_GUARD:-off}"
    else
      _cbox_doctor_row "container-exec" OFF "CBOX_NETACCESS_EXEC_MODE=${CBOX_NETACCESS_EXEC_MODE:-off}"
    fi
    if [ -n "${CBOX_HOST_ROUTE_MODE:-}" ] && [ "${CBOX_HOST_ROUTE_MODE:-off}" != off ]; then
      _cbox_doctor_row "hostroute" CONFIG-ONLY "CBOX_HOST_ROUTE_MODE=$CBOX_HOST_ROUTE_MODE, applied=${CBOX_HOST_ROUTE_APPLIED:-0} - verify in a running container"
    else
      _cbox_doctor_row "hostroute" OFF "CBOX_HOST_ROUTE_MODE=${CBOX_HOST_ROUTE_MODE:-off}"
    fi
    if [ "${CBOX_GPU:-0}" = 1 ]; then
      _cbox_doctor_row "gpu" CONFIG-ONLY "CBOX_GPU=1 - verify in a running container"
    else
      _cbox_doctor_row "gpu" OFF "CBOX_GPU=${CBOX_GPU:-0}"
    fi
    if [ -n "${CBOX_SSH_MODE:-}" ] && [ "${CBOX_SSH_MODE:-none}" != none ]; then
      _cbox_doctor_row "ssh" CONFIG-ONLY "CBOX_SSH_MODE=$CBOX_SSH_MODE - verify in a running container"
    else
      _cbox_doctor_row "ssh" OFF "CBOX_SSH_MODE=${CBOX_SSH_MODE:-none}"
    fi
  fi

  if [ "${CBOX_LOCAL_MODEL:-off}" = on ] && [ -n "${CBOX_LOCAL_MODEL_URL:-}" ] && [ -n "${CBOX_LOCAL_MODEL_NAME:-}" ]; then
    local lm_seed
    if [ "${CBOX_CLAUDE_MODE:-mount}" = mount ]; then
      lm_seed="$INSTALL_DIR/generated/claude-config/.claude.json"
    else
      lm_seed="$INSTALL_DIR/generated/state/claude.json"
    fi
    if [ "$in_container" = 1 ]; then
      _cbox_doctor_row "local-model" ACTIVE "CBOX_LOCAL_MODEL=on, url and name set"
    elif [ -f "$lm_seed" ] && grep -q '"local-qwen"' "$lm_seed" 2>/dev/null; then
      _cbox_doctor_row "local-model" ACTIVE "CBOX_LOCAL_MODEL=on, url and name set, local-qwen present in the rendered seed"
    else
      _cbox_doctor_row "local-model" CONFIG-ONLY "CBOX_LOCAL_MODEL=on but local-qwen absent from the rendered seed - regenerate (cbox up or ./setup.sh update local-model)"
    fi
  elif [ "${CBOX_LOCAL_MODEL:-off}" = on ]; then
    _cbox_doctor_row "local-model" CONFIG-ONLY "CBOX_LOCAL_MODEL=on but CBOX_LOCAL_MODEL_URL or CBOX_LOCAL_MODEL_NAME unset - delegate absent from render"
  else
    _cbox_doctor_row "local-model" OFF "CBOX_LOCAL_MODEL unset or off (default) - see cbox/etc/docs/LOCAL_MODEL_RUNBOOK.md"
  fi

  if [ "${CBOX_HERMES:-off}" = on ]; then
    local hermes_managed="$INSTALL_DIR/generated/hermes/managed.env"
    if { [ "${CBOX_HERMES_PROVIDER:-local}" = local ] && [ -z "${CBOX_HERMES_MODEL_URL:-}" ]; } \
      || [ -z "${CBOX_HERMES_MODEL_NAME:-}" ] || [ ! -f "$hermes_managed" ]; then
      _cbox_doctor_row "hermes" CONFIG-ONLY "CBOX_HERMES=on but provider/url/name incomplete or $hermes_managed missing - regenerate (cbox up or ./setup.sh update hermes)"
    else
      _cbox_doctor_row "hermes" ACTIVE "CBOX_HERMES=on, provider=${CBOX_HERMES_PROVIDER:-local}, version=${CBOX_HERMES_VERSION:-}"
    fi
  else
    _cbox_doctor_row "hermes" OFF "CBOX_HERMES unset or off (default)"
  fi

  if [ "${CBOX_HERMES_DELEGATE:-off}" = on ]; then
    if [ "${CBOX_HERMES:-off}" != on ]; then
      _cbox_doctor_row "hermes-delegate" CONFIG-ONLY "CBOX_HERMES_DELEGATE=on but CBOX_HERMES != on - the delegate requires the hermes console engine"
    else
      local hd_seed
      if [ "${CBOX_CLAUDE_MODE:-mount}" = mount ]; then
        hd_seed="$INSTALL_DIR/generated/claude-config/.claude.json"
      else
        hd_seed="$INSTALL_DIR/generated/state/claude.json"
      fi
      if [ "$in_container" = 1 ]; then
        _cbox_doctor_row "hermes-delegate" ACTIVE "CBOX_HERMES_DELEGATE=on, CBOX_HERMES=on"
      elif [ -f "$hd_seed" ] && grep -q '"hermes-local"' "$hd_seed" 2>/dev/null; then
        _cbox_doctor_row "hermes-delegate" ACTIVE "CBOX_HERMES_DELEGATE=on, hermes-local present in the rendered seed"
      else
        _cbox_doctor_row "hermes-delegate" CONFIG-ONLY "CBOX_HERMES_DELEGATE=on but hermes-local absent from the rendered seed - regenerate (cbox up or ./setup.sh update hermes-delegate)"
      fi
    fi
  else
    _cbox_doctor_row "hermes-delegate" OFF "CBOX_HERMES_DELEGATE unset or off (default)"
  fi

  if [ -f "$claude_dir/settings.json" ] && [ -s "$claude_dir/settings.json" ] \
    && python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$claude_dir/settings.json" >/dev/null 2>&1; then
    _cbox_doctor_row "settings" ACTIVE "~/.claude/settings.json present and valid JSON"
  else
    _cbox_doctor_row "settings" MISSING "~/.claude/settings.json absent, empty, or invalid JSON"
  fi

  if [ "$in_container" = 1 ]; then
    if [ -n "${CBOX_MANAGED_DIRS:-}" ]; then
      local md_bad="" md_dir md_owner_ok=1
      IFS=':' read -ra _doctor_managed_dirs <<< "$CBOX_MANAGED_DIRS"
      for md_dir in "${_doctor_managed_dirs[@]}"; do
        [ -n "$md_dir" ] || continue
        [ -e "$md_dir" ] || { md_bad="$md_bad $md_dir"; continue; }
        [ -w "$md_dir" ] || md_owner_ok=0
      done
      if [ -n "$md_bad" ]; then
        _cbox_doctor_row "managed-dirs" CONFIG-ONLY "CBOX_MANAGED_DIRS set but missing:$md_bad"
      elif [ "$md_owner_ok" = 1 ]; then
        _cbox_doctor_row "managed-dirs" ACTIVE "CBOX_MANAGED_DIRS ownership fixed up by entrypoint, all writable"
      else
        _cbox_doctor_row "managed-dirs" CONFIG-ONLY "CBOX_MANAGED_DIRS set but at least one dir not writable by this user"
      fi
    else
      _cbox_doctor_row "managed-dirs" OFF "CBOX_MANAGED_DIRS not set in this shell"
    fi
  else
    _cbox_doctor_row "managed-dirs" HOST-CHECK "CBOX_MANAGED_DIRS ownership fixup runs in the entrypoint, not decidable on the host"
  fi

  if [ "$in_container" = 1 ]; then
    _cbox_doctor_row "config-pending" HOST-CHECK "cbox config set is host-only - pending.apply lives outside the container"
  else
    local cfg_pf=""
    cfg_pf="$(_cbox_config_pending_file 2>/dev/null)" || cfg_pf=""
    if [ -n "$cfg_pf" ] && [ -s "$cfg_pf" ]; then
      _cbox_doctor_row "config-pending" CONFIG-ONLY "$(tr '\n' ' ' < "$cfg_pf")"
    else
      _cbox_doctor_row "config-pending" OFF "no pending.apply - nothing staged by cbox config set"
    fi
  fi

  local ss_ok=0
  if [ -f "$claude_dir/settings.json" ]; then
    if python3 -c "
import json, sys
try:
    d = json.load(open(sys.argv[1]))
except Exception:
    sys.exit(1)
hooks = d.get('hooks', {}).get('SessionStart', [])
text = json.dumps(hooks)
sys.exit(0 if 'SessionStart' not in ('',) and hooks else 1)
" "$claude_dir/settings.json" >/dev/null 2>&1; then
      ss_ok=1
    fi
  fi
  if [ "$ss_ok" = 1 ] && [ -f "$hooks_dir/continuity_session_start.py" ]; then
    _cbox_doctor_row "sessionstart-hooks" ACTIVE "SessionStart wired in settings.json, continuity_session_start.py present"
  elif [ "$ss_ok" = 1 ]; then
    _cbox_doctor_row "sessionstart-hooks" CONFIG-ONLY "SessionStart wired but continuity_session_start.py missing (older orchestrator-global.txt style?)"
  else
    _cbox_doctor_row "sessionstart-hooks" MISSING "no SessionStart hooks in settings.json"
  fi

  if [ -f "$codex_dir/AGENTS.override.md" ] && [ -f "$codex_dir/cbox-container.config.toml" ] && [ -f "$hooks_dir/codex_mcp_shim.py" ]; then
    if _cbox_doctor_nonempty "$codex_dir/AGENTS.override.md" 2>/dev/null; then
      _cbox_doctor_row "codex-profile" ACTIVE "AGENTS.override.md non-empty, container config + shim present"
    else
      _cbox_doctor_row "codex-profile" CONFIG-ONLY "AGENTS.override.md present but empty, container config + shim present"
    fi
  elif [ -f "$codex_dir/AGENTS.override.md" ] || [ -f "$codex_dir/cbox-container.config.toml" ] || [ -f "$hooks_dir/codex_mcp_shim.py" ]; then
    _cbox_doctor_row "codex-profile" CONFIG-ONLY "some codex profile artifacts present, not all three"
  else
    _cbox_doctor_row "codex-profile" MISSING "no AGENTS.override.md / cbox-container.config.toml / codex_mcp_shim.py"
  fi

  local manifest="$INSTALL_DIR/generated/context-manifest.json"
  if [ "$in_container" = 1 ]; then
    _cbox_doctor_row "context-manifest" HOST-CHECK "generated/context-manifest.json is a host-side setup artifact, not mounted into the container"
  elif [ -f "$manifest" ]; then
    if python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$manifest" >/dev/null 2>&1; then
      _cbox_doctor_row "context-manifest" ACTIVE "generated/context-manifest.json present and valid JSON"
    else
      _cbox_doctor_row "context-manifest" MISSING "generated/context-manifest.json present but not valid JSON"
    fi
  else
    _cbox_doctor_row "context-manifest" MISSING "no generated/context-manifest.json - run ./setup.sh update"
  fi

  local sess_root sess_dir
  if sess_root="$(_cbox_workspace_root 2>/dev/null)" && [ -d "$(_cbox_session_root "$sess_root")" ]; then
    sess_dir="$(_cbox_session_root "$sess_root")"
    local sid open_n=0 idle_n=0 closed_n=0 total=0 st
    while IFS= read -r sid; do
      [ -n "$sid" ] || continue
      total=$((total + 1))
      st="$(_cbox_session_field_get "$sess_root" "$sid" state 2>/dev/null)" || st=""
      st="${st%\"}"; st="${st#\"}"
      case "$st" in
        open) open_n=$((open_n + 1)) ;;
        idle) idle_n=$((idle_n + 1)) ;;
        closed) closed_n=$((closed_n + 1)) ;;
      esac
    done < <(_cbox_session_list_ids "$sess_root")
    _cbox_doctor_row "sessions" ACTIVE "$total session(s): open=$open_n idle=$idle_n closed=$closed_n"
  else
    _cbox_doctor_row "sessions" OFF "no .cbox/sessions/ - no cbox session created yet in this scope"
  fi

  echo
  echo "legend: ACTIVE=wired and operational here, CONFIG-ONLY=configured but not active in this container, OFF=disabled, MISSING=expected artifact absent, HOST-CHECK=needs docker/GPU/TTY, not decidable in-container"
}

_cbox_config_load_sections() {
  [ -n "${SECTIONS[*]:-}" ] && return 0
  local sec="$INSTALL_DIR/templates/sections.sh"
  [ -f "$sec" ] || die "$sec missing"
  . "$sec"
}

_cbox_config_in_container() {
  _cbox_doctor_in_container
}

_cbox_config_whitelist() {
  _cbox_config_load_sections
  local s v
  for s in "${SECTIONS[@]}"; do
    for v in ${SEC_VARS[$s]:-}; do
      printf '%s\n' "$v"
    done
  done
}

_cbox_config_is_whitelisted() {
  local key="$1"
  case "$key" in
    ''|*[!A-Z0-9_]*) return 1 ;;
  esac
  case "$key" in
    [A-Z]*) ;;
    *) return 1 ;;
  esac
  local w
  while IFS= read -r w; do
    [ "$w" = "$key" ] && return 0
  done < <(_cbox_config_whitelist)
  return 1
}

_cbox_config_section_for_var() {
  _cbox_config_load_sections
  local key="$1" s v
  for s in "${SECTIONS[@]}"; do
    for v in ${SEC_VARS[$s]:-}; do
      [ "$v" = "$key" ] && { printf '%s' "$s"; return 0; }
    done
  done
  return 1
}

_cbox_config_no_ctrl() {
  local val="$1" c i
  case "$val" in
    *$'\n'*|*$'\r'*) return 1 ;;
  esac
  for ((i = 0; i < ${#val}; i++)); do
    c="${val:i:1}"
    case "$c" in
      $'\x00'|$'\x01'|$'\x02'|$'\x03'|$'\x04'|$'\x05'|$'\x06'|$'\x07'|$'\x08'|\
      $'\x0b'|$'\x0c'|$'\x0e'|$'\x0f'|$'\x10'|$'\x11'|$'\x12'|$'\x13'|$'\x14'|\
      $'\x15'|$'\x16'|$'\x17'|$'\x18'|$'\x19'|$'\x1a'|$'\x1b'|$'\x1c'|$'\x1d'|\
      $'\x1e'|$'\x1f')
        return 1
        ;;
    esac
  done
  return 0
}

_cbox_config_validate_enum() {
  local val="$1"; shift
  local a
  for a in "$@"; do
    [ "$val" = "$a" ] && return 0
  done
  return 1
}

_cbox_config_validate_uint() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
  esac
  return 0
}

_cbox_config_validate_path() {
  case "$1" in
    ''|*[!\ -~]*) return 1 ;;
    *' '*) return 1 ;;
    /*) return 0 ;;
    '~'|'~/'*) return 0 ;;
  esac
  return 1
}

_cbox_config_validate_url() {
  case "$1" in
    http://*|https://*) return 0 ;;
  esac
  return 1
}

_cbox_config_validate_var() {
  local key="$1" val="$2"
  _cbox_config_no_ctrl "$val" || { printf 'contains a control character'; return 1; }
  case "$key" in
    CBOX_MODE)
      _cbox_config_validate_enum "$val" global isolated || { printf 'expected one of: global isolated'; return 1; }
      ;;
    CBOX_SESSION_SCOPE)
      _cbox_config_validate_enum "$val" isolated global || { printf 'expected one of: isolated global'; return 1; }
      ;;
    CBOX_BASE_DIGEST_TTL)
      _cbox_config_validate_uint "$val" || { printf 'expected a non-negative integer (seconds)'; return 1; }
      ;;
    CBOX_CLAUDE_MODE|CBOX_CODEX_MODE)
      _cbox_config_validate_enum "$val" mount volume || { printf 'expected one of: mount volume'; return 1; }
      ;;
    CBOX_CLAUDE_PATH|CBOX_CODEX_PATH|CBOX_VENV_PATH|CBOX_SSH_AGENT_DIR)
      [ -z "$val" ] || _cbox_config_validate_path "$val" || { printf 'expected an absolute path (or empty)'; return 1; }
      ;;
    CBOX_CLAUDE_BACKUP|CBOX_CODEX_BACKUP)
      _cbox_config_validate_enum "$val" y c n || { printf 'expected one of: y c n'; return 1; }
      ;;
    CBOX_WORKSPACES)
      local w
      for w in $val; do
        _cbox_config_validate_path "$w" || { printf 'workspace entries must be absolute paths: %s' "$w"; return 1; }
      done
      ;;
    CBOX_WORKDIR)
      [ -z "$val" ] || _cbox_config_validate_path "$val" || { printf 'expected an absolute path (or empty)'; return 1; }
      ;;
    CBOX_VENV_MODE)
      _cbox_config_validate_enum "$val" none host volume || { printf 'expected one of: none host volume'; return 1; }
      ;;
    CBOX_GPU)
      _cbox_config_validate_enum "$val" 0 1 || { printf 'expected one of: 0 1'; return 1; }
      ;;
    CBOX_EGRESS_MODE)
      _cbox_config_validate_enum "$val" off allowlist blocklist || { printf 'expected one of: off allowlist blocklist'; return 1; }
      ;;
    CBOX_EGRESS_APPLIED)
      _cbox_config_validate_enum "$val" 0 1 || { printf 'expected one of: 0 1'; return 1; }
      ;;
    CBOX_NETACCESS_MODE)
      _cbox_config_validate_enum "$val" off socks || { printf 'expected one of: off socks'; return 1; }
      ;;
    CBOX_NETACCESS_APPLIED)
      _cbox_config_validate_enum "$val" 0 1 || { printf 'expected one of: 0 1'; return 1; }
      ;;
    CBOX_NETACCESS_NETWORKS)
      local n
      for n in $val; do
        case "$n" in
          [A-Za-z0-9]*) ;;
          *) printf 'invalid network name: %s' "$n"; return 1 ;;
        esac
        case "$n" in
          *[!A-Za-z0-9_.-]*) printf 'invalid network name: %s' "$n"; return 1 ;;
        esac
      done
      ;;
    CBOX_NETACCESS_CIDRS)
      command -v _cbox_is_ipv4_cidr >/dev/null 2>&1 || . "$INSTALL_DIR/templates/generators.sh"
      local c
      for c in $val; do
        if ! _cbox_is_ipv4_cidr "$c" || [ "${c%/*}" = "0.0.0.0" ]; then
          printf 'invalid IPv4 CIDR: %s' "$c"; return 1
        fi
        if [ "${c#*/}" -lt 8 ]; then
          printf 'prefix too broad (minimum /8): %s' "$c"; return 1
        fi
      done
      ;;
    CBOX_NETACCESS_SOCKS_PORT)
      _cbox_config_validate_uint "$val" || { printf 'expected a non-negative integer (port)'; return 1; }
      [ "$val" -ge 1 ] && [ "$val" -le 65535 ] || { printf 'expected port 1..65535'; return 1; }
      ;;
    CBOX_NETACCESS_EXEC_MODE)
      _cbox_config_validate_enum "$val" off scoped || { printf 'expected one of: off scoped'; return 1; }
      ;;
    CBOX_NETACCESS_EXEC_WORKSPACE_GUARD)
      _cbox_config_validate_enum "$val" off on || { printf 'expected one of: off on'; return 1; }
      ;;
    CBOX_NETACCESS_EXEC_TIMEOUT)
      _cbox_config_validate_uint "$val" || { printf 'expected a non-negative integer'; return 1; }
      [ "$val" -ge 1 ] && [ "$val" -le 3600 ] || { printf 'expected integer 1..3600'; return 1; }
      ;;
    CBOX_NETACCESS_EXEC_MAX_BYTES)
      _cbox_config_validate_uint "$val" || { printf 'expected a non-negative integer'; return 1; }
      [ "$val" -ge 1024 ] && [ "$val" -le 16777216 ] || { printf 'expected integer 1024..16777216'; return 1; }
      ;;
    CBOX_HOST_ROUTE_MODE)
      _cbox_config_validate_enum "$val" off host-proxy || { printf 'expected one of: off host-proxy'; return 1; }
      ;;
    CBOX_HOST_ROUTE_APPLIED)
      _cbox_config_validate_enum "$val" 0 1 || { printf 'expected one of: 0 1'; return 1; }
      ;;
    CBOX_HOST_PROXY_URL)
      [ -z "$val" ] || _cbox_config_validate_url "$val" || { printf 'expected an http(s):// URL (or empty)'; return 1; }
      ;;
    CBOX_HOST_PROXY_ADDR_MODE)
      _cbox_config_validate_enum "$val" host-gateway explicit || { printf 'expected one of: host-gateway explicit'; return 1; }
      ;;
    CBOX_SSH_MODE)
      _cbox_config_validate_enum "$val" none host-agent container-keys mixed || { printf 'expected one of: none host-agent container-keys mixed'; return 1; }
      ;;
    CBOX_BASHRC)
      _cbox_config_validate_enum "$val" 0 1 || { printf 'expected one of: 0 1'; return 1; }
      ;;
    CBOX_MCP_SERVERS|CBOX_AGENTS)
      : ;;
    CBOX_CODEX_PROGRESS_MODE)
      _cbox_config_validate_enum "$val" off shim || { printf 'expected one of: off shim'; return 1; }
      ;;
    CBOX_LOCAL_MODEL)
      _cbox_config_validate_enum "$val" off on || { printf 'expected one of: off on'; return 1; }
      ;;
    CBOX_LOCAL_MODEL_URL)
      [ -z "$val" ] || _cbox_config_validate_url "$val" || { printf 'expected an http(s):// URL (or empty)'; return 1; }
      ;;
    CBOX_LOCAL_MODEL_NAME)
      : ;;
    CBOX_HERMES)
      _cbox_config_validate_enum "$val" off on || { printf 'expected one of: off on'; return 1; }
      ;;
    CBOX_HERMES_VERSION)
      printf '%s' "$val" | grep -Eq '^[0-9]+([.][0-9]+){1,3}$' || { printf 'expected a plain x.y[.z[.w]] version'; return 1; }
      ;;
    CBOX_HERMES_PROVIDER)
      _cbox_config_validate_enum "$val" local nous openrouter openai anthropic || { printf 'expected one of: local nous openrouter openai anthropic'; return 1; }
      ;;
    CBOX_HERMES_MODEL_URL)
      [ -z "$val" ] || _cbox_config_validate_url "$val" || { printf 'expected an http(s):// URL (or empty)'; return 1; }
      ;;
    CBOX_HERMES_MODEL_NAME)
      : ;;
    CBOX_HERMES_DELEGATE)
      _cbox_config_validate_enum "$val" off on || { printf 'expected one of: off on'; return 1; }
      ;;
    CBOX_HERMES_DELEGATE_PROVIDER)
      [ -z "$val" ] || _cbox_config_validate_enum "$val" local nous openrouter openai anthropic || { printf 'expected one of: local nous openrouter openai anthropic (or empty)'; return 1; }
      ;;
    CBOX_HERMES_DELEGATE_BASE_URL)
      [ -z "$val" ] || _cbox_config_validate_url "$val" || { printf 'expected an http(s):// URL (or empty)'; return 1; }
      ;;
    CBOX_HERMES_DELEGATE_MODEL)
      : ;;
    CBOX_LIMIT_AUTORESUME)
      _cbox_config_validate_enum "$val" off on || { printf 'expected one of: off on'; return 1; }
      ;;
    CBOX_LIMIT_RESUME_DELAY|CBOX_LIMIT_RESUME_STAGGER|CBOX_LIMIT_RESUME_MAX_PER_DAY)
      _cbox_config_validate_uint "$val" || { printf 'expected a non-negative integer'; return 1; }
      ;;
    CBOX_LIMIT_RESUME_PROMPT)
      [ -n "$val" ] || { printf 'must not be empty'; return 1; }
      ;;
    CBOX_CODEX_MCP)
      _cbox_config_validate_enum "$val" 0 1 || { printf 'expected one of: 0 1'; return 1; }
      ;;
    CBOX_HISTORY|CBOX_GIT|CBOX_DIARY|CBOX_OPEN_QUESTIONS)
      _cbox_config_validate_enum "$val" 0 1 || { printf 'expected one of: 0 1'; return 1; }
      ;;
    CBOX_CONTEXT_PROFILE)
      _cbox_config_validate_enum "$val" full light || { printf 'expected one of: full light'; return 1; }
      ;;
    CBOX_GITCONFIG)
      _cbox_config_validate_enum "$val" 0 1 || { printf 'expected one of: 0 1'; return 1; }
      ;;
    CBOX_APT_EXTRA)
      local p
      for p in $val; do
        case "$p" in
          *[!A-Za-z0-9.+-]*|[.+-]*) printf 'invalid package name: %s' "$p"; return 1 ;;
        esac
      done
      ;;
    CBOX_CLAUDE_TARGET)
      printf '%s' "$val" | grep -Eq '^(stable|latest|[0-9]+\.[0-9]+\.[0-9]+(-[A-Za-z0-9.]+)?)$' || { printf 'expected stable, latest, or x.y.z'; return 1; }
      ;;
    CBOX_CODEX_VERSION)
      printf '%s' "$val" | grep -Eq '^(latest|[0-9]+\.[0-9]+\.[0-9]+(-(alpha|beta)(\.[0-9]+)?)?)$' || { printf 'expected latest or x.y.z'; return 1; }
      ;;
    CBOX_CODEX_TARGET)
      : ;;
    CBOX_BINS_SCOPE)
      _cbox_config_validate_enum "$val" global pinned || { printf 'expected one of: global pinned'; return 1; }
      ;;
    CBOX_RESTART_POLICY)
      _cbox_config_validate_enum "$val" no unless-stopped || { printf 'expected one of: no unless-stopped'; return 1; }
      ;;
    *)
      printf 'no validator registered for %s' "$key"; return 1
      ;;
  esac
  return 0
}

_cbox_config_dep_gate() {
  local key="$1" section
  _cbox_config_load_sections
  section="$(_cbox_config_section_for_var "$key")" || return 0
  local tok mech cond met=1
  for tok in ${SEC_DEPS[$section]:-}; do
    mech="${tok%%:*}"
    cond="${tok#*:}"
    met=1
    case "$cond" in
      isolated-mode) [ "${CBOX_MODE:-global}" = isolated ] && met=0 ;;
      no-cdi) command -v nvidia-ctk >/dev/null 2>&1 && [ -f /etc/cdi/nvidia.yaml ] && met=0 ;;
      hermes-off) [ "${CBOX_HERMES:-off}" != on ] && met=0 ;;
      hooks|continuity-hooks) met=0 ;;
    esac
    if [ "$mech" = disable ] && [ "$met" = 0 ]; then
      printf '%s' "${SEC_DEP_TEXT[$tok]:-$tok}"
      return 1
    fi
  done
  return 0
}

_cbox_config_apply_cmd_for() {
  local class="$1"
  case "$class" in
    none) printf 'none - takes effect on next cbox run' ;;
    shell) printf 'source ~/.bashrc' ;;
    restart) printf 'cbox down && cbox run <bin>' ;;
    recreate|topology) printf 'cbox down && cbox run <bin> (compose recreates)' ;;
    rebuild) printf 'next cbox run rebuilds the image automatically (image.inputs changed)' ;;
    *) printf 'unknown apply class' ;;
  esac
}

_cbox_config_get() {
  local mode eff conf
  mode="$(_cbox_effective_mode)"
  case "$mode" in
    isolated)
      local root
      root="$(_cbox_workspace_root)" || die "refusing to operate in $PWD (home, /, or a mount root)"
      eff="$HOME/.config/cbox/projects/$(_cbox_path_hash "$root")"
      conf="$eff/cbox.conf"
      ;;
    global)
      conf="$INSTALL_DIR/cbox.conf"
      ;;
    *)
      die_no_conf
      ;;
  esac
  [ -f "$conf" ] || { echo "cbox: no configuration at $conf yet - run ./setup.sh first" >&2; return 1; }

  _cbox_config_load_sections
  local arg="${1:-}"
  if [ "$arg" = "--all" ]; then
    local s v val
    for s in "${SECTIONS[@]}"; do
      [ -n "${SEC_VARS[$s]:-}" ] || continue
      printf '# %s\n' "$s"
      for v in ${SEC_VARS[$s]}; do
        val="$(unset "$v"; . "$conf" >/dev/null 2>&1; printf '%s' "${!v-}")"
        printf '%s=%s\n' "$v" "$val"
      done
    done
    return 0
  fi
  if [ "$arg" = "--section" ]; then
    local sname="${2:-}" v val found=0
    for s in "${SECTIONS[@]}"; do
      [ "$s" = "$sname" ] && { found=1; break; }
    done
    if [ "$found" != 1 ]; then
      echo "cbox: unknown section '$sname' - valid sections: ${SECTIONS[*]}" >&2
      return 1
    fi
    for v in ${SEC_VARS[$sname]:-}; do
      val="$(unset "$v"; . "$conf" >/dev/null 2>&1; printf '%s' "${!v-}")"
      printf '%s=%s\n' "$v" "$val"
    done
    return 0
  fi
  local key="$arg"
  if ! _cbox_config_is_whitelisted "$key"; then
    echo "cbox: unknown key '$key' - valid sections: ${SECTIONS[*]}" >&2
    return 1
  fi
  local val
  val="$(unset "$key"; . "$conf" >/dev/null 2>&1; printf '%s' "${!key-}")"
  printf '%s=%s\n' "$key" "$val"
}

_cbox_config_parse_pairs() {
  local pair key val
  CBOX_CONFIG_KEYS=()
  CBOX_CONFIG_VALS=()
  for pair in "$@"; do
    case "$pair" in
      *=*) key="${pair%%=*}"; val="${pair#*=}" ;;
      *) echo "cbox: invalid assignment (expected KEY=VALUE): $pair" >&2; return 1 ;;
    esac
    if ! printf '%s' "$key" | grep -Eq '^[A-Z][A-Z0-9_]*$'; then
      echo "cbox: invalid key '$key' - must match ^[A-Z][A-Z0-9_]*\$" >&2
      return 1
    fi
    if ! _cbox_config_is_whitelisted "$key"; then
      echo "cbox: key '$key' is not in the settable whitelist" >&2
      return 1
    fi
    case "$val" in
      *$'\n'*|*$'\r'*)
        echo "cbox: value for $key contains a newline or carriage return - rejected" >&2
        return 1
        ;;
    esac
    if printf '%s' "$val" | LC_ALL=C grep -qP '\x00'; then
      echo "cbox: value for $key contains a NUL byte - rejected" >&2
      return 1
    fi
    CBOX_CONFIG_KEYS+=("$key")
    CBOX_CONFIG_VALS+=("$val")
  done
  return 0
}

_cbox_config_set_var() {
  local key="$1" val="$2"
  printf -v "$key" '%s' "$val"
}

_cbox_config_touched_sections() {
  local -n _keys="$1"
  local k s out="" seen=""
  for k in "${_keys[@]}"; do
    s="$(_cbox_config_section_for_var "$k")" || continue
    case " $seen " in
      *" $s "*) continue ;;
    esac
    seen="$seen $s"
    out="$out $s"
  done
  printf '%s' "${out# }"
}

_cbox_config_write_pending() {
  local eff="$1"; shift
  local -a sections=("$@")
  local s tmp
  tmp="$(mktemp "$eff/.cbox.XXXXXX")"
  for s in "${sections[@]}"; do
    printf '%s=%s\n' "$s" "${SEC_APPLY[$s]:-none}" >> "$tmp"
  done
  chmod 0644 "$tmp"
  mv "$tmp" "$eff/pending.apply"
}

_cbox_config_section_has_dictate() {
  local s="$1" tok
  for tok in ${SEC_DEPS[$s]:-}; do
    case "$tok" in dictate:*) return 0 ;; esac
  done
  return 1
}

_cbox_config_print_report() {
  local -a sections=("$@")
  local s
  echo "cbox: config set staged - apply status:"
  for s in "${sections[@]}"; do
    printf '  %-16s %-10s %s\n' "$s" "${SEC_APPLY[$s]:-none}" "$(_cbox_config_apply_cmd_for "${SEC_APPLY[$s]:-none}")"
    if _cbox_config_section_has_dictate "$s"; then
      printf '    note: %s has wizard-only auto-deploy behavior (hook install/removal) that headless config set does not perform - run setup.sh to match wizard state if this section flipped on/off\n' "$s"
    fi
  done
}

_cbox_config_regen_isolated() {
  local eff="$1" root="$2"
  _gen_effective "$eff" "$root"
}

_cbox_config_regen_global() {
  _global_prepare
}

_cbox_config_set() {
  if _cbox_config_in_container; then
    echo "cbox: config set is host-only - run it from a host shell, not inside the container (get is still allowed)" >&2
    return 1
  fi
  [ "$#" -ge 1 ] || { echo "cbox: usage: $0 config set KEY=VALUE [KEY=VALUE...]" >&2; return 1; }

  _cbox_config_load_sections
  _cbox_config_parse_pairs "$@" || return 1

  local i key val errmsg
  for i in "${!CBOX_CONFIG_KEYS[@]}"; do
    key="${CBOX_CONFIG_KEYS[$i]}"
    val="${CBOX_CONFIG_VALS[$i]}"
    if ! errmsg="$(_cbox_config_validate_var "$key" "$val")"; then
      echo "cbox: invalid value for $key: '$val' - ${errmsg:-rejected}" >&2
      return 1
    fi
  done

  local mode
  mode="$(_cbox_effective_mode)"
  case "$mode" in
    isolated) _cbox_config_set_isolated ;;
    global) _cbox_config_set_global ;;
    *) die_no_conf ;;
  esac
}

_cbox_config_apply_staged_vars() {
  local i
  for i in "${!CBOX_CONFIG_KEYS[@]}"; do
    _cbox_config_set_var "${CBOX_CONFIG_KEYS[$i]}" "${CBOX_CONFIG_VALS[$i]}"
  done
}

_cbox_config_dep_gate_check() {
  local i key reason
  for i in "${!CBOX_CONFIG_KEYS[@]}"; do
    key="${CBOX_CONFIG_KEYS[$i]}"
    if ! reason="$(_cbox_config_dep_gate "$key")"; then
      echo "cbox: rejecting set - dependency rule for $key would force it back: $reason" >&2
      return 1
    fi
  done
  return 0
}

_cbox_config_preserve_extra_lines() {
  local conf="$1" key
  [ -f "$conf" ] || return 0
  while IFS= read -r line; do
    case "$line" in
      [A-Z]*=*)
        key="${line%%=*}"
        if ! _cbox_config_is_whitelisted "$key"; then
          printf '%s\n' "$line"
        fi
        ;;
    esac
  done < "$conf"
}

_cbox_config_set_isolated() {
  local root eff
  root="$(_cbox_workspace_root)" || die "refusing to operate in $PWD (home, /, or a mount root)"
  eff="$HOME/.config/cbox/projects/$(_cbox_path_hash "$root")"
  [ -f "$eff/cbox.conf" ] || die "no effective config for $root - run 'cbox run codex' or 'setup.sh --local $root' first"

  local status
  status="$(_cbox_manifest_status "$eff" "$root")"
  case "$status" in
    malformed|collision)
      echo "cbox: refusing - effective config manifest is $status; re-derive with setup.sh --local --from-global $root" >&2
      return 1
      ;;
    drifted)
      echo "cbox: refusing - effective config has drifted; re-derive with setup.sh --local --from-global $root" >&2
      return 1
      ;;
  esac

  mkdir -p "$eff"
  local lockfile="$eff/.regen.lock"
  exec 6> "$lockfile"
  flock -x 6 || { echo "cbox: cannot lock $lockfile" >&2; exec 6>&-; return 1; }

  local backup_conf backup_gen rc=0
  backup_conf="$(mktemp)"
  backup_gen="$(mktemp -d)"
  cp "$eff/cbox.conf" "$backup_conf"
  if [ -d "$eff/generated" ]; then
    cp -a "$eff/generated" "$backup_gen/generated"
  fi

  (
    set -e
    unset CBOX_MODE CBOX_SESSION_SCOPE CBOX_BASE_DIGEST_TTL CBOX_CODEX_TARGET
    . "$eff/cbox.conf"
    _cbox_config_apply_staged_vars
    _cbox_config_dep_gate_check
    local tmp
    tmp="$(mktemp "$eff/.cbox.XXXXXX")"
    {
      local v
      for v in $(_cbox_config_whitelist); do
        printf '%s=%q\n' "$v" "${!v-}"
      done
      _cbox_config_preserve_extra_lines "$eff/cbox.conf"
    } > "$tmp"
    chmod 0644 "$tmp"
    mv "$tmp" "$eff/cbox.conf"
    . "$eff/cbox.conf"
    export CBOX_LOCAL_MODEL CBOX_LOCAL_MODEL_URL CBOX_LOCAL_MODEL_NAME
    export CBOX_HERMES CBOX_HERMES_VERSION CBOX_HERMES_PROVIDER CBOX_HERMES_MODEL_URL CBOX_HERMES_MODEL_NAME
    _cbox_config_regen_isolated "$eff" "$root"
  ) || rc=$?

  if [ "$rc" -ne 0 ]; then
    local restore_tmp
    restore_tmp="$(mktemp "$eff/.cbox.XXXXXX")"
    cp "$backup_conf" "$restore_tmp"
    chmod 0644 "$restore_tmp"
    mv "$restore_tmp" "$eff/cbox.conf"
    if [ -d "$backup_gen/generated" ]; then
      local restore_gen_tmp
      restore_gen_tmp="$(mktemp -d "$eff/.cbox-gen.XXXXXX")"
      cp -a "$backup_gen/generated/." "$restore_gen_tmp/"
      rm -rf "$eff/generated.stale.$$"
      [ -d "$eff/generated" ] && mv "$eff/generated" "$eff/generated.stale.$$"
      mv "$restore_gen_tmp" "$eff/generated"
      rm -rf "$eff/generated.stale.$$"
    fi
    rm -f "$backup_conf"
    rm -rf "$backup_gen"
    exec 6>&-
    echo "cbox: config set failed - previous configuration and generated artifacts restored" >&2
    return 1
  fi

  rm -f "$backup_conf"
  rm -rf "$backup_gen"

  _cbox_manifest_write "$eff" "$root" "$eff/cbox.conf"
  _cbox_manifest_write_generated "$eff"

  local touched
  touched="$(_cbox_config_touched_sections CBOX_CONFIG_KEYS)"
  local -a touched_arr=()
  read -r -a touched_arr <<< "$touched"
  if [ "${#touched_arr[@]}" -gt 0 ]; then
    _cbox_config_write_pending "$eff" "${touched_arr[@]}"
    _cbox_config_print_report "${touched_arr[@]}"
  fi

  exec 6>&-
  return 0
}

_cbox_config_set_global() {
  require_global_conf
  local conf="$INSTALL_DIR/cbox.conf"
  local lockfile="$INSTALL_DIR/.regen.lock"
  exec 6> "$lockfile"
  flock -x 6 || { echo "cbox: cannot lock $lockfile" >&2; exec 6>&-; return 1; }

  local loaded_sha cur_sha
  loaded_sha="$(sha256sum "$conf" | awk '{print $1}')"

  local backup="$conf.bak"
  cp "$conf" "$backup"

  local rc=0
  (
    set -e
    . "$conf"
    _cbox_config_apply_staged_vars
    _cbox_config_dep_gate_check
    cur_sha="$(sha256sum "$conf" | awk '{print $1}')"
    if [ "$cur_sha" != "$loaded_sha" ]; then
      echo "cbox: refusing - global cbox.conf changed on disk since load (concurrent writer race) - re-run config set" >&2
      exit 1
    fi
    local tmp
    tmp="$(mktemp "$INSTALL_DIR/.cbox.XXXXXX")"
    {
      local v
      for v in $(_cbox_config_whitelist); do
        printf '%s=%q\n' "$v" "${!v-}"
      done
      _cbox_config_preserve_extra_lines "$conf"
    } > "$tmp"
    cur_sha="$(sha256sum "$conf" | awk '{print $1}')"
    if [ "$cur_sha" != "$loaded_sha" ]; then
      rm -f "$tmp"
      echo "cbox: refusing - global cbox.conf changed on disk since load (concurrent writer race) - re-run config set" >&2
      exit 1
    fi
    chmod 0644 "$tmp"
    mv "$tmp" "$conf"
    . "$conf"
    export CBOX_LOCAL_MODEL CBOX_LOCAL_MODEL_URL CBOX_LOCAL_MODEL_NAME
    export CBOX_HERMES CBOX_HERMES_VERSION CBOX_HERMES_PROVIDER CBOX_HERMES_MODEL_URL CBOX_HERMES_MODEL_NAME
    _cbox_config_regen_global
  ) || rc=$?

  if [ "$rc" -ne 0 ]; then
    cp "$backup" "$conf"
    exec 6>&-
    echo "cbox: config set failed - previous global cbox.conf restored (kept at $backup)" >&2
    return 1
  fi

  local touched
  touched="$(_cbox_config_touched_sections CBOX_CONFIG_KEYS)"
  local -a touched_arr=()
  read -r -a touched_arr <<< "$touched"
  if [ "${#touched_arr[@]}" -gt 0 ]; then
    _cbox_config_write_pending "$INSTALL_DIR" "${touched_arr[@]}"
    _cbox_config_print_report "${touched_arr[@]}"
  fi

  echo "cbox: previous global cbox.conf kept at $backup"
  exec 6>&-
  return 0
}

_cbox_config_pending_file() {
  local mode root eff
  mode="$(_cbox_effective_mode)"
  case "$mode" in
    isolated)
      root="$(_cbox_workspace_root)" || die "refusing to operate in $PWD (home, /, or a mount root)"
      eff="$HOME/.config/cbox/projects/$(_cbox_path_hash "$root")"
      printf '%s/pending.apply' "$eff"
      ;;
    global)
      printf '%s/pending.apply' "$INSTALL_DIR"
      ;;
    *)
      die_no_conf
      ;;
  esac
}

_cbox_config_pending() {
  local pf
  pf="$(_cbox_config_pending_file)" || return 1
  case "${1:-}" in
    --clear)
      rm -f "$pf"
      echo "cbox: pending apply info cleared"
      return 0
      ;;
  esac
  if [ -f "$pf" ] && [ -s "$pf" ]; then
    cat "$pf"
  else
    echo "none"
  fi
}

config_cmd() {
  local sub="${1:-}"
  case "$sub" in
    get)
      shift
      _cbox_config_get "$@"
      ;;
    set)
      shift
      _cbox_config_set "$@"
      ;;
    pending)
      shift
      _cbox_config_pending "$@"
      ;;
    *)
      echo "cbox: usage: $0 config {get [KEY|--section NAME|--all]|set KEY=VALUE...|pending [--clear]}" >&2
      return 1
      ;;
  esac
}

_hub_engine_names() {
  local reg="$INSTALL_DIR/etc/engines/engines.json"
  local py="$INSTALL_DIR/etc/engines/engines_registry.py"
  local names="" n enabled_var enabled_val
  [ -f "$reg" ] && [ -f "$py" ] || { printf 'claude\ncodex\n'; return 0; }
  names="$(python3 "$py" names "$reg" 2>/dev/null)" || { printf 'claude\ncodex\n'; return 0; }
  for n in $names; do
    enabled_var="$(python3 "$py" get "$reg" "$n" enabled_var 2>/dev/null)" || enabled_var=""
    case "$enabled_var" in
      ""|null) printf '%s\n' "$n" ;;
      *)
        case "$enabled_var" in
          [A-Za-z_]*[A-Za-z0-9_])
            enabled_val="${!enabled_var:-off}"
            [ "$enabled_val" = on ] && printf '%s\n' "$n"
            ;;
        esac
        ;;
    esac
  done
}

_hub_engine_probe_argv1() {
  local reg="$INSTALL_DIR/etc/engines/engines.json"
  local py="$INSTALL_DIR/etc/engines/engines_registry.py"
  local name="$1" kind
  kind="$(python3 "$py" get "$reg" "$name" probe.kind 2>/dev/null)" || kind=""
  case "$kind" in
    canonical-paths)
      python3 "$py" get "$reg" "$name" probe.argv1 2>/dev/null \
        | python3 -c 'import json,sys; print(json.load(sys.stdin)[0])' 2>/dev/null
      ;;
    *) printf '%s' "$name" ;;
  esac
}

_hub_running_marker() {
  local cid="$1" name="$2" argv1 out
  [ -n "$cid" ] || { printf 'unknown'; return 0; }
  argv1="$(_hub_engine_probe_argv1 "$name")" || argv1="$name"
  [ -n "$argv1" ] || argv1="$name"
  out="$(docker exec "$cid" sh -c '
for p in /proc/[0-9]*/cmdline; do
  [ -e "$p" ] || continue
  a0="$(tr "\0" "\n" < "$p" 2>/dev/null | sed -n 1p)"
  a1="$(tr "\0" "\n" < "$p" 2>/dev/null | sed -n 2p)"
  case "$a0" in
    */entrypoint.sh)
      if [ "$a1" = "$1" ]; then
        d="${p%/cmdline}"
        printf "%s\n" "$d"
        exit 0
      fi
      ;;
    "$1")
      d="${p%/cmdline}"
      printf "%s\n" "$d"
      exit 0
      ;;
  esac
done
exit 1
' sh "$argv1" 2>/dev/null)" || { printf 'unknown'; return 0; }
  [ -n "$out" ] || { printf 'unknown'; return 0; }
  printf 'running'
}

_hub_container_state() {
  local mode="$1" eff="$2" cid state
  if [ "$mode" = global ]; then
    cid="$("${COMPOSE[@]}" ps -q "$SERVICE" 2>/dev/null)" || { printf 'unknown'; return 0; }
  else
    cid="$(_compose_p "$eff" ps -q cbox 2>/dev/null)" || { printf 'unknown'; return 0; }
  fi
  if [ -z "$cid" ]; then
    printf 'down'
    return 0
  fi
  state="$(docker inspect -f '{{.State.StartedAt}}' "$cid" 2>/dev/null)" || { printf 'up (unknown start time)'; return 0; }
  printf 'up (since %s)' "${state:0:19}"
}

_hub_image_freshness() {
  local eff_or_install="$1" want="$2"
  local have=""
  have="$(_cbox_image_hash "$eff_or_install" 2>/dev/null)" || { printf 'unknown'; return 0; }
  if [ "$have" = "$want" ]; then
    printf '%s (fresh)' "${have:0:12}"
  else
    printf '%s (stale)' "${have:0:12}"
  fi
}

_hub_status_line() {
  local mode="$1" eff="$2" cid running_hash state img egress
  state="$(_hub_container_state "$mode" "$eff" 2>/dev/null)" || state=unknown
  if [ "$mode" = global ]; then
    cid="$("${COMPOSE[@]}" ps -q "$SERVICE" 2>/dev/null)" || cid=""
  else
    cid="$(_compose_p "$eff" ps -q cbox 2>/dev/null)" || cid=""
  fi
  running_hash=""
  if [ -n "$cid" ]; then
    running_hash="$(docker inspect -f '{{ index .Config.Labels "cbox.inputs" }}' "$cid" 2>/dev/null)" || running_hash=""
  fi
  if [ -n "$running_hash" ]; then
    img="$(_hub_image_freshness "$eff" "$running_hash" 2>/dev/null)" || img=unknown
  elif [ -n "$cid" ]; then
    img="$(docker inspect -f '{{.Image}}' "$cid" 2>/dev/null | cut -c1-19)" || img=unknown
    [ -n "$img" ] || img=unknown
  else
    img=unknown
  fi
  egress="${CBOX_EGRESS_MODE:-off}"
  printf 'container: %-24s  image: %-16s  egress: %s\n' "$state" "$img" "$egress" >&2
}

_hub_engines_line() {
  local mode="$1" eff="$2" cid name argv1 out=""
  if [ "$mode" = global ]; then
    cid="$("${COMPOSE[@]}" ps -q "$SERVICE" 2>/dev/null)" || cid=""
  else
    cid="$(_compose_p "$eff" ps -q cbox 2>/dev/null)" || cid=""
  fi
  while IFS= read -r name; do
    [ -n "$name" ] || continue
    local mark
    mark="$(_hub_running_marker "$cid" "$name" 2>/dev/null)" || mark=unknown
    case "$mark" in
      running) out="$out $name(running)" ;;
      *) out="$out $name" ;;
    esac
  done < <(_hub_engine_names)
  printf 'engines:%s\n' "$out" >&2
}

_hub_row_running() {
  local mode="$1" eff="$2" name="$3" cid
  if [ "$mode" = global ]; then
    cid="$("${COMPOSE[@]}" ps -q "$SERVICE" 2>/dev/null)" || cid=""
  else
    cid="$(_compose_p "$eff" ps -q cbox 2>/dev/null)" || cid=""
  fi
  [ "$(_hub_running_marker "$cid" "$name" 2>/dev/null)" = running ]
}

_hub_render() {
  local mode="$1" eff="$2" root="$3"
  printf 'cbox - %s   mode: %s\n' "$root" "$mode" >&2
  _hub_status_line "$mode" "$eff"
  _hub_engines_line "$mode" "$eff"
  echo >&2

  local -a names=()
  local n
  while IFS= read -r n; do
    [ -n "$n" ] && names+=("$n")
  done < <(_hub_engine_names)

  HUB_ROWS=()
  local i=1 label end_note=""
  [ "$mode" = global ] && end_note=" (ends hub)"
  for n in "${names[@]}"; do
    if _hub_row_running "$mode" "$eff" "$n"; then
      label="attach - running${end_note}"
    else
      label="start${end_note}"
    fi
    printf '  %d) %-10s [%s]\n' "$i" "$n" "$label" >&2
    HUB_ROWS+=("engine:$n")
    i=$((i + 1))
  done
  if [ "$mode" = global ]; then
    printf '  %d) shell (ends hub)\n' "$i" >&2
  else
    printf '  %d) shell\n' "$i" >&2
  fi
  HUB_ROWS+=("shell")
  i=$((i + 1))
  printf '  %d) logs\n' "$i" >&2
  HUB_ROWS+=("logs")
  i=$((i + 1))
  printf '  %d) doctor\n' "$i" >&2
  HUB_ROWS+=("doctor")
  i=$((i + 1))
  printf '  %d) config\n' "$i" >&2
  HUB_ROWS+=("config")
  i=$((i + 1))
  if [ "$mode" != global ]; then
    printf '  %d) sessions\n' "$i" >&2
    HUB_ROWS+=("sessions")
    i=$((i + 1))
  fi
  printf '  %d) down\n' "$i" >&2
  HUB_ROWS+=("down")
  i=$((i + 1))
  printf '  q) quit\n' >&2
  printf '> ' >&2
}

_hub_dispatch_engine() {
  local mode="$1" name="$2" rc=0
  if [ "$mode" = global ]; then
    echo "cbox: attaching $name in global mode - this ends the hub (exec-replace); start a new 'cbox' for the crossroads again" >&2
  fi
  run "$name" || rc=$?
  return "$rc"
}

_hub_dispatch_shell() {
  local mode="$1" rc=0
  case "$mode" in
    global) shell || rc=$? ;;
    *) shell_isolated || rc=$? ;;
  esac
  return "$rc"
}

_hub_dispatch_logs() {
  local mode="$1" rc=0
  case "$mode" in
    global) logs || rc=$? ;;
    *) logs_isolated || rc=$? ;;
  esac
  return "$rc"
}

_hub_config_submenu() {
  local mode="$1"
  while true; do
    echo "cbox config:" >&2
    echo "  1) show all" >&2
    echo "  2) set one key" >&2
    echo "  3) pending" >&2
    echo "  b) back" >&2
    printf '> ' >&2
    local ans
    IFS= read -r ans || return 0
    case "$ans" in
      1)
        [ -f "$INSTALL_DIR/templates/sections.sh" ] && . "$INSTALL_DIR/templates/sections.sh"
        _cbox_config_get --all 2>&1 | cat 1>&2 || true
        ;;
      2)
        printf 'KEY=VALUE: ' >&2
        local kv
        IFS= read -r kv || continue
        [ -n "$kv" ] || continue
        [ -f "$INSTALL_DIR/templates/sections.sh" ] && . "$INSTALL_DIR/templates/sections.sh"
        _cbox_config_set "$kv" 2>&1 | cat 1>&2 || true
        ;;
      3)
        [ -f "$INSTALL_DIR/templates/sections.sh" ] && . "$INSTALL_DIR/templates/sections.sh"
        _cbox_config_pending 2>&1 | cat 1>&2 || true
        ;;
      b|B) return 0 ;;
      *) echo "cbox: unrecognized choice '$ans'" >&2 ;;
    esac
  done
}

_hub_sessions_render() {
  local root="$1" sid row state active last legs mapped title updated kind i=1
  HUB_SESSION_IDS=()
  while IFS=$'\t' read -r sid state active last legs mapped title updated kind; do
    [ -n "$sid" ] || continue
    printf '  %d) %-24s %-11s %-8s %-24s %s\n' "$i" "$sid" "$kind" "$state" "$mapped" "$title" >&2
    HUB_SESSION_IDS+=("$sid")
    i=$((i + 1))
  done < <(
    while IFS= read -r sid; do
      [ -n "$sid" ] || continue
      _cbox_session_row_summary "$root" "$sid" 2>/dev/null || true
    done < <(_cbox_session_list_ids "$root") | sort -t$'\t' -k8,8r
  )
  [ "${#HUB_SESSION_IDS[@]}" -gt 0 ] || echo "  <no sessions>" >&2
}

_hub_session_pick_id() {
  local answer="$1"
  if _cbox_session_id_valid "$answer"; then
    printf '%s' "$answer"
    return 0
  fi
  case "$answer" in ''|*[!0-9]*) return 1 ;; esac
  [ "$answer" -ge 1 ] && [ "$answer" -le "${#HUB_SESSION_IDS[@]}" ] || return 1
  printf '%s' "${HUB_SESSION_IDS[$((answer - 1))]}"
}

_hub_session_pick_engine() {
  local -a engines=()
  local name answer i=1
  while IFS= read -r name; do
    [ -n "$name" ] || continue
    engines+=("$name")
    printf '  %d) %s\n' "$i" "$name" >&2
    i=$((i + 1))
  done < <(_hub_engine_names)
  printf 'engine: ' >&2
  IFS= read -r answer || return 1
  case "$answer" in ''|*[!0-9]*) return 1 ;; esac
  [ "$answer" -ge 1 ] && [ "$answer" -le "${#engines[@]}" ] || return 1
  printf '%s' "${engines[$((answer - 1))]}"
}

_hub_sessions_submenu() {
  local root
  root="$(_cbox_workspace_root 2>/dev/null)" || { echo "cbox: sessions unavailable outside a workspace root" >&2; return 0; }
  echo "cbox: syncing project-native sessions..." >&2
  _cbox_session_sync_native 2>&1 | cat 1>&2 || echo "cbox: session sync unavailable; showing the durable index" >&2
  while true; do
    echo "cbox sessions for $root:" >&2
    _hub_sessions_render "$root"
    echo "  c) continue a session" >&2
    echo "  n) new shared session" >&2
    echo "  s) sync/import native sessions" >&2
    echo "  x) close a session" >&2
    echo "  b) back" >&2
    printf '> ' >&2
    local ans
    IFS= read -r ans || return 0
    case "$ans" in
      c|C)
        printf 'session number or id: ' >&2
        local choice sid engine rc=0
        IFS= read -r choice || continue
        sid="$(_hub_session_pick_id "$choice")" || { echo "cbox: invalid session selection" >&2; continue; }
        engine="$(_hub_session_pick_engine)" || { echo "cbox: invalid engine selection" >&2; continue; }
        trap - INT
        _cbox_session_run_leg "$sid" "$engine" || { rc=$?; echo "cbox: session leg exited non-zero ($rc)" >&2; }
        trap '_hub_on_int' INT
        ;;
      n|N)
        local sid engine
        sid="$(_cbox_session_cmd_new)" || continue
        echo "cbox: new session $sid" >&2
        engine="$(_hub_session_pick_engine)" || { echo "cbox: invalid engine selection" >&2; continue; }
        trap - INT
        _cbox_session_run_leg "$sid" "$engine" || echo "cbox: session leg exited non-zero" >&2
        trap '_hub_on_int' INT
        ;;
      s|S)
        _cbox_session_sync_native 2>&1 | cat 1>&2 || true
        ;;
      x|X)
        printf 'session id to close: ' >&2
        local csid
        IFS= read -r csid || continue
        [ -n "$csid" ] || continue
        _cbox_session_id_valid "$csid" || { echo "cbox: refusing - invalid session id '$csid'" >&2; continue; }
        _cbox_session_cmd_close "$csid" 2>&1 | cat 1>&2 || true
        ;;
      b|B) return 0 ;;
      *) echo "cbox: unrecognized choice '$ans'" >&2 ;;
    esac
  done
}

_hub_dispatch_down() {
  local mode="$1" rc=0
  case "$mode" in
    global) down 0 || rc=$? ;;
    *) down_project 0 || rc=$? ;;
  esac
  if [ "$rc" -ne 0 ]; then
    printf 'cbox: down refused - type FORCE to stop anyway, anything else to cancel: ' >&2
    local ans
    IFS= read -r ans || ans=""
    if [ "$ans" = FORCE ]; then
      case "$mode" in
        global) down 1 || rc=$? ;;
        *) down_project 1 || rc=$? ;;
      esac
    fi
  fi
  return "$rc"
}

_hub_loop_int_count=0

_hub_on_int() {
  _hub_loop_int_count=$((_hub_loop_int_count + 1))
  if [ "$_hub_loop_int_count" -ge 2 ]; then
    echo >&2
    echo "cbox: interrupted twice - quitting" >&2
    _hub_stty_restore
    exit 130
  fi
  echo >&2
  echo "cbox: press q then Enter to quit, or Ctrl-C again to force quit" >&2
}

_hub_dispatch_row() {
  local mode="$1" row="$2" rc=0
  case "$row" in
    engine:*)
      local ename="${row#engine:}"
      trap - INT
      _hub_dispatch_engine "$mode" "$ename" || { rc=$?; echo "cbox: $ename exited non-zero ($rc)" >&2; }
      trap '_hub_on_int' INT
      ;;
    shell)
      trap - INT
      _hub_dispatch_shell "$mode" || { rc=$?; echo "cbox: shell exited non-zero ($rc)" >&2; }
      trap '_hub_on_int' INT
      ;;
    logs)
      trap - INT
      _hub_dispatch_logs "$mode" || { rc=$?; echo "cbox: logs exited non-zero ($rc)" >&2; }
      trap '_hub_on_int' INT
      ;;
    doctor) doctor || { rc=$?; echo "cbox: doctor exited non-zero ($rc)" >&2; } ;;
    config) _hub_config_submenu "$mode" || true ;;
    sessions) _hub_sessions_submenu || true ;;
    down) _hub_dispatch_down "$mode" || echo "cbox: down did not proceed" >&2 ;;
    *) echo "cbox: internal error - unknown row '$row'" >&2 ;;
  esac
  _hub_loop_int_count=0
  return 0
}

_hub_stty_saved=""

_hub_stty_restore() {
  if [ -n "$_hub_stty_saved" ]; then
    stty "$_hub_stty_saved" 2>/dev/null || stty sane 2>/dev/null || true
  else
    stty sane 2>/dev/null || true
  fi
}

_hub_loop() {
  local mode="$1" eff="$2" root="$3"
  _hub_stty_saved="$(stty -g 2>/dev/null)" || _hub_stty_saved=""
  trap '_hub_on_int' INT
  while true; do
    _hub_loop_int_count=0
    _hub_render "$mode" "$eff" "$root"
    local ans
    if ! IFS= read -r ans; then
      echo >&2
      echo "cbox: EOF - quitting" >&2
      _hub_stty_restore
      trap - INT
      return 0
    fi
    case "$ans" in
      q|Q)
        _hub_stty_restore
        trap - INT
        return 0
        ;;
      *[!0-9]*|'')
        echo "cbox: unrecognized selection '$ans'" >&2
        ;;
      *)
        if [ "$ans" -ge 1 ] && [ "$ans" -le "${#HUB_ROWS[@]}" ]; then
          _hub_dispatch_row "$mode" "${HUB_ROWS[$((ans - 1))]}"
        else
          echo "cbox: unrecognized selection '$ans'" >&2
        fi
        ;;
    esac
    _hub_stty_restore
  done
}

hub() {
  local mode root eff
  mode="$(_cbox_effective_mode)"
  case "$mode" in
    global)
      root="$PWD"
      eff="$INSTALL_DIR"
      _hub_loop global "$INSTALL_DIR" "$root"
      return 0
      ;;
    isolated)
      if root="$(_cbox_workspace_root)"; then
        eff="$HOME/.config/cbox/projects/$(_cbox_path_hash "$root")"
        if [ ! -f "$eff/cbox.conf" ]; then
          _first_run_init "$root" "$eff" || return 1
        fi
        . "$eff/cbox.conf"
        _hub_loop isolated "$eff" "$root"
        return 0
      fi
      usage
      ;;
    *)
      usage
      ;;
  esac
}

usage() {
  echo "usage: $0 {run [--session <id>] <bin> [args]|session {list|new|close <id>|show <id>}|ai <analyse|plan|full> [claude|codex|auto] [--host|--container] [-p <prompt>|-] [--model M] [--effort E] [--dry-run]|up [--gpu]|down [--force]|restart [--gpu]|shell|logs [args]|update|reinstall-bins [--fresh|--if-stale]|install-hooks|continuity migrate|verify [--gpu|--isolated]|doctor|config {get|set|pending}|backup|login [oauth-url]|login-codex|gc|net-refresh|ls|images [list|rm <hash>]}"
  echo "cbox: with zero arguments and a TTY on stdin+stdout, bare '$0' opens the interactive hub instead of this usage text"
  echo "cbox: 'cbox ls' lists RUNNING isolated projects only, not every configured project"
  exit 1
}

case "${1:-}" in
  run) shift; run "$@";;
  session) shift; _cbox_session_cmd "$@";;
  ai) shift; ai "$@";;
  up) shift; up "$@";;
  down)
    shift
    _down_force=0
    if [ "${1:-}" = "--force" ]; then _down_force=1; shift; fi
    case "$(_cbox_effective_mode)" in
      isolated) down_project "$_down_force";;
      global) down "$_down_force";;
      *) die_no_conf;;
    esac
    ;;
  restart) shift; restart "$@";;
  shell)
    case "$(_cbox_effective_mode)" in
      isolated) shell_isolated;;
      global) shell;;
      *) die_no_conf;;
    esac
    ;;
  logs)
    shift
    case "$(_cbox_effective_mode)" in
      isolated) logs_isolated "$@";;
      global) logs "$@";;
      *) die_no_conf;;
    esac
    ;;
  update) shift; reinstall_bins "$@";;
  reinstall-bins) shift; reinstall_bins "$@";;
  install-hooks) install_hooks;;
  continuity)
    shift
    case "${1:-}" in
      migrate) continuity_migrate;;
      *) usage;;
    esac
    ;;
  verify)
    shift
    if [ "${1:-}" = "--isolated" ]; then
      shift
      verify_isolated "$@"
    else
      case "$(_cbox_effective_mode)" in
        isolated) verify_isolated "$@";;
        global) verify "$@";;
        *) die_no_conf;;
      esac
    fi
    ;;
  doctor) shift; doctor "$@";;
  config)
    shift
    [ -f "$INSTALL_DIR/templates/sections.sh" ] || die "$INSTALL_DIR/templates/sections.sh missing"
    . "$INSTALL_DIR/templates/sections.sh"
    config_cmd "$@"
    ;;
  backup) backup;;
  login) shift; login_claude "$@";;
  login-codex) login_codex;;
  gc) gc;;
  net-refresh) net_refresh;;
  ls) ls_projects;;
  images) shift; images_cmd "$@";;
  *)
    if [ $# -eq 0 ] && [ -t 0 ] && [ -t 1 ]; then
      hub
    else
      usage
    fi
    ;;
esac
