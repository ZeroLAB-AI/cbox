install_hooks() {
  require_global_conf
  [ -t 0 ] || { echo "cbox: install-hooks requires a TTY"; return 1; }
  local files=(codex_mode_guard.py agent_label_guard.py code_hygiene_guard.py commit_guard.py orchestrator-global.txt codex_scope.container.json ask_claude_mcp.py continuity_commit_log.py continuity_ledger_sweep.py continuity_session_digest.py)
  local srcs=(
    "$INSTALL_DIR/etc/hooks/codex_mode_guard.py"
    "$INSTALL_DIR/etc/hooks/agent_label_guard.py"
    "$INSTALL_DIR/etc/hooks/code_hygiene_guard.py"
    "$INSTALL_DIR/etc/hooks/commit_guard.py"
    "$INSTALL_DIR/etc/hooks/orchestrator-global.txt"
    "$INSTALL_DIR/generated/hooks/codex_scope.container.json"
    "$INSTALL_DIR/etc/codex/ask_claude_mcp.py"
    "$INSTALL_DIR/etc/hooks/continuity_commit_log.py"
    "$INSTALL_DIR/etc/hooks/continuity_ledger_sweep.py"
    "$INSTALL_DIR/etc/hooks/continuity_session_digest.py"
  )
  local s f i stage target ans changed=0
  for s in "${srcs[@]}"; do
    [ -f "$s" ] || { echo "cbox: $s missing - run ./setup.sh first"; return 1; }
  done
  stage="$(mktemp -d)"
  trap 'rm -rf "$stage"' RETURN
  for i in "${!files[@]}"; do
    cp "${srcs[$i]}" "$stage/${files[$i]}"
  done
  if [ "${CBOX_CLAUDE_MODE:-mount}" = mount ]; then
    target="${CBOX_CLAUDE_PATH:-$HOME/.claude}/hooks"
    mkdir -p "$target"
    for f in "${files[@]}"; do
      if cmp -s "$stage/$f" "$target/$f" 2>/dev/null; then
        echo "cbox: $f unchanged"
        continue
      fi
      echo "== $f: $target/$f vs staged =="
      if [ -f "$target/$f" ]; then
        diff -u "$target/$f" "$stage/$f" || true
      else
        echo "(new file)"
        sed 's/^/+ /' "$stage/$f"
      fi
      changed=1
    done
    if [ "$changed" = 0 ]; then
      echo "cbox: install-hooks: nothing to do"
      return 0
    fi
    read -r -p "Install the changes above into $target? [y/N] " ans
    case "$ans" in
      y|Y) ;;
      *) echo "cbox: install-hooks: cancelled"; return 1;;
    esac
    for f in "${files[@]}"; do
      install -m 0644 "$stage/$f" "$target/$f"
    done
  else
    target="$INSTALL_DIR/generated/hooks"
    mkdir -p "$target"
    for f in "${files[@]}"; do
      if cmp -s "$stage/$f" "$target/$f" 2>/dev/null; then
        echo "cbox: $f unchanged"
      else
        install -m 0644 "$stage/$f" "$target/$f"
        echo "cbox: $f updated"
      fi
    done
  fi
  echo "cbox: install-hooks: done - apply with: $0 restart"
}

backup() {
  require_global_conf
  local ts v vols=()
  if [ "${CBOX_CLAUDE_MODE:-mount}" = volume ]; then vols+=("${CBOX_NAME:-cbox}-claude"); fi
  if [ "${CBOX_CODEX_MODE:-mount}" = volume ]; then vols+=("${CBOX_NAME:-cbox}-codex"); fi
  if [ "${CBOX_VENV_MODE:-none}" = volume ]; then vols+=("${CBOX_NAME:-cbox}-venv"); fi
  case "${CBOX_SSH_MODE:-none}" in
    container-keys|mixed) vols+=("${CBOX_NAME:-cbox}-ssh");;
  esac
  ts="$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$INSTALL_DIR/backups"
  for v in "${vols[@]}"; do
    if ! docker volume inspect "$v" >/dev/null 2>&1; then
      echo "cbox: volume $v not found - skipped"
      continue
    fi
    docker run --rm -v "$v:/src:ro" -v "$INSTALL_DIR/backups:/out" ubuntu:24.04 tar czf "/out/$v-$ts.tar.gz" -C /src .
    du -h "$INSTALL_DIR/backups/$v-$ts.tar.gz"
  done
}

login_codex() {
  require_global_conf
  if [ "${CBOX_EGRESS_MODE:-off}" = off ]; then
    echo "cbox: egress mode is off - the login bridge is only needed with egress enabled; run 'codex login' inside '$0 shell'"
    return 0
  fi
  command -v socat >/dev/null 2>&1 || { echo "cbox: socat not found on host - install it first (e.g. apt install socat)"; return 1; }
  echo "cbox: forwarding host 127.0.0.1:1455 into the container"
  echo "cbox: run 'codex login' inside '$0 shell' and open the printed URL in a browser on this host"
  echo "cbox: press Ctrl-C to stop the bridge"
  trap 'echo; echo "cbox: login bridge stopped"; exit 0' INT
  local -a inner=(docker compose -f "$INSTALL_DIR/docker-compose.yml" exec -T "$SERVICE" socat - TCP:127.0.0.1:1455)
  local inner_q exec_addr
  printf -v inner_q '%q ' "${inner[@]}"
  inner_q="${inner_q% }"
  printf -v exec_addr 'EXEC:%q' "$inner_q"
  socat TCP-LISTEN:1455,bind=127.0.0.1,reuseaddr,fork "$exec_addr"
}

VN=0
VOK=0
VFAIL=0
VSKIP=0

v_t() {
  VN=$((VN + 1))
  printf '[%d] %s: ' "$VN" "$1"
}

v_ok() {
  VOK=$((VOK + 1))
  if [ -n "${1:-}" ]; then echo "OK ($1)"; else echo "OK"; fi
}

v_fail() {
  VFAIL=$((VFAIL + 1))
  if [ -n "${1:-}" ]; then echo "FAIL ($1)"; else echo "FAIL"; fi
}

v_skip() {
  VSKIP=$((VSKIP + 1))
  if [ -n "${1:-}" ]; then echo "SKIP ($1)"; else echo "SKIP"; fi
}

verify() {
  require_global_conf
  local gpu=0
  if [ "${1:-}" = "--gpu" ]; then gpu=1; fi
  local X=("${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh)
  local workspaces=()
  read -r -a workspaces <<< "${CBOX_WORKSPACES:-}"
  local w v got want rc ref payload gitws
  echo "== cbox verify =="

  v_t "uid/gid match"
  got="$("${X[@]}" sh -c 'echo "$(id -u):$(id -g)"' 2>/dev/null)" || got=""
  if _cbox_is_rootless_docker; then
    want="0:0"
  else
    want="$(id -u):$(id -g)"
  fi
  if [ "$got" = "$want" ]; then v_ok "$got"; else v_fail "container ${got:-unknown}, expected $want"; fi

  for w in "${workspaces[@]}"; do
    v_t "workspace writable $w"
    if "${X[@]}" sh -c 'touch "$1/.cbox-verify" && rm "$1/.cbox-verify"' sh "$w" >/dev/null 2>&1; then v_ok; else v_fail; fi
  done

  for w in "${workspaces[@]}"; do
    v_t "workspace is a git work-tree $w"
    if "${X[@]}" sh -c 'git -C "$1" rev-parse --is-inside-work-tree' sh "$w" >/dev/null 2>&1; then
      v_ok
    else
      v_fail "no git history - run git init in $w"
    fi
  done

  if [ "${CBOX_VENV_MODE:-none}" = host ]; then
    v_t "venv mount read-only ${CBOX_VENV_PATH:-}"
    if "${X[@]}" sh -c 'touch "$1/.cbox-verify"' sh "${CBOX_VENV_PATH:-}" >/dev/null 2>&1; then
      v_fail "writable"
    else
      v_ok "write denied"
    fi
  fi

  v_t "claude --version"
  if v="$("${X[@]}" claude --version 2>&1)"; then v_ok "$v"; else v_fail "$v"; fi

  v_t "codex --version"
  if v="$("${X[@]}" codex --version 2>&1)"; then v_ok "$v"; else v_fail "$v"; fi

  v_t "binaries from volumes"
  if "${X[@]}" sh -c 'test "$(command -v claude)" = "$HOME/.local/bin/claude" && test "$(command -v codex)" = "$HOME/.local/bin/codex" && case "$(readlink -f "$HOME/.local/bin/codex")" in "$HOME/.codex/packages/"*) exit 0;; *) exit 1;; esac' >/dev/null 2>&1; then
    v_ok
  else
    v_fail "claude/codex not from ~/.local/bin or codex does not resolve under ~/.codex/packages"
  fi

  v_t "claude bins mount read-only (write denied)"
  if "${X[@]}" sh -c 'touch "$HOME/.local/.cbox-verify"' >/dev/null 2>&1; then
    v_fail "writable"
  else
    v_ok "write denied"
  fi

  v_t "codex bins mount read-only (write denied)"
  if "${X[@]}" sh -c 'touch "$HOME/.codex/packages/.cbox-verify"' >/dev/null 2>&1; then
    v_fail "writable"
  else
    v_ok "write denied"
  fi

  v_t "claude stamp present and want matches pin"
  want="${CBOX_CLAUDE_TARGET:-stable}"
  if got="$("${X[@]}" sh -c 'sed -n 1p "$HOME/.local/.cbox-stamp"' 2>/dev/null)" && [ "$got" = "$want" ]; then
    v_ok "$got"
  else
    v_fail "stamp missing or want '${got:-}' != pin '$want'"
  fi

  v_t "codex stamp present and want matches pin"
  want="${CBOX_CODEX_VERSION:-latest}|${CBOX_CODEX_TARGET:-}"
  if got="$("${X[@]}" sh -c 'sed -n 1p "$HOME/.codex/packages/.cbox-stamp"' 2>/dev/null)" && [ "$got" = "$want" ]; then
    v_ok "$got"
  else
    v_fail "stamp missing or want '${got:-}' != pin '$want'"
  fi

  v_t "claude resolved binary executable and matches stamp"
  if "${X[@]}" sh -c '
p="$(sed -n 2p "$HOME/.local/.cbox-stamp")"
v="$(sed -n 4p "$HOME/.local/.cbox-stamp")"
test -n "$p" && test -x "$p" || exit 1
case "$("$p" --version 2>&1)" in *"$v"*) exit 0;; *) exit 1;; esac
' >/dev/null 2>&1; then
    v_ok
  else
    v_fail "resolved binary missing, not executable, or --version does not match stamp"
  fi

  v_t "codex resolved binary executable and matches stamp"
  if "${X[@]}" sh -c '
p="$(sed -n 2p "$HOME/.codex/packages/.cbox-stamp")"
v="$(sed -n 4p "$HOME/.codex/packages/.cbox-stamp")"
test -n "$p" && test -x "$p" || exit 1
case "$("$p" --version 2>&1)" in *"$v"*) exit 0;; *) exit 1;; esac
' >/dev/null 2>&1; then
    v_ok
  else
    v_fail "resolved binary missing, not executable, or --version does not match stamp"
  fi

  v_t "guard read-only (append denied)"
  if "${X[@]}" sh -c 'echo x >> "$HOME/.claude/hooks/codex_mode_guard.py"' >/dev/null 2>&1; then
    v_fail "writable"
  else
    v_ok "write denied"
  fi

  v_t "guard read-only (rm denied)"
  if "${X[@]}" sh -c 'rm "$HOME/.claude/hooks/codex_mode_guard.py"' >/dev/null 2>&1; then
    v_fail "removable"
  else
    v_ok "remove denied"
  fi

  v_t "guard wired in settings.json"
  if "${X[@]}" sh -c 'p="$(jq -r ".hooks.PreToolUse[] | select(.matcher==\"mcp__codex-.*\") | .hooks[0].command" "$HOME/.claude/settings.json" | grep -oE "/[^ ]+codex_mode_guard\.py" | head -n 1)"; test -n "$p" && test -f "$p"' >/dev/null 2>&1; then
    v_ok
  else
    v_fail
  fi

  if [ "${CBOX_CLAUDE_MODE:-mount}" = mount ]; then
    ref="${CBOX_CLAUDE_PATH:-$HOME/.claude}/hooks/codex_mode_guard.py"
  else
    ref="$INSTALL_DIR/generated/hooks/codex_mode_guard.py"
  fi
  v_t "guard in sync with $ref"
  if [ ! -f "$ref" ]; then
    v_fail "reference file missing"
  elif "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'cmp -s - "$HOME/.claude/hooks/codex_mode_guard.py"' < "$ref" >/dev/null 2>&1; then
    v_ok
  else
    v_fail "drift - run $0 install-hooks"
  fi

  if [ "${CBOX_CLAUDE_MODE:-mount}" = mount ]; then
    ref="${CBOX_CLAUDE_PATH:-$HOME/.claude}/settings.json"
  else
    ref="$INSTALL_DIR/generated/settings.json"
  fi
  v_t "settings.json in sync with $ref"
  if [ ! -f "$ref" ]; then
    v_fail "reference file missing"
  elif "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'cmp -s - "$HOME/.claude/settings.json"' < "$ref" >/dev/null 2>&1; then
    v_ok
  else
    v_fail "drift - run $0 install-hooks"
  fi

  v_t "CLAUDE.md read-only (append denied)"
  if "${X[@]}" sh -c 'echo x >> "$HOME/.claude/CLAUDE.md"' >/dev/null 2>&1; then
    v_fail "writable"
  else
    v_ok "write denied"
  fi

  v_t "CLAUDE.md read-only (rm denied)"
  if "${X[@]}" sh -c 'rm "$HOME/.claude/CLAUDE.md"' >/dev/null 2>&1; then
    v_fail "removable"
  else
    v_ok "remove denied"
  fi

  v_t "agents dir read-only (create denied)"
  if "${X[@]}" sh -c 'touch "$HOME/.claude/agents/.cbox-verify"' >/dev/null 2>&1; then
    v_fail "writable"
  else
    v_ok "write denied"
  fi

  v_t "agents dir read-only (rm denied)"
  if "${X[@]}" sh -c 'rm -rf "$HOME/.claude/agents"' >/dev/null 2>&1; then
    v_fail "removable"
  else
    v_ok "remove denied"
  fi

  if [ "${CBOX_HISTORY:-1}" = 1 ]; then
    v_t "agents and policies populated"
    if "${X[@]}" sh -c '[ -n "$(ls -A "$HOME/.claude/agents" 2>/dev/null)" ] && [ -n "$(ls -A "$HOME/.claude/policies" 2>/dev/null)" ]' >/dev/null 2>&1; then
      v_ok
    else
      v_fail "empty - run ./setup.sh update agents / update claude-md"
    fi

    v_t "CLAUDE.md imports resolve"
    if "${X[@]}" sh -c 'ok=1; while IFS= read -r l; do case "$l" in "@~/"*) p="$HOME/${l#@~/}"; [ -f "$p" ] || ok=0;; esac; done < "$HOME/.claude/CLAUDE.md"; [ "$ok" = 1 ]' >/dev/null 2>&1; then
      v_ok
    else
      v_fail "missing policy file for an @import line"
    fi
  fi

  if [ "${CBOX_CLAUDE_MODE:-mount}" = mount ]; then
    v_t "host sessions readable"
    if "${X[@]}" sh -c 'test -d "$HOME/.claude/projects" && ls "$HOME/.claude/projects" >/dev/null' >/dev/null 2>&1; then
      v_ok
    else
      v_fail
    fi
  fi

  gitws=""
  for w in "${workspaces[@]}" "${CBOX_WORKDIR:-}"; do
    [ -n "$w" ] || continue
    if git -C "$w" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      gitws="$w"
      break
    fi
  done
  v_t "guard allows danger-full-access in scope"
  if [ -z "$gitws" ]; then
    v_skip "no git work-tree among workspaces"
  else
    printf -v payload '{"tool_name":"mcp__codex-terra__codex","permission_mode":"auto","tool_input":{"cwd":"%s","sandbox":"danger-full-access","approval-policy":"never"}}' "$gitws"
    rc=0
    printf '%s' "$payload" | "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'CODEX_GUARD_CONFIG="$HOME/.claude/hooks/codex_scope.container.json" python3 "$HOME/.claude/hooks/codex_mode_guard.py"' >/dev/null 2>&1 || rc=$?
    if [ "$rc" -eq 0 ]; then v_ok "$gitws"; else v_fail "exit $rc"; fi
  fi

  v_t "guard denies out-of-scope cwd (git gate)"
  payload='{"tool_name":"mcp__codex-terra__codex","permission_mode":"bypassPermissions","tool_input":{"cwd":"/etc","sandbox":"danger-full-access","approval-policy":"never"}}'
  rc=0
  printf '%s' "$payload" | "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'CODEX_GUARD_CONFIG="$HOME/.claude/hooks/codex_scope.container.json" python3 "$HOME/.claude/hooks/codex_mode_guard.py"' >/dev/null 2>&1 || rc=$?
  if [ "$rc" -eq 2 ]; then v_ok; else v_fail "exit $rc, expected 2"; fi

  v_t "ask-claude wrapper present and read-only"
  if "${X[@]}" sh -c 'test -f "$HOME/.claude/hooks/ask_claude_mcp.py" && ! { echo x >> "$HOME/.claude/hooks/ask_claude_mcp.py"; } 2>/dev/null' >/dev/null 2>&1; then
    v_ok
  else
    v_fail "missing or writable"
  fi

  v_t "ask-claude mcp protocol roundtrip"
  payload='{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-03-26","capabilities":{},"clientInfo":{"name":"verify","version":"0"}}}
{"jsonrpc":"2.0","method":"notifications/initialized"}
{"jsonrpc":"2.0","id":2,"method":"tools/list"}'
  if printf '%s\n' "$payload" | "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'python3 "$HOME/.claude/hooks/ask_claude_mcp.py"' 2>/dev/null | grep -q '"ask-claude"'; then
    v_ok
  else
    v_fail "tools/list did not report ask-claude"
  fi

  v_t "ask-claude depth guard refuses nested calls"
  payload='{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-03-26","capabilities":{},"clientInfo":{"name":"verify","version":"0"}}}
{"jsonrpc":"2.0","method":"notifications/initialized"}
{"jsonrpc":"2.0","id":2,"method":"tools/call","params":{"name":"ask-claude","arguments":{"prompt":"ping"}}}'
  if printf '%s\n' "$payload" | "${COMPOSE[@]}" exec -T "$SERVICE" /entrypoint.sh sh -c 'CBOX_MCP_DEPTH=1 python3 "$HOME/.claude/hooks/ask_claude_mcp.py"' 2>/dev/null | grep -q 'depth limit'; then
    v_ok
  else
    v_fail "nested call was not refused"
  fi

  if [ "${CBOX_CODEX_MCP:-0}" = 1 ]; then
    v_t "codex-mcp wired in config.toml"
    if "${X[@]}" sh -c 'grep -q "^\[mcp_servers\.claude\]" "$HOME/.codex/config.toml"' >/dev/null 2>&1; then
      v_ok
    else
      v_fail "run ./setup.sh update codex-mcp"
    fi
  fi

  if [ "${CBOX_EGRESS_MODE:-off}" != off ] && [ "${CBOX_EGRESS_APPLIED:-0}" != 1 ]; then
    v_t "egress topology"
    v_skip "configured but not applied - run ./setup.sh update egress"
  elif [ "${CBOX_EGRESS_MODE:-off}" != off ]; then
    v_t "egress proxy allows api.anthropic.com"
    if "${X[@]}" curl -s -o /dev/null --connect-timeout 10 -x http://proxy:8888 https://api.anthropic.com >/dev/null 2>&1; then
      v_ok
    else
      v_fail
    fi

    v_t "egress proxy denies example.com"
    if "${X[@]}" curl -s -o /dev/null --connect-timeout 10 -x http://proxy:8888 https://example.com >/dev/null 2>&1; then
      v_fail "reachable through proxy"
    else
      v_ok "denied"
    fi

    v_t "direct egress bypass fails"
    if "${X[@]}" curl -s -o /dev/null --noproxy "*" --connect-timeout 3 https://api.anthropic.com >/dev/null 2>&1; then
      v_fail "direct connection succeeded"
    else
      v_ok "blocked"
    fi

    v_t "proxy service running"
    if [ -n "$("${COMPOSE[@]}" ps -q --status running proxy 2>/dev/null)" ]; then v_ok; else v_fail; fi
  fi

  case "${CBOX_SSH_MODE:-none}" in
    none)
      v_t "ssh isolation (~/.ssh absent)"
      if "${X[@]}" sh -c 'test -e "$HOME/.ssh"' >/dev/null 2>&1; then v_fail "exists"; else v_ok; fi
      ;;
    host-agent)
      v_t "ssh agent socket present"
      if "${X[@]}" sh -c 'test -S /run/cbox-ssh/agent.sock' >/dev/null 2>&1; then v_ok; else v_fail; fi
      v_t "no private key files in ~/.ssh"
      if "${X[@]}" sh -c 'ls "$HOME/.ssh"/id_* >/dev/null 2>&1' >/dev/null 2>&1; then v_fail "key files present"; else v_ok; fi
      ;;
    container-keys)
      v_t "~/.ssh owned by user"
      if "${X[@]}" sh -c 'test -d "$HOME/.ssh" && test "$(stat -c %u "$HOME/.ssh")" = "$(id -u)"' >/dev/null 2>&1; then v_ok; else v_fail; fi
      ;;
    mixed)
      v_t "ssh agent socket present"
      if "${X[@]}" sh -c 'test -S /run/cbox-ssh/agent.sock' >/dev/null 2>&1; then v_ok; else v_fail; fi
      v_t "~/.ssh owned by user"
      if "${X[@]}" sh -c 'test -d "$HOME/.ssh" && test "$(stat -c %u "$HOME/.ssh")" = "$(id -u)"' >/dev/null 2>&1; then v_ok; else v_fail; fi
      ;;
  esac

  if [ "$gpu" = 1 ]; then
    v_t "nvidia-smi in container"
    if "${X[@]}" nvidia-smi -L >/dev/null 2>&1; then v_ok; else v_fail; fi
  fi

  echo "== cbox verify: $VN tests, $VOK ok, $VFAIL failed, $VSKIP skipped =="
  [ "$VFAIL" -eq 0 ] || exit 1
}

_cbox_verify_v13_restore() {
  [ "${v13_restored:-1}" = 0 ] || return 0
  v13_restored=1
  if [ "$v13_had_cache" = 1 ]; then
    printf '%s\n' "$v13_saved" > "$v13_cache"
  else
    rm -f "$v13_cache"
  fi
  rm -f "$v13_cache.verify"
}

_cbox_verify_v13_digest_bump() {
  local eff="$1" root="$2"
  local v13_cache="$HOME/.config/cbox/base-digest.cache"
  local v13_saved="" v13_had_cache=0 v13_restored=0
  local fake_digest tag_before tag_after
  if [ -f "$v13_cache" ]; then
    v13_saved="$(cat "$v13_cache")"
    v13_had_cache=1
  fi
  trap '_cbox_verify_v13_restore' RETURN
  fake_digest="sha256:$(printf 'cbox-verify-fake-%s' "$$" | sha256sum | awk '{print $1}')"
  tag_before="$(_cbox_image_tag "$(_cbox_image_hash "$eff")")"
  {
    if [ -n "$v13_saved" ]; then
      printf '%s\n' "$v13_saved" | grep -v '^ubuntu:24.04|' || true
    fi
    printf 'ubuntu:24.04|%s|%s\n' "$fake_digest" "$(date +%s)"
  } > "$v13_cache.verify" 2>/dev/null
  if [ ! -s "$v13_cache.verify" ]; then
    v_skip "could not stage cache poke"
    return 0
  fi
  mv "$v13_cache.verify" "$v13_cache"
  ( . "$eff/cbox.conf" 2>/dev/null; _gen_effective "$eff" "$root" ) >/dev/null 2>&1 || true
  tag_after="$(_cbox_image_tag "$(_cbox_image_hash "$eff")")"
  _cbox_verify_v13_restore
  ( . "$eff/cbox.conf" 2>/dev/null; _gen_effective "$eff" "$root" ) >/dev/null 2>&1 || true
  if [ "$tag_before" != "$tag_after" ]; then
    v_ok "$tag_before -> $tag_after"
  else
    v_fail "tag unchanged after digest bump"
  fi
}

verify_isolated() {
  echo "== cbox verify (isolated) =="
  local root P eff cid n rc
  if ! root="$(_cbox_workspace_root)"; then
    v_t "isolated project resolvable from cwd"
    v_skip "cwd is home, /, or a mount root"
    echo "== cbox verify: $VN tests, $VOK ok, $VFAIL failed, $VSKIP skipped =="
    return 0
  fi
  P="$(_cbox_path_hash "$root")"
  eff="$HOME/.config/cbox/projects/$P"
  if [ ! -f "$eff/cbox.conf" ]; then
    v_t "effective config present for $root"
    v_skip "no project - run 'cbox run claude' first"
    echo "== cbox verify: $VN tests, $VOK ok, $VFAIL failed, $VSKIP skipped =="
    return 0
  fi
  _cbox_manifest_verify_conf "$eff" "$root"

  v_t "manifest verify (conf+generators)"
  v_ok

  cid="$(_compose_p "$eff" ps -q cbox 2>/dev/null)" || cid=""

  v_t "v10 mirror tamper ignored"
  if [ -f "$root/.claude/cbox/docker-compose.yml" ]; then
    local before after
    before="$(sha256sum "$eff/docker-compose.yml" | awk '{print $1}')"
    printf 'tampered: this line must never be read\n' >> "$root/.claude/cbox/docker-compose.yml"
    _compose_p "$eff" config >/dev/null 2>&1 || true
    after="$(sha256sum "$eff/docker-compose.yml" | awk '{print $1}')"
    if [ "$before" = "$after" ]; then v_ok "effdir compose unchanged"; else v_fail "effdir compose mutated"; fi
  else
    v_skip "no mirror written yet"
  fi

  v_t "v11 SIGKILL-then-gc reap"
  if [ -n "$cid" ] && [ -z "${CBOX_VERIFY_NO_KILL:-}" ]; then
    n="$(_probe "$cid" 2>/dev/null)" || n=unknown
    if [ "$n" = 0 ]; then
      docker kill "$cid" >/dev/null 2>&1 || true
      gc >/dev/null 2>&1 || true
      if [ -z "$(_compose_p "$eff" ps -q cbox 2>/dev/null)" ]; then v_ok "reaped"; else v_fail "container survived gc"; fi
    else
      v_skip "container has $n live session(s) - refusing to kill a real session"
    fi
  else
    v_skip "no running container or CBOX_VERIFY_NO_KILL set"
  fi

  v_t "v12 piped claude -p no hang"
  if [ -n "$cid" ] || [ -f "$eff/docker-compose.yml" ]; then
    rc=0
    printf '' | _compose_p "$eff" exec -T cbox timeout 20 /entrypoint.sh true >/dev/null 2>&1 || rc=$?
    if [ "$rc" -ne 124 ]; then v_ok "no timeout"; else v_fail "hung past 20s"; fi
  else
    v_skip "no effective compose"
  fi

  v_t "v13 digest-bump triggers rebuild"
  if command -v docker >/dev/null 2>&1; then
    _cbox_verify_v13_digest_bump "$eff" "$root" || true
  else
    v_skip "docker not available"
  fi

  v_t "v14 slug round-trip vs live claude run"
  local slug slugdir
  slug="$(_cbox_slug "$root")"
  slugdir="$HOME/.claude/projects/$slug"
  if [ -d "$slugdir" ]; then v_ok "$slug"; else v_skip "no session recorded yet under $slugdir - run 'cbox run claude' once"; fi

  v_t "v15 agent-copies-binary still stops (B-2)"
  if [ -n "$cid" ]; then
    n="$(_probe "$cid" 2>/dev/null)" || n=unknown
    if [ "$n" = 0 ]; then
      if docker exec "$cid" sh -c 'cp "$HOME/.local/bin/claude" /tmp/.cbox-verify-copy 2>/dev/null && /tmp/.cbox-verify-copy --version' >/dev/null 2>&1; then
        n="$(_probe "$cid" 2>/dev/null)" || n=unknown
        docker exec "$cid" sh -c 'rm -f /tmp/.cbox-verify-copy' >/dev/null 2>&1 || true
        if [ "$n" = 0 ]; then v_ok "copy not counted"; else v_fail "copy inflated probe count to $n"; fi
      else
        v_skip "could not stage a binary copy in the container"
      fi
    else
      v_skip "container has $n live session(s) already"
    fi
  else
    v_skip "no running container"
  fi

  v_t "v16 buildx-absent digest fallback"
  if command -v docker >/dev/null 2>&1; then
    local stub stubdir dg
    stubdir="$(mktemp -d)"
    stub="$stubdir/docker"
    {
      printf '#!/bin/sh\n'
      printf 'if [ "$1" = buildx ]; then exit 1; fi\n'
      printf 'exec %q "$@"\n' "$(command -v docker)"
    } > "$stub"
    chmod 755 "$stub"
    dg="$(PATH="$stubdir:$PATH" CBOX_BASE_DIGEST_TTL=0 _cbox_resolve_base_digest ubuntu:24.04 2>/dev/null)" || dg=""
    rm -rf "$stubdir"
    if [ -n "$dg" ]; then v_ok "resolved via fallback"; else v_fail "digest resolution failed without buildx"; fi
  else
    v_skip "docker not available"
  fi

  v_t "restart policy is no"
  if grep -q 'restart: "no"' "$eff/docker-compose.yml" 2>/dev/null; then v_ok; else v_fail "restart policy is not \"no\""; fi

  v_t "external bins volumes (cbox-bins-claude/codex)"
  if grep -q 'name: cbox-bins-claude' "$eff/docker-compose.yml" 2>/dev/null \
    && grep -q 'name: cbox-bins-codex' "$eff/docker-compose.yml" 2>/dev/null \
    && grep -q 'external: true' "$eff/docker-compose.yml" 2>/dev/null; then
    v_ok
  else
    v_fail "cbox-bins-claude/codex not declared external"
  fi

  v_t "no claude-home volume overlapping projects/"
  if grep -q 'claude-home' "$eff/docker-compose.yml" 2>/dev/null; then v_fail "claude-home volume present"; else v_ok; fi

  v_t "session-scope isolated mounts only own slug"
  if [ "${CBOX_SESSION_SCOPE:-isolated}" = "isolated" ]; then
    if grep -q "projects/$slug:" "$eff/docker-compose.yml" 2>/dev/null && ! grep -q '\.claude/projects:\${HOST_HOME}' "$eff/docker-compose.yml" 2>/dev/null; then
      v_ok
    else
      v_fail "compose does not scope to slug $slug"
    fi
  else
    v_skip "CBOX_SESSION_SCOPE=global"
  fi

  v_t "workspace B absent in A (label-based cross-project check)"
  if command -v docker >/dev/null 2>&1; then
    local other has_other=0
    for other in "$HOME"/.config/cbox/projects/*/; do
      [ -d "$other" ] || continue
      [ "$(realpath "$other")" = "$(realpath "$eff")" ] && continue
      has_other=1
      break
    done
    if [ "$has_other" = 1 ] && [ -n "$cid" ]; then
      local otherroot
      otherroot="$(cat "$other/workspace" 2>/dev/null || true)"
      if [ -n "$otherroot" ] && docker exec "$cid" sh -c "test -e '$otherroot'" >/dev/null 2>&1; then
        v_fail "$otherroot visible inside this container"
      else
        v_ok "not visible"
      fi
    else
      v_skip "no other project or no running container to check"
    fi
  else
    v_skip "docker not available"
  fi

  v_t "two windows no premature stop / last exit immediate stop"
  v_skip "requires two concurrent live sessions - exercised manually, not by automated verify"

  v_t "two projects share one image (by inputs hash)"
  if command -v docker >/dev/null 2>&1; then
    local other otherhash myhash=""
    myhash="$(_cbox_image_hash "$eff" 2>/dev/null)" || myhash=""
    local found=0
    for other in "$HOME"/.config/cbox/projects/*/; do
      [ -d "$other" ] || continue
      [ "$(realpath "$other")" = "$(realpath "$eff")" ] && continue
      [ -f "$other/image.inputs" ] || continue
      otherhash="$(sha256sum "$other/image.inputs" 2>/dev/null | awk '{print $1}')" || otherhash=""
      if [ -n "$myhash" ] && [ "$otherhash" = "$myhash" ]; then found=1; break; fi
    done
    if [ "$found" = 1 ]; then v_ok "shared image confirmed"; else v_skip "no other project with matching inputs"; fi
  else
    v_skip "docker not available"
  fi

  v_t "claude bins mount read-only (write denied)"
  if [ -n "$cid" ]; then
    if _compose_p "$eff" exec -T cbox /entrypoint.sh sh -c 'touch "$HOME/.local/.cbox-verify"' >/dev/null 2>&1; then
      v_fail "writable"
    else
      v_ok "write denied"
    fi
  else
    v_skip "no running container"
  fi

  v_t "codex bins mount read-only (write denied)"
  if [ -n "$cid" ]; then
    if _compose_p "$eff" exec -T cbox /entrypoint.sh sh -c 'touch "$HOME/.codex/packages/.cbox-verify"' >/dev/null 2>&1; then
      v_fail "writable"
    else
      v_ok "write denied"
    fi
  else
    v_skip "no running container"
  fi

  v_t "claude stamp present and want matches pin"
  if [ -n "$cid" ]; then
    local iso_want iso_got
    iso_want="${CBOX_CLAUDE_TARGET:-stable}"
    if iso_got="$(_compose_p "$eff" exec -T cbox /entrypoint.sh sh -c 'sed -n 1p "$HOME/.local/.cbox-stamp"' 2>/dev/null)" && [ "$iso_got" = "$iso_want" ]; then
      v_ok "$iso_got"
    else
      v_fail "stamp missing or want '${iso_got:-}' != pin '$iso_want'"
    fi
  else
    v_skip "no running container"
  fi

  v_t "codex stamp present and want matches pin"
  if [ -n "$cid" ]; then
    local iso_want iso_got
    iso_want="${CBOX_CODEX_VERSION:-latest}|${CBOX_CODEX_TARGET:-}"
    if iso_got="$(_compose_p "$eff" exec -T cbox /entrypoint.sh sh -c 'sed -n 1p "$HOME/.codex/packages/.cbox-stamp"' 2>/dev/null)" && [ "$iso_got" = "$iso_want" ]; then
      v_ok "$iso_got"
    else
      v_fail "stamp missing or want '${iso_got:-}' != pin '$iso_want'"
    fi
  else
    v_skip "no running container"
  fi

  v_t "resolved binaries executable and match stamp"
  if [ -n "$cid" ]; then
    if _compose_p "$eff" exec -T cbox /entrypoint.sh sh -c '
for f in "$HOME/.local/.cbox-stamp" "$HOME/.codex/packages/.cbox-stamp"; do
  p="$(sed -n 2p "$f")"
  v="$(sed -n 4p "$f")"
  test -n "$p" && test -x "$p" || exit 1
  case "$("$p" --version 2>&1)" in *"$v"*) ;; *) exit 1;; esac
done
' >/dev/null 2>&1; then
      v_ok
    else
      v_fail "resolved binary missing, not executable, or --version does not match stamp"
    fi
  else
    v_skip "no running container"
  fi

  v_t "bins volumes are the shared global names, not per-project"
  if grep -oE 'name: cbox-bins-(claude|codex)(-[0-9a-f]{8})?' "$eff/docker-compose.yml" 2>/dev/null \
    | grep -qE -- '-[0-9a-f]{8}$'; then
    v_skip "CBOX_BINS_SCOPE=pinned - per-tool private volume by design"
  elif grep -q 'name: cbox-bins-claude$' "$eff/docker-compose.yml" 2>/dev/null \
    && grep -q 'name: cbox-bins-codex$' "$eff/docker-compose.yml" 2>/dev/null; then
    v_ok "global cbox-bins-claude/codex"
  else
    v_fail "bins volume names are not the fixed global cbox-bins-claude/codex pair"
  fi

  v_t "two effdir composes reference the same bins volume names"
  local other_eff found_share=0
  for other_eff in "$HOME"/.config/cbox/projects/*/; do
    [ -d "$other_eff" ] || continue
    [ "$(realpath "$other_eff")" = "$(realpath "$eff")" ] && continue
    [ -f "$other_eff/docker-compose.yml" ] || continue
    if grep -q 'name: cbox-bins-claude$' "$eff/docker-compose.yml" 2>/dev/null \
      && grep -q 'name: cbox-bins-claude$' "$other_eff/docker-compose.yml" 2>/dev/null; then
      found_share=1
      break
    fi
  done
  if [ "$found_share" = 1 ]; then
    v_ok "shared with $(basename "$other_eff")"
  else
    v_skip "no other project with a matching global bins volume name"
  fi

  echo "== cbox verify: $VN tests, $VOK ok, $VFAIL failed, $VSKIP skipped =="
  [ "$VFAIL" -eq 0 ] || exit 1
}

usage() {
  echo "usage: $0 {run <bin> [args]|up [--gpu]|down|restart [--gpu]|shell|logs [args]|update|reinstall-bins [--fresh|--if-stale]|install-hooks|verify [--gpu|--isolated]|backup|login-codex|gc|ls|images [list|rm <hash>]}"
  exit 1
}

case "${1:-}" in
  run) shift; run "$@";;
  up) shift; up "$@";;
  down)
    case "$(_cbox_effective_mode)" in
      isolated) down_project;;
      global) down;;
      *) die_no_conf;;
    esac
    ;;
  restart) shift; restart "$@";;
  shell) shell;;
  logs) shift; logs "$@";;
  update) shift; reinstall_bins "$@";;
  reinstall-bins) shift; reinstall_bins "$@";;
  install-hooks) install_hooks;;
  verify)
    shift
    if [ "${1:-}" = "--isolated" ]; then
      shift
      verify_isolated "$@"
    else
      case "$(_cbox_effective_mode)" in
        isolated) verify_isolated "$@";;
        global) verify "$@";;
        *) die_no_conf;;
      esac
    fi
    ;;
  backup) backup;;
  login-codex) login_codex;;
  gc) gc;;
  ls) ls_projects;;
  images) shift; images_cmd "$@";;
  *) usage;;
esac
