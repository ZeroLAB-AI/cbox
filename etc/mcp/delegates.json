{
  "codex-terra-light": {
    "type": "stdio",
    "command": "codex",
    "args": [
      "mcp-server"
    ],
    "_cbox": {
      "adapter": "codex-mcp",
      "available_to": [
        "claude"
      ],
      "backend": "codex",
      "side_effects": [
        "spawns-codex-subprocess"
      ],
      "model": "gpt-5.6-terra",
      "model_reasoning_effort": "medium"
    }
  },
  "codex-sol": {
    "type": "stdio",
    "command": "codex",
    "args": [
      "mcp-server"
    ],
    "_cbox": {
      "adapter": "codex-mcp",
      "available_to": [
        "claude"
      ],
      "backend": "codex",
      "side_effects": [
        "spawns-codex-subprocess"
      ],
      "model": "gpt-5.6-sol",
      "model_reasoning_effort": "xhigh"
    }
  },
  "codex-terra": {
    "type": "stdio",
    "command": "codex",
    "args": [
      "mcp-server"
    ],
    "_cbox": {
      "adapter": "codex-mcp",
      "available_to": [
        "claude"
      ],
      "backend": "codex",
      "side_effects": [
        "spawns-codex-subprocess"
      ],
      "model": "gpt-5.6-terra",
      "model_reasoning_effort": "max"
    }
  },
  "codex-luna": {
    "type": "stdio",
    "command": "codex",
    "args": [
      "mcp-server"
    ],
    "_cbox": {
      "adapter": "codex-mcp",
      "available_to": [
        "claude"
      ],
      "backend": "codex",
      "side_effects": [
        "spawns-codex-subprocess"
      ],
      "model": "gpt-5.6-luna",
      "model_reasoning_effort": "max"
    }
  },
  "ask-claude": {
    "_cbox": {
      "adapter": "claude-cli",
      "available_to": [
        "codex"
      ],
      "backend": "claude",
      "side_effects": [
        "spawns-claude-subprocess"
      ],
      "command": "python3",
      "script": "ask_claude_mcp.py",
      "startup_timeout_sec": 30,
      "tool_timeout_sec": 3600
    }
  },
  "local-qwen": {
    "type": "stdio",
    "command": "python3",
    "args": [
      "local_model_mcp.py"
    ],
    "env": {
      "CBOX_LOCAL_MODEL_URL": "@CBOX_LOCAL_MODEL_URL@",
      "CBOX_LOCAL_MODEL_NAME": "@CBOX_LOCAL_MODEL_NAME@"
    },
    "_cbox": {
      "adapter": "stdio-mcp",
      "available_to": [
        "claude",
        "codex"
      ],
      "backend": "ollama",
      "side_effects": [
        "text-only"
      ],
      "enabled_when_env": "CBOX_LOCAL_MODEL_URL"
    }
  },
  "hermes-local": {
    "type": "stdio",
    "command": "python3",
    "args": [
      "hermes_delegate_mcp.py"
    ],
    "env": {
      "HERMES_BIN": "@CBOX_HERMES_DELEGATE_BIN@",
      "CBOX_HERMES_DELEGATE_HOME_TEMPLATE": "@CBOX_HERMES_DELEGATE_HOME_TEMPLATE@",
      "CBOX_HERMES_DELEGATE_PROVIDER": "@CBOX_HERMES_DELEGATE_PROVIDER@",
      "CBOX_HERMES_DELEGATE_BASE_URL": "@CBOX_HERMES_DELEGATE_BASE_URL@",
      "CBOX_HERMES_DELEGATE_MODEL": "@CBOX_HERMES_DELEGATE_MODEL@"
    },
    "_cbox": {
      "adapter": "stdio-mcp",
      "available_to": [
        "claude"
      ],
      "backend": "hermes",
      "side_effects": [
        "spawns-hermes-subprocess"
      ],
      "enabled_when_env": "CBOX_HERMES_DELEGATE"
    }
  }
}
